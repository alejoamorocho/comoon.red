{
  "name": "comoon",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler pages dev ./dist",
    "astro": "astro",
    "db:create": "wrangler d1 create comoon-db",
    "db:schema": "wrangler d1 execute comoon-db --local --file=./src/db/schema.sql",
    "db:seed": "wrangler d1 execute comoon-db --local --file=./src/db/seed.sql",
    "db:setup": "npm run db:schema && npm run db:seed",
    "db:reset": "npm run db:schema && npm run db:seed",
    "db:migrate:local": "npx wrangler d1 execute comoon-db --local --file=./migrations/001_normalize_tags.sql && npx wrangler d1 execute comoon-db --local --file=./migrations/002_add_constraints.sql",
    "db:migrate:remote": "npx wrangler d1 execute comoon-db --remote --file=./migrations/001_normalize_tags.sql && npx wrangler d1 execute comoon-db --remote --file=./migrations/002_add_constraints.sql",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,astro,css}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,astro,css}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest run --config vitest.config.components.ts",
    "test:coverage": "vitest run --coverage",
    "typecheck": "astro check && tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.astro": [
      "prettier --write --plugin=prettier-plugin-astro"
    ],
    "*.css": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/react": "^4.4.2",
    "@astrojs/tailwind": "^6.0.2",
    "@phosphor-icons/react": "^2.1.10",
    "astro": "^5.16.15",
    "clsx": "^2.1.1",
    "hono": "^4.11.5",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.19",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260124.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.11.0"
  }
}
