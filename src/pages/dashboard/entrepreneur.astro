---
import Layout from '../../layouts/Layout.astro';
import DashboardTabs from '../../components/dashboard/DashboardTabs.astro';
import StatCard from '../../components/dashboard/StatCard.astro';
import QuickActions from '../../components/dashboard/QuickActions.astro';
import ProfileCompletionCard from '../../components/dashboard/ProfileCompletionCard.astro';
import CreateProductForm from '../../components/dashboard/CreateProductForm';
import EditEntrepreneurProfileForm from '../../components/dashboard/EditEntrepreneurProfileForm';
import {
  PlusCircle,
  Tag,
  Eye,
  PencilSimple,
  Storefront,
  CurrencyDollar,
  ShoppingBag,
  Heart,
  Trash,
} from '@phosphor-icons/react';
import { formatCOP as formatCurrency } from '../../utils/format';
import {
  getEntrepreneurCompletionPercentage,
  getEntrepreneurMissingFields,
} from '../../utils/profileCompletion';

// Read tab from query params
const url = new URL(Astro.request.url);
const activeTab = url.searchParams.get('tab') || 'overview';

const tabs = [
  { id: 'overview', label: 'Resumen' },
  { id: 'productos', label: 'Mis Productos' },
  { id: 'agregar', label: 'Agregar Producto' },
  { id: 'causas', label: 'Causas que Apoyo' },
  { id: 'perfil', label: 'Mi Perfil' },
];

// Fetch real data from DB
const user = Astro.locals.user;
const db = Astro.locals.runtime?.env?.DB;

let entrepreneurProfile: Record<string, any> = {
  id: 0,
  storeName: '',
  location: '',
  photo: '',
  bio: '',
  isVerified: false,
};
let myProducts: Array<Record<string, any>> = [];
let supportedCauses: Array<Record<string, any>> = [];
let stats = { totalProducts: 0, totalContributed: 0, causesSupported: 0, totalSales: 0 };

if (db && user?.profileId) {
  // Fetch entrepreneur profile
  const entrepreneur = await db
    .prepare('SELECT * FROM entrepreneurs WHERE id = ?')
    .bind(user.profileId)
    .first();
  if (entrepreneur) {
    entrepreneurProfile = {
      id: entrepreneur.id,
      storeName: entrepreneur.store_name || '',
      location:
        entrepreneur.city && entrepreneur.department
          ? `${entrepreneur.city}, ${entrepreneur.department}`
          : entrepreneur.location || '',
      photo: entrepreneur.photo_url || '',
      bio: entrepreneur.bio || '',
      isVerified: Boolean(entrepreneur.is_verified),
      store_name: entrepreneur.store_name || '',
      department: entrepreneur.department || '',
      city: entrepreneur.city || '',
      contact_info: entrepreneur.contact_info || '{}',
      photo_url: entrepreneur.photo_url || '',
    };

    // Fetch products with cause info
    const { results: productsData } = await db
      .prepare(
        `
            SELECT p.*, c.title as cause_title, c.id as cause_id_ref
            FROM products p
            LEFT JOIN causes c ON p.cause_id = c.id
            WHERE p.entrepreneur_id = ?
            ORDER BY p.created_at DESC
        `,
      )
      .bind(user.profileId)
      .all();

    myProducts = (productsData || []).map((p: any) => ({
      id: p.id,
      name: p.name,
      price: p.price,
      photo: p.photo_url,
      cause: { id: p.cause_id_ref, title: p.cause_title || 'Sin causa' },
      contribution:
        p.contribution_type === 'percentage'
          ? `${p.contribution_amount}%`
          : formatCurrency(p.contribution_amount || 0),
      contributionType: p.contribution_type,
      contributionAmount: p.contribution_amount,
      isActive: Boolean(p.is_active),
    }));

    // Calculate stats
    const activeProducts = myProducts.filter((p) => p.isActive);
    stats.totalProducts = activeProducts.length;

    // Get supported causes with aggregated data
    const { results: causesData } = await db
      .prepare(
        `
            SELECT c.id, c.title, l.name as leader, c.current_amount as raised, c.target_goal as goal,
                   COUNT(p.id) as my_products
            FROM causes c
            JOIN products p ON p.cause_id = c.id
            JOIN leaders l ON c.leader_id = l.id
            WHERE p.entrepreneur_id = ?
            GROUP BY c.id
        `,
      )
      .bind(user.profileId)
      .all();

    supportedCauses = (causesData || []).map((c: any) => ({
      id: c.id,
      title: c.title,
      leader: c.leader,
      raised: c.raised || 0,
      goal: c.goal || 0,
      myProducts: c.my_products,
      myContribution: 0,
    }));

    stats.causesSupported = supportedCauses.length;
  }
}

const profileCompletion = getEntrepreneurCompletionPercentage({
  store_name: entrepreneurProfile.storeName,
  bio: entrepreneurProfile.bio,
  photo_url: entrepreneurProfile.photo,
  location: entrepreneurProfile.location,
  activeProductsCount: stats.totalProducts,
});

const missingFields = getEntrepreneurMissingFields({
  store_name: entrepreneurProfile.storeName,
  bio: entrepreneurProfile.bio,
  photo_url: entrepreneurProfile.photo,
  location: entrepreneurProfile.location,
  activeProductsCount: stats.totalProducts,
});
---

<Layout title="Dashboard Emprendedor">
  <div class="max-w-6xl mx-auto py-8 px-4">
    <!-- Header with Profile -->
    <div class="glass p-6 rounded-xl mb-6 flex flex-col md:flex-row items-center gap-6">
      {
        entrepreneurProfile.photo ? (
          <img
            src={entrepreneurProfile.photo}
            alt={entrepreneurProfile.storeName}
            class="w-20 h-20 rounded-xl object-cover border-4 border-entrepreneur"
          />
        ) : (
          <div class="w-20 h-20 rounded-xl bg-entrepreneur/20 flex items-center justify-center border-4 border-entrepreneur">
            <span class="text-2xl font-bold text-entrepreneur">
              {entrepreneurProfile.storeName?.charAt(0) || 'E'}
            </span>
          </div>
        )
      }
      <div class="flex-1 text-center md:text-left">
        <div class="flex items-center gap-2 justify-center md:justify-start">
          <h1 class="text-2xl font-bold text-white">
            {entrepreneurProfile.storeName || 'Mi Tienda'}
          </h1>
          {
            entrepreneurProfile.isVerified && (
              <span class="bg-dracula-green/20 text-dracula-green text-xs px-2 py-1 rounded-full font-bold">
                Verificado
              </span>
            )
          }
        </div>
        <p class="text-dracula-comment text-sm">{entrepreneurProfile.location}</p>
        <p class="text-entrepreneur font-medium mt-1 text-sm">Emprendedor</p>
      </div>
      <a
        href={`/entrepreneurs/${entrepreneurProfile.id}`}
        class="px-4 py-2 bg-dracula-current text-white rounded-lg hover:bg-dracula-comment transition-colors flex items-center gap-2 text-sm"
      >
        <Eye size={18} />
        Ver Tienda Publica
      </a>
    </div>

    <!-- Tabs Navigation -->
    <DashboardTabs
      tabs={tabs}
      activeTab={activeTab}
      baseUrl="/dashboard/entrepreneur"
      accentColor="entrepreneur"
    />

    <!-- Tab: Overview -->
    {
      activeTab === 'overview' && (
        <div class="space-y-6">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <StatCard value={stats.totalProducts} label="Productos Activos">
              <ShoppingBag slot="icon" size={28} className="mx-auto text-entrepreneur" />
            </StatCard>
            <StatCard value={formatCurrency(stats.totalContributed)} label="Total Donado">
              <CurrencyDollar slot="icon" size={28} className="mx-auto text-dracula-green" />
            </StatCard>
            <StatCard value={stats.causesSupported} label="Causas Apoyadas">
              <Heart slot="icon" size={28} className="mx-auto text-dracula-pink" />
            </StatCard>
            <StatCard value={stats.totalSales} label="Ventas Totales">
              <Storefront slot="icon" size={28} className="mx-auto text-dracula-orange" />
            </StatCard>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <ProfileCompletionCard
              percentage={profileCompletion}
              missingFields={missingFields}
              accentColor="entrepreneur"
            />
            <QuickActions
              actions={[
                {
                  label: 'Agregar Producto',
                  href: '/dashboard/entrepreneur?tab=agregar',
                  color: 'entrepreneur',
                },
                {
                  label: 'Ver Tienda',
                  href: `/entrepreneurs/${entrepreneurProfile.id}`,
                  color: 'dracula-purple',
                },
                { label: 'Explorar Causas', href: '/leaders', color: 'leader' },
              ]}
            />
          </div>

          <div class="grid lg:grid-cols-3 gap-6">
            <div class="lg:col-span-2 glass p-6 rounded-xl">
              <h3 class="font-bold text-white mb-4">Productos Recientes</h3>
              {myProducts.length > 0 ? (
                <div class="space-y-3">
                  {myProducts.slice(0, 3).map((product) => (
                    <div class="flex items-center gap-4 p-3 bg-dracula-bg/50 rounded-lg">
                      {product.photo ? (
                        <img
                          src={product.photo}
                          alt={product.name}
                          class="w-12 h-12 rounded-lg object-cover"
                        />
                      ) : (
                        <div class="w-12 h-12 rounded-lg bg-entrepreneur/20 flex items-center justify-center">
                          <ShoppingBag size={20} className="text-entrepreneur" />
                        </div>
                      )}
                      <div class="flex-1 min-w-0">
                        <p class="text-sm text-white font-medium truncate">{product.name}</p>
                        <p class="text-xs text-leader flex items-center gap-1">
                          <Heart size={10} />
                          {product.cause.title}
                        </p>
                      </div>
                      <span class="text-sm font-bold text-dracula-green">
                        {formatCurrency(product.price)}
                      </span>
                    </div>
                  ))}
                </div>
              ) : (
                <p class="text-dracula-comment text-sm">
                  No tienes productos aun. Agrega tu primer producto!
                </p>
              )}
              {myProducts.length > 3 && (
                <a
                  href="/dashboard/entrepreneur?tab=productos"
                  class="block text-center text-entrepreneur text-sm mt-4 hover:underline"
                >
                  Ver todos los productos
                </a>
              )}
            </div>

            <div class="glass p-6 rounded-xl">
              <h3 class="font-bold text-white mb-4 flex items-center gap-2">
                <Heart className="text-dracula-pink" size={20} />
                Causas que Apoyas
              </h3>
              {supportedCauses.length > 0 ? (
                <div class="space-y-3">
                  {supportedCauses.map((cause) => (
                    <a
                      href={`/causes/${cause.id}`}
                      class="block p-3 bg-dracula-bg/50 rounded-lg hover:bg-dracula-current/50 transition-colors"
                    >
                      <h4 class="font-medium text-white text-sm">{cause.title}</h4>
                      <p class="text-xs text-dracula-comment">{cause.leader}</p>
                      {cause.goal > 0 && (
                        <div class="w-full bg-dracula-current h-1 rounded-full mt-2 overflow-hidden">
                          <div
                            class="bg-leader h-full rounded-full"
                            style={`width: ${Math.min((cause.raised / cause.goal) * 100, 100)}%`}
                          />
                        </div>
                      )}
                    </a>
                  ))}
                </div>
              ) : (
                <p class="text-dracula-comment text-sm">
                  Vincula productos a causas para verlas aqui.
                </p>
              )}
            </div>
          </div>
        </div>
      )
    }

    <!-- Tab: Productos -->
    {
      activeTab === 'productos' && (
        <div class="space-y-4">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-white flex items-center gap-2">
              <Tag className="text-dracula-orange" size={24} />
              Mis Productos
            </h2>
            <a
              href="/dashboard/entrepreneur?tab=agregar"
              class="px-4 py-2 bg-entrepreneur text-dracula-bg rounded-lg font-bold text-sm hover:brightness-110 transition-all flex items-center gap-2"
            >
              <PlusCircle size={18} />
              Nuevo Producto
            </a>
          </div>
          {myProducts.length > 0 ? (
            <div class="space-y-3">
              {myProducts.map((product) => (
                <div class="glass p-5 rounded-xl flex flex-col md:flex-row items-center gap-5">
                  {product.photo ? (
                    <img
                      src={product.photo}
                      alt={product.name}
                      class="w-24 h-24 rounded-xl object-cover"
                    />
                  ) : (
                    <div class="w-24 h-24 rounded-xl bg-entrepreneur/20 flex items-center justify-center">
                      <ShoppingBag size={32} className="text-entrepreneur" />
                    </div>
                  )}
                  <div class="flex-1 text-center md:text-left">
                    <h4 class="font-bold text-white text-lg">{product.name}</h4>
                    <p class="text-sm text-leader flex items-center gap-1 mt-1 justify-center md:justify-start">
                      <Heart size={14} />
                      Apoya: {product.cause.title}
                    </p>
                    <p class="text-xs text-dracula-comment mt-1">
                      Contribucion: {product.contribution} por venta
                    </p>
                  </div>
                  <div class="text-center">
                    <p class="font-bold text-dracula-green text-xl">
                      {formatCurrency(product.price)}
                    </p>
                    <div class="flex gap-2 mt-3 justify-center">
                      <a
                        href={`/store/${product.id}`}
                        class="p-2 text-dracula-fg/60 hover:text-entrepreneur transition-colors rounded-lg hover:bg-dracula-current"
                        title="Ver"
                      >
                        <Eye size={18} />
                      </a>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="glass p-12 rounded-xl text-center">
              <ShoppingBag size={48} className="mx-auto mb-4 text-dracula-comment" />
              <p class="text-dracula-comment mb-4">No tienes productos aun.</p>
              <a
                href="/dashboard/entrepreneur?tab=agregar"
                class="inline-flex items-center gap-2 px-6 py-3 bg-entrepreneur text-dracula-bg font-bold rounded-xl hover:brightness-110 transition-all"
              >
                <PlusCircle size={20} />
                Agregar tu primer producto
              </a>
            </div>
          )}
        </div>
      )
    }

    <!-- Tab: Agregar Producto (React Form) -->
    {
      activeTab === 'agregar' && (
        <div class="max-w-3xl mx-auto">
          <div class="glass p-6 rounded-xl">
            <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
              <PlusCircle className="text-entrepreneur" size={24} />
              Agregar Nuevo Producto
            </h2>
            <CreateProductForm client:visible />
          </div>
        </div>
      )
    }

    <!-- Tab: Causas que Apoyo -->
    {
      activeTab === 'causas' && (
        <div class="space-y-4">
          <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
            <Heart className="text-dracula-pink" size={24} />
            Causas que Apoyas
          </h2>
          {supportedCauses.length > 0 ? (
            <>
              {supportedCauses.map((cause) => (
                <div class="glass p-6 rounded-xl">
                  <div class="flex items-start justify-between mb-4">
                    <div>
                      <h3 class="font-bold text-white text-lg">{cause.title}</h3>
                      <p class="text-sm text-dracula-comment">{cause.leader}</p>
                    </div>
                    <a href={`/causes/${cause.id}`} class="text-leader text-sm hover:underline">
                      Ver causa
                    </a>
                  </div>
                  {cause.goal > 0 && (
                    <div class="mb-4">
                      <div class="flex justify-between text-sm mb-1">
                        <span class="text-dracula-green font-bold">
                          {formatCurrency(cause.raised)}
                        </span>
                        <span class="text-dracula-comment">de {formatCurrency(cause.goal)}</span>
                      </div>
                      <div class="w-full bg-dracula-current h-2 rounded-full overflow-hidden">
                        <div
                          class="bg-gradient-to-r from-dracula-green to-leader h-full rounded-full"
                          style={`width: ${Math.min((cause.raised / cause.goal) * 100, 100)}%`}
                        />
                      </div>
                    </div>
                  )}
                  <div class="grid grid-cols-2 gap-4 text-center bg-dracula-bg/50 p-4 rounded-lg">
                    <div>
                      <p class="text-lg font-bold text-entrepreneur">{cause.myProducts}</p>
                      <p class="text-xs text-dracula-comment">Productos vinculados</p>
                    </div>
                    <div>
                      <p class="text-lg font-bold text-dracula-green">
                        {formatCurrency(cause.myContribution)}
                      </p>
                      <p class="text-xs text-dracula-comment">Total contribuido</p>
                    </div>
                  </div>
                </div>
              ))}
            </>
          ) : (
            <div class="glass p-12 rounded-xl text-center">
              <Heart size={48} className="mx-auto mb-4 text-dracula-comment" />
              <p class="text-dracula-comment mb-4">
                Aun no apoyas ninguna causa. Vincula un producto a una causa!
              </p>
            </div>
          )}
          <div class="text-center mt-6">
            <a
              href="/leaders"
              class="inline-flex items-center gap-2 px-6 py-3 border-2 border-leader text-leader font-bold rounded-xl hover:bg-leader/10 transition-colors"
            >
              Explorar mas causas
            </a>
          </div>
        </div>
      )
    }

    <!-- Tab: Perfil (React Form) -->
    {
      activeTab === 'perfil' && (
        <div class="max-w-3xl mx-auto space-y-6">
          <div class="glass p-6 rounded-xl">
            <h2 class="text-xl font-bold text-white mb-6">Editar Perfil de Tienda</h2>
            <EditEntrepreneurProfileForm
              client:visible
              profileId={user?.profileId || 0}
              initialData={{
                store_name: entrepreneurProfile.store_name || entrepreneurProfile.storeName,
                bio: entrepreneurProfile.bio,
                photo_url: entrepreneurProfile.photo_url || entrepreneurProfile.photo,
                department: entrepreneurProfile.department || '',
                city: entrepreneurProfile.city || '',
                contact_info: entrepreneurProfile.contact_info || '{}',
              }}
            />
          </div>
          <div class="glass p-6 rounded-xl">
            <h3 class="font-bold text-white mb-2">Seguridad</h3>
            <a href="#" class="text-sm text-dracula-purple hover:underline">
              Cambiar contrasena
            </a>
          </div>
        </div>
      )
    }
  </div>
</Layout>
