---
import Layout from '../../layouts/Layout.astro';
import DashboardTabs from '../../components/dashboard/DashboardTabs.astro';
import StatCard from '../../components/dashboard/StatCard.astro';
import QuickActions from '../../components/dashboard/QuickActions.astro';
import ProfileCompletionCard from '../../components/dashboard/ProfileCompletionCard.astro';
import CreateCauseForm from '../../components/dashboard/CreateCauseForm';
import CreateProductForm from '../../components/dashboard/CreateProductForm';
import EditLeaderProfileForm from '../../components/dashboard/EditLeaderProfileForm';
import EditCauseForm from '../../components/dashboard/EditCauseForm';
import EditProductForm from '../../components/dashboard/EditProductForm';
import CauseManagementList from '../../components/dashboard/CauseManagementList';
import ProductManagementList from '../../components/dashboard/ProductManagementList';
import { LeaderTagsList } from '../../components/LeaderTagBadge';
import {
  PlusCircle,
  Trophy,
  Users,
  CurrencyDollar,
  Eye,
  PencilSimple,
  ChartLineUp,
  Newspaper,
  Heart,
  CheckCircle,
  ShoppingBag,
} from '@phosphor-icons/react';
import { formatCOP as formatCurrency } from '../../utils/format';
import {
  getLeaderCompletionPercentage,
  getLeaderMissingFields,
} from '../../utils/profileCompletion';

// Read tab from query params
const url = new URL(Astro.request.url);
const activeTab = url.searchParams.get('tab') || 'overview';

const tabs = [
  { id: 'overview', label: 'Resumen' },
  { id: 'causas', label: 'Mis Causas' },
  { id: 'productos', label: 'Mi Tienda' },
  { id: 'crear', label: 'Crear Causa' },
  { id: 'updates', label: 'Actualizaciones' },
  { id: 'perfil', label: 'Mi Perfil' },
];

// Fetch real data from DB
const user = Astro.locals.user;
const db = Astro.locals.runtime?.env?.DB;

let leaderProfile: Record<string, any> = {
  id: 0,
  name: '',
  location: '',
  photo: '',
  bio: '',
  isVerified: false,
  tags: [],
};
let myCauses: Array<Record<string, any>> = [];
let alliedEntrepreneurs: Array<Record<string, any>> = [];
let leaderProducts: Array<Record<string, any>> = [];
let stats = {
  totalRaised: 0,
  totalGoal: 0,
  entrepreneursAllied: 0,
  activeCauses: 0,
  totalProducts: 0,
};
let recentUpdates: Array<Record<string, any>> = [];

if (db && user?.profileId) {
  // Fetch leader profile
  const leader = await db
    .prepare('SELECT * FROM leaders WHERE id = ?')
    .bind(user.profileId)
    .first();
  if (leader) {
    const parsedTags = leader.tags ? JSON.parse(leader.tags as string) : [];
    leaderProfile = {
      id: leader.id,
      name: leader.name || '',
      location:
        leader.city && leader.department
          ? `${leader.city}, ${leader.department}`
          : leader.location || '',
      photo: leader.photo_url || '',
      bio: leader.bio || '',
      isVerified: Boolean(leader.is_verified),
      tags: parsedTags,
      department: leader.department || '',
      city: leader.city || '',
      contact_info: leader.contact_info || '{}',
      photo_url: leader.photo_url || '',
      tags_raw: leader.tags || '[]',
      cover_url: leader.cover_url || '',
      organization_name: leader.organization_name || '',
      who_we_are: leader.who_we_are || '',
      our_why: leader.our_why || '',
      how_to_help: leader.how_to_help || '',
      years_active: leader.years_active || null,
      impact_scope: leader.impact_scope || '',
      community: leader.community || '',
      areas_of_influence: leader.areas_of_influence || '[]',
      people_impacted: leader.people_impacted || null,
      achievements: leader.achievements || '[]',
      testimonials: leader.testimonials || '[]',
      media_gallery: leader.media_gallery || '[]',
      awards: leader.awards || '[]',
      email: leader.email || '',
      preferred_contact: leader.preferred_contact || '',
    };

    // Fetch causes
    const { results: causesData } = await db
      .prepare('SELECT * FROM causes WHERE leader_id = ? ORDER BY created_at DESC')
      .bind(user.profileId)
      .all();
    myCauses = (causesData || []).map((c: any) => ({
      id: c.id,
      title: c.title,
      description: c.description,
      raised: c.current_amount || 0,
      goal: c.target_goal || 0,
      status: c.status,
      productsLinked: 0,
      createdAt: c.created_at,
    }));

    // Count products linked to each cause
    for (const cause of myCauses) {
      const countResult = await db
        .prepare('SELECT COUNT(*) as count FROM products WHERE cause_id = ? AND is_active = 1')
        .bind(cause.id)
        .first<{ count: number }>();
      cause.productsLinked = countResult?.count || 0;
    }

    // Calculate stats
    const activeCauses = myCauses.filter((c) => c.status === 'active');
    stats.activeCauses = activeCauses.length;
    stats.totalRaised = myCauses.reduce((sum, c) => sum + c.raised, 0);
    stats.totalGoal = myCauses.reduce((sum, c) => sum + c.goal, 0);
    stats.totalProducts = myCauses.reduce((sum, c) => sum + c.productsLinked, 0);

    // Get allied entrepreneurs
    const { results: entrepreneurs } = await db
      .prepare(
        `
            SELECT DISTINCT e.id, e.store_name, e.photo_url, COUNT(p.id) as product_count
            FROM entrepreneurs e
            JOIN products p ON e.id = p.entrepreneur_id
            JOIN causes c ON p.cause_id = c.id
            WHERE c.leader_id = ?
            GROUP BY e.id
        `,
      )
      .bind(user.profileId)
      .all();
    alliedEntrepreneurs = (entrepreneurs || []).map((e: any) => ({
      id: e.id,
      name: e.store_name,
      photo: e.photo_url,
      products: e.product_count,
    }));
    stats.entrepreneursAllied = alliedEntrepreneurs.length;

    // Get leader's products (own + allied)
    const { results: leaderProductRows } = await db
      .prepare(
        `
            SELECT p.*,
                CASE WHEN p.leader_id IS NOT NULL THEN pl.name ELSE e.store_name END as seller_name,
                c.title as cause_title
            FROM products p
            LEFT JOIN entrepreneurs e ON p.entrepreneur_id = e.id
            LEFT JOIN leaders pl ON p.leader_id = pl.id
            JOIN causes c ON p.cause_id = c.id
            WHERE (p.leader_id = ? OR c.leader_id = ?) AND p.is_active = 1
            ORDER BY p.created_at DESC
        `,
      )
      .bind(user.profileId, user.profileId)
      .all();
    leaderProducts = (leaderProductRows || []).map((p: any) => ({
      id: p.id,
      name: p.name,
      price: p.price,
      sellerName: p.seller_name,
      causeName: p.cause_title,
      isOwn: p.leader_id === user!.profileId,
      photoUrl: p.photo_url,
      createdAt: p.created_at,
    }));

    // Get recent cause updates
    const { results: updates } = await db
      .prepare(
        `
            SELECT cu.* FROM cause_updates cu
            JOIN causes c ON cu.cause_id = c.id
            WHERE c.leader_id = ?
            ORDER BY cu.created_at DESC LIMIT 5
        `,
      )
      .bind(user.profileId)
      .all();
    recentUpdates = (updates || []).map((u: any) => ({
      id: u.id,
      title: u.title,
      cause: '',
      type: u.update_type,
      date: u.created_at,
    }));
  }
}

// Fetch data for edit forms
const editCauseId = url.searchParams.get('id');
let editCauseData: Record<string, any> | null = null;
let editProductData: Record<string, any> | null = null;

if (db && user?.profileId && activeTab === 'editar-causa' && editCauseId) {
  editCauseData = await db
    .prepare('SELECT * FROM causes WHERE id = ? AND leader_id = ?')
    .bind(parseInt(editCauseId), user.profileId)
    .first();
}

if (db && user?.profileId && activeTab === 'editar-producto' && editCauseId) {
  const productRow = await db
    .prepare(
      'SELECT p.*, c.title as cause_title FROM products p JOIN causes c ON p.cause_id = c.id WHERE p.id = ? AND (p.leader_id = ? OR EXISTS (SELECT 1 FROM causes c2 WHERE c2.id = p.cause_id AND c2.leader_id = ?))',
    )
    .bind(parseInt(editCauseId), user.profileId, user.profileId)
    .first();
  if (productRow) {
    editProductData = productRow;
  }
}

// Build product counts for CauseManagementList
const productCounts: Record<number, number> = {};
for (const cause of myCauses) {
  productCounts[cause.id] = cause.productsLinked;
}

const leaderProfileData = {
  name: leaderProfile.name,
  bio: leaderProfile.bio,
  photo_url: leaderProfile.photo,
  location: leaderProfile.location,
  tags: leaderProfile.tags,
  activeCausesCount: stats.activeCauses,
  who_we_are: leaderProfile.who_we_are || '',
  our_why: leaderProfile.our_why || '',
  how_to_help: leaderProfile.how_to_help || '',
  contact_info: leaderProfile.contact_info || '{}',
  people_impacted: leaderProfile.people_impacted || null,
  achievements: leaderProfile.achievements || '[]',
  testimonials: leaderProfile.testimonials || '[]',
};

const profileCompletion = getLeaderCompletionPercentage(leaderProfileData);
const missingFields = getLeaderMissingFields(leaderProfileData);
---

<Layout title="Dashboard Lider">
  <div class="max-w-6xl mx-auto py-8 px-4">
    <!-- Header with Profile -->
    <div class="glass p-6 rounded-xl mb-6 flex flex-col md:flex-row items-center gap-6">
      {
        leaderProfile.photo ? (
          <img
            src={leaderProfile.photo}
            alt={leaderProfile.name}
            class="w-20 h-20 rounded-full object-cover border-4 border-leader"
          />
        ) : (
          <div class="w-20 h-20 rounded-full bg-leader/20 flex items-center justify-center border-4 border-leader">
            <span class="text-2xl font-bold text-leader">
              {leaderProfile.name?.charAt(0) || 'L'}
            </span>
          </div>
        )
      }
      <div class="flex-1 text-center md:text-left">
        <div class="flex items-center gap-2 justify-center md:justify-start">
          <h1 class="text-2xl font-bold text-white">{leaderProfile.name || 'Mi Perfil'}</h1>
          {
            leaderProfile.isVerified && (
              <span class="bg-dracula-green/20 text-dracula-green text-xs px-2 py-1 rounded-full font-bold">
                Verificado
              </span>
            )
          }
        </div>
        <p class="text-dracula-comment text-sm">{leaderProfile.location}</p>
        {
          leaderProfile.tags && leaderProfile.tags.length > 0 && (
            <div class="mt-2">
              <LeaderTagsList client:visible tags={leaderProfile.tags} size="sm" maxVisible={4} />
            </div>
          )
        }
      </div>
      <a
        href={`/leaders/${leaderProfile.id}`}
        class="px-4 py-2 bg-dracula-current text-white rounded-lg hover:bg-dracula-comment transition-colors flex items-center gap-2 text-sm"
      >
        <Eye size={18} />
        Ver Perfil Publico
      </a>
    </div>

    <!-- Tabs Navigation -->
    <DashboardTabs
      tabs={tabs}
      activeTab={activeTab}
      baseUrl="/dashboard/leader"
      accentColor="leader"
    />

    <!-- Tab: Overview -->
    {
      activeTab === 'overview' && (
        <div class="space-y-6">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <StatCard value={formatCurrency(stats.totalRaised)} label="Total Recaudado">
              <CurrencyDollar slot="icon" size={28} className="mx-auto text-dracula-green" />
            </StatCard>
            <StatCard value={stats.activeCauses} label="Causas Activas">
              <Trophy slot="icon" size={28} className="mx-auto text-dracula-yellow" />
            </StatCard>
            <StatCard value={stats.entrepreneursAllied} label="Emprendedores Aliados">
              <Users slot="icon" size={28} className="mx-auto text-entrepreneur" />
            </StatCard>
            <StatCard
              value={
                stats.totalGoal > 0
                  ? `${Math.round((stats.totalRaised / stats.totalGoal) * 100)}%`
                  : '0%'
              }
              label="Meta Cumplida"
            >
              <ChartLineUp slot="icon" size={28} className="mx-auto text-dracula-pink" />
            </StatCard>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <ProfileCompletionCard
              percentage={profileCompletion}
              missingFields={missingFields}
              accentColor="leader"
            />
            <QuickActions
              actions={[
                { label: 'Crear Causa', href: '/dashboard/leader?tab=crear', color: 'leader' },
                {
                  label: 'Publicar Update',
                  href: '/dashboard/leader?tab=updates',
                  color: 'dracula-cyan',
                },
                {
                  label: 'Ver Perfil Publico',
                  href: `/leaders/${leaderProfile.id}`,
                  color: 'dracula-purple',
                },
              ]}
            />
          </div>

          {myCauses.length > 0 && myCauses[0].status === 'active' && (
            <div class="glass p-4 rounded-xl border border-leader/30 flex items-center gap-4">
              <div class="bg-leader/20 p-2 rounded-lg">
                <ChartLineUp size={24} className="text-leader" />
              </div>
              <div class="flex-1">
                <p class="text-white text-sm font-medium">
                  Tu causa "{myCauses[0].title}" esta al{' '}
                  {myCauses[0].goal > 0
                    ? Math.round((myCauses[0].raised / myCauses[0].goal) * 100)
                    : 0}
                  % de la meta
                </p>
                <p class="text-dracula-comment text-xs">
                  {formatCurrency(myCauses[0].raised)} de {formatCurrency(myCauses[0].goal)}
                </p>
              </div>
              <a href={`/causes/${myCauses[0].id}`} class="text-leader text-sm hover:underline">
                Ver causa
              </a>
            </div>
          )}

          <div class="grid lg:grid-cols-3 gap-6">
            <div class="lg:col-span-2 glass p-6 rounded-xl">
              <h3 class="font-bold text-white mb-4">Actividad Reciente</h3>
              {recentUpdates.length > 0 ? (
                <div class="space-y-3">
                  {recentUpdates.map((update) => (
                    <div class="flex items-center gap-3 p-3 bg-dracula-bg/50 rounded-lg">
                      <div
                        class={`w-2 h-2 rounded-full shrink-0 ${
                          update.type === 'milestone'
                            ? 'bg-dracula-yellow'
                            : update.type === 'gratitude'
                              ? 'bg-dracula-pink'
                              : 'bg-dracula-cyan'
                        }`}
                      />
                      <div class="flex-1 min-w-0">
                        <p class="text-sm text-white font-medium truncate">{update.title}</p>
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <p class="text-dracula-comment text-sm">
                  No hay actividad reciente. Crea tu primera causa para empezar!
                </p>
              )}
            </div>

            <div class="glass p-6 rounded-xl">
              <h3 class="font-bold text-white mb-4 flex items-center gap-2">
                <Users className="text-entrepreneur" size={20} />
                Emprendedores Aliados
              </h3>
              {alliedEntrepreneurs.length > 0 ? (
                <div class="space-y-3">
                  {alliedEntrepreneurs.map((ent) => (
                    <a
                      href={`/entrepreneurs/${ent.id}`}
                      class="flex items-center gap-3 p-3 bg-dracula-bg/50 rounded-lg hover:bg-dracula-current/50 transition-colors"
                    >
                      {ent.photo ? (
                        <img
                          src={ent.photo}
                          alt={ent.name}
                          class="w-10 h-10 rounded-full object-cover"
                        />
                      ) : (
                        <div class="w-10 h-10 rounded-full bg-entrepreneur/20 flex items-center justify-center">
                          <span class="text-sm font-bold text-entrepreneur">
                            {ent.name?.charAt(0)}
                          </span>
                        </div>
                      )}
                      <div class="flex-1">
                        <h4 class="font-bold text-white text-sm">{ent.name}</h4>
                        <p class="text-xs text-entrepreneur">{ent.products} productos</p>
                      </div>
                    </a>
                  ))}
                </div>
              ) : (
                <p class="text-dracula-comment text-sm">
                  Aun no hay emprendedores vinculados a tus causas.
                </p>
              )}
            </div>
          </div>
        </div>
      )
    }

    <!-- Tab: Causas -->
    {
      activeTab === 'causas' && (
        <div>
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-white flex items-center gap-2">
              <Trophy className="text-dracula-yellow" size={24} />
              Mis Causas
            </h2>
            <a
              href="/dashboard/leader?tab=crear"
              class="px-4 py-2 bg-leader text-dracula-bg rounded-lg font-bold text-sm hover:brightness-110 transition-all flex items-center gap-2"
            >
              <PlusCircle size={18} />
              Nueva Causa
            </a>
          </div>
          <CauseManagementList
            client:visible
            causes={myCauses.map((c) => ({
              id: c.id,
              title: c.title,
              description: c.description || null,
              target_goal: c.goal || null,
              current_amount: c.raised,
              photo_url: null,
              status: c.status,
              created_at: c.createdAt,
            }))}
            productCounts={productCounts}
          />
        </div>
      )
    }

    <!-- Tab: Productos (Mi Tienda) -->
    {
      activeTab === 'productos' && (
        <div class="space-y-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-white flex items-center gap-2">
              <ShoppingBag className="text-entrepreneur" size={24} />
              Mi Tienda
            </h2>
          </div>

          {/* Create Product Form */}
          <div class="glass p-6 rounded-xl">
            <h3 class="font-bold text-white mb-4 flex items-center gap-2">
              <PlusCircle className="text-dracula-green" size={20} />
              Crear Producto
            </h3>
            <CreateProductForm client:visible userRole="leader" />
          </div>

          {/* Products List */}
          <ProductManagementList
            client:visible
            products={leaderProducts.map((p) => ({
              id: p.id,
              name: p.name,
              description: null,
              price: p.price,
              photo_url: p.photoUrl || null,
              cause_title: p.causeName,
              is_active: true,
              created_at: p.createdAt,
            }))}
            userRole="leader"
          />
        </div>
      )
    }

    <!-- Tab: Crear Causa (React Form) -->
    {
      activeTab === 'crear' && (
        <div class="max-w-3xl mx-auto">
          <div class="glass p-6 rounded-xl">
            <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
              <PlusCircle className="text-dracula-green" size={24} />
              Crear Nueva Causa
            </h2>
            <CreateCauseForm client:visible />
          </div>
        </div>
      )
    }

    <!-- Tab: Updates -->
    {
      activeTab === 'updates' && (
        <div class="max-w-3xl mx-auto">
          <div class="glass p-6 rounded-xl">
            <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
              <Newspaper className="text-dracula-cyan" size={24} />
              Publicar Actualizacion de Causa
            </h2>
            <p class="text-sm text-dracula-comment mb-4">
              Comparte el progreso de tu causa con la comunidad
            </p>
            <form class="space-y-4" id="createCauseUpdateForm">
              <div>
                <label class="block text-sm font-bold text-dracula-fg mb-2">
                  Causa a actualizar
                </label>
                <select
                  name="cause_id"
                  class="w-full bg-dracula-bg border border-dracula-current rounded-lg px-4 py-3 text-white focus:border-dracula-cyan outline-none"
                  required
                >
                  <option value="">Selecciona una causa...</option>
                  {myCauses
                    .filter((c) => c.status === 'active')
                    .map((cause) => (
                      <option value={cause.id}>{cause.title}</option>
                    ))}
                </select>
              </div>
              <div>
                <label class="block text-sm font-bold text-dracula-fg mb-2">Tipo</label>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
                  <label class="cursor-pointer">
                    <input
                      type="radio"
                      name="update_type"
                      value="progress"
                      class="sr-only peer"
                      checked
                    />
                    <div class="p-3 rounded-lg border border-dracula-current text-center peer-checked:border-dracula-cyan peer-checked:bg-dracula-cyan/10 transition-colors">
                      <Newspaper size={20} className="mx-auto mb-1 text-dracula-cyan" />
                      <span class="text-xs text-dracula-fg">Progreso</span>
                    </div>
                  </label>
                  <label class="cursor-pointer">
                    <input type="radio" name="update_type" value="milestone" class="sr-only peer" />
                    <div class="p-3 rounded-lg border border-dracula-current text-center peer-checked:border-dracula-yellow peer-checked:bg-dracula-yellow/10 transition-colors">
                      <Trophy size={20} className="mx-auto mb-1 text-dracula-yellow" />
                      <span class="text-xs text-dracula-fg">Logro</span>
                    </div>
                  </label>
                  <label class="cursor-pointer">
                    <input type="radio" name="update_type" value="gratitude" class="sr-only peer" />
                    <div class="p-3 rounded-lg border border-dracula-current text-center peer-checked:border-dracula-pink peer-checked:bg-dracula-pink/10 transition-colors">
                      <Heart size={20} className="mx-auto mb-1 text-dracula-pink" />
                      <span class="text-xs text-dracula-fg">Agradecimiento</span>
                    </div>
                  </label>
                  <label class="cursor-pointer">
                    <input type="radio" name="update_type" value="closing" class="sr-only peer" />
                    <div class="p-3 rounded-lg border border-dracula-current text-center peer-checked:border-dracula-green peer-checked:bg-dracula-green/10 transition-colors">
                      <CheckCircle size={20} className="mx-auto mb-1 text-dracula-green" />
                      <span class="text-xs text-dracula-fg">Cerrar</span>
                    </div>
                  </label>
                </div>
              </div>
              <div>
                <label class="block text-sm font-bold text-dracula-fg mb-2">Titulo</label>
                <input
                  type="text"
                  name="title"
                  placeholder="Ej. Llegamos al 50% de nuestra meta!"
                  class="w-full bg-dracula-bg border border-dracula-current rounded-lg px-4 py-3 text-white focus:border-dracula-cyan outline-none"
                  required
                />
              </div>
              <div>
                <label class="block text-sm font-bold text-dracula-fg mb-2">Contenido</label>
                <textarea
                  name="content"
                  rows="4"
                  placeholder="Cuenta a la comunidad sobre tu progreso..."
                  class="w-full bg-dracula-bg border border-dracula-current rounded-lg px-4 py-3 text-white focus:border-dracula-cyan outline-none"
                  required
                />
              </div>
              <div>
                <label class="block text-sm font-bold text-dracula-fg mb-2">Foto (opcional)</label>
                <input
                  type="url"
                  name="photo_url"
                  placeholder="URL de la imagen"
                  class="w-full bg-dracula-bg border border-dracula-current rounded-lg px-4 py-3 text-white focus:border-dracula-cyan outline-none"
                />
              </div>
              <div>
                <label class="block text-sm font-bold text-dracula-fg mb-2">
                  Monto recaudado actualizado (opcional)
                </label>
                <input
                  type="number"
                  name="amount_received"
                  min="0"
                  step="1000"
                  placeholder="Ej. 500000"
                  class="w-full bg-dracula-bg border border-dracula-current rounded-lg px-4 py-3 text-white focus:border-dracula-cyan outline-none"
                />
                <p class="text-xs text-dracula-comment mt-1">
                  Ingresa el total recaudado hasta ahora. Las donaciones son directas, por eso tu
                  actualizas este valor.
                </p>
              </div>
              <button
                type="submit"
                class="w-full bg-dracula-cyan text-dracula-bg font-bold py-3 rounded-xl hover:brightness-110 transition-all flex items-center justify-center gap-2"
