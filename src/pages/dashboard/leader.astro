<script>
  // Handle cause update form submission
  document.getElementById('createCauseUpdateForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);

    const causeId = formData.get('cause_id');
    if (!causeId) {
      alert('Por favor selecciona una causa para actualizar');
      return;
    }

    const updateType = formData.get('update_type') as string;
    const updateData = {
      cause_id: parseInt(causeId as string),
      title: formData.get('title'),
      content: formData.get('content'),
      update_type: updateType,
      photo_url: formData.get('photo_url') || null,
      is_closing: updateType === 'closing',
      amount_received: formData.get('amount_received')
        ? parseFloat(formData.get('amount_received') as string)
        : null,
    };

    try {
      const response = await fetch('/api/cause-updates', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(updateData),
      });

      if (response.ok) {
        const message =
          updateType === 'closing'
            ? 'Causa cerrada exitosamente!'
            : 'Actualizacion publicada exitosamente!';
        alert(message);
        form.reset();
        if (updateType === 'closing') {
          window.location.reload();
        }
      } else {
        const error = await response.json();
        alert('Error al publicar: ' + (error.error || 'Error desconocido'));
      }
    } catch (err) {
      alert('Error de conexion');
    }
  });
</script>
