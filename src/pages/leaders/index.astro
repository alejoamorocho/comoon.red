---
import Layout from '../../layouts/Layout.astro';
import LeaderCard from '../../components/LeaderCard.astro';
import ProfileCompleteBadge from '../../components/ProfileCompleteBadge';
import { isLeaderProfileComplete } from '../../utils/profileCompletion';
import { MagnifyingGlass, MapPin, CheckCircle, UsersThree } from '@phosphor-icons/react';

// Fetch leaders from database
const db = Astro.locals.runtime?.env?.DB;

let leadersData: Array<{
  id: string;
  name: string;
  bio: string;
  location: string;
  cause: string;
  photoUrl: string;
  tags: string[];
  activeCausesCount: number;
  isVerified: boolean;
}> = [];

if (db) {
  try {
    const { results } = await db
      .prepare(
        `
      SELECT l.*,
        (SELECT title FROM causes WHERE leader_id = l.id AND status = 'active' LIMIT 1) as active_cause_title,
        (SELECT COUNT(*) FROM causes WHERE leader_id = l.id AND status = 'active') as active_causes_count
      FROM leaders l
      ORDER BY l.is_verified DESC, l.created_at DESC
    `,
      )
      .all();

    leadersData = (results || []).map((l: any) => ({
      id: String(l.id),
      name: l.name,
      bio: l.bio,
      location: [l.city, l.department].filter(Boolean).join(', ') || l.location || '',
      cause: l.active_cause_title || '',
      photoUrl: l.photo_url || '',
      tags: JSON.parse(l.tags || '[]'),
      activeCausesCount: l.active_causes_count || 0,
      isVerified: !!l.is_verified,
    }));
  } catch (e) {
    console.error('Failed to fetch leaders:', e);
    leadersData = [];
  }
}

// Sort by profile completeness (complete profiles first)
const leaders = leadersData
  .map((leader) => ({
    ...leader,
    isComplete: isLeaderProfileComplete({
      name: leader.name,
      bio: leader.bio,
      photo_url: leader.photoUrl,
      location: leader.location,
      tags: leader.tags,
      activeCausesCount: leader.activeCausesCount,
    }),
  }))
  .sort((a, b) => (b.isComplete ? 1 : 0) - (a.isComplete ? 1 : 0));
---

<Layout title="Lideres Sociales" fullWidth>
  <!-- ===== HERO ===== -->
  <section class="relative py-24 px-6 overflow-hidden">
    <!-- Ambient lights -->
    <div
      class="absolute top-1/4 left-1/3 w-[600px] h-[600px] bg-leader/10 rounded-full blur-[160px] pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-comoon-purple/8 rounded-full blur-[120px] pointer-events-none"
    >
    </div>

    <div class="relative z-10 max-w-7xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="text-leader text-xs font-bold uppercase tracking-[0.2em] mb-4">
          Lideres Sociales
        </p>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-white mb-6">
          Transformadores de comunidades
        </h1>
        <p class="text-lg text-dracula-comment-accessible leading-relaxed max-w-2xl mx-auto">
          Rostros reales de transformacion. Cada uno de ellos lidera una causa verificada que
          necesita tu apoyo.
        </p>
      </div>

      <!-- Search -->
      <div class="max-w-xl mx-auto mb-16">
        <div class="relative">
          <MagnifyingGlass
            size={20}
            weight="duotone"
            className="absolute left-4 top-1/2 -translate-y-1/2 text-dracula-comment pointer-events-none"
          />
          <input
            type="text"
            id="leader-search"
            placeholder="Buscar por nombre, ubicacion o causa..."
            class="w-full pl-12 pr-6 py-4 bg-dracula-current/60 border border-white/10 rounded-full text-white placeholder:text-dracula-comment/60 focus:outline-none focus:border-leader/40 focus:shadow-[0_0_30px_rgba(45,212,191,0.1)] transition-all duration-300 backdrop-blur-md"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== LEADERS GRID ===== -->
  <section class="border-t border-white/5 py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <!-- Stats bar -->
      <div class="flex items-center justify-center gap-8 mb-16 text-sm">
        <div class="flex items-center gap-2">
          <UsersThree size={18} weight="duotone" className="text-leader" />
          <span class="text-dracula-comment-accessible">
            <span class="text-white font-semibold">{leaders.length}</span> lideres registrados
          </span>
        </div>
        <div class="flex items-center gap-2">
          <CheckCircle size={18} weight="duotone" className="text-dracula-green" />
          <span class="text-dracula-comment-accessible">
            <span class="text-white font-semibold"
              >{leaders.filter((l) => l.isVerified).length}</span
            > verificados
          </span>
        </div>
      </div>

      <!-- Grid -->
      <div id="leaders-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          leaders.map((leader) => (
            <a
              href={`/leaders/${leader.id}`}
              class="leader-card group glass rounded-2xl overflow-hidden border border-white/10 hover:border-leader/30 transition-all duration-300 hover:shadow-[0_0_40px_rgba(45,212,191,0.08)]"
              data-name={leader.name.toLowerCase()}
              data-location={leader.location.toLowerCase()}
              data-cause={leader.cause.toLowerCase()}
            >
              {/* Image */}
              <div class="relative h-52 overflow-hidden">
                {leader.photoUrl ? (
                  <img
                    src={leader.photoUrl}
                    alt={leader.name}
                    width={400}
                    height={208}
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                ) : (
                  <div class="w-full h-full bg-leader/10 flex items-center justify-center">
                    <span class="text-5xl font-bold text-leader/40">{leader.name?.charAt(0)}</span>
                  </div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-dracula-bg via-dracula-bg/20 to-transparent" />

                {/* Badges */}
                <div class="absolute top-3 right-3 flex items-center gap-2">
                  {leader.isComplete && (
                    <ProfileCompleteBadge client:visible isComplete={true} size="sm" />
                  )}
                  {leader.isVerified && (
                    <span class="bg-dracula-green/20 backdrop-blur-sm text-dracula-green px-2 py-1 rounded-full text-xs font-bold flex items-center gap-1 border border-dracula-green/20">
                      <CheckCircle size={12} weight="fill" />
                      Verificado
                    </span>
                  )}
                </div>

                {/* Name overlay */}
                <div class="absolute bottom-4 left-5 right-5">
                  <h3 class="text-xl font-bold text-white mb-1">{leader.name}</h3>
                  {leader.location && (
                    <p class="text-leader/80 text-sm font-medium flex items-center gap-1.5">
                      <MapPin size={14} weight="duotone" />
                      {leader.location}
                    </p>
                  )}
                </div>
              </div>

              {/* Content */}
              <div class="p-5">
                {leader.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mb-3">
                    {leader.tags.slice(0, 3).map((tag: string) => (
                      <span class="text-xs px-2.5 py-1 rounded-full bg-leader/10 text-leader/80 border border-leader/10">
                        {tag}
                      </span>
                    ))}
                    {leader.tags.length > 3 && (
                      <span class="text-xs px-2.5 py-1 rounded-full bg-white/5 text-dracula-comment">
                        +{leader.tags.length - 3}
                      </span>
                    )}
                  </div>
                )}

                {leader.cause && (
                  <p class="text-xs font-bold uppercase tracking-[0.15em] text-leader/60 mb-1.5">
                    Causa Activa
                  </p>
                )}
                {leader.cause && (
                  <p class="text-sm font-semibold text-white/90 mb-3 line-clamp-1">
                    {leader.cause}
                  </p>
                )}

                {leader.bio && (
                  <p class="text-sm text-dracula-comment-accessible line-clamp-2 leading-relaxed">
                    {leader.bio}
                  </p>
                )}

                <div class="mt-4 pt-3 border-t border-white/5 flex items-center justify-between">
                  <span class="text-xs text-dracula-comment">
                    {leader.activeCausesCount}{' '}
                    {leader.activeCausesCount === 1 ? 'causa activa' : 'causas activas'}
                  </span>
                  <span class="text-xs text-leader font-semibold group-hover:translate-x-1 transition-transform duration-300 flex items-center gap-1">
                    Ver perfil &rarr;
                  </span>
                </div>
              </div>
            </a>
          ))
        }
      </div>

      <!-- Empty state -->
      {
        leaders.length === 0 && (
          <div class="text-center py-24">
            <UsersThree size={48} weight="duotone" className="text-dracula-comment mx-auto mb-4" />
            <p class="text-lg text-dracula-comment">No hay lideres registrados aun.</p>
          </div>
        )
      }

      <!-- No results (hidden by default, shown by JS) -->
      <div id="no-results" class="text-center py-24 hidden">
        <MagnifyingGlass size={48} weight="duotone" className="text-dracula-comment mx-auto mb-4" />
        <p class="text-lg text-dracula-comment">No se encontraron lideres con ese criterio.</p>
      </div>
    </div>
  </section>

  <!-- Search script -->
  <script>
    const searchInput = document.getElementById('leader-search') as HTMLInputElement;
    const cards = document.querySelectorAll('.leader-card') as NodeListOf<HTMLElement>;
    const noResults = document.getElementById('no-results');

    if (searchInput) {
      searchInput.addEventListener('input', () => {
        const query = searchInput.value.toLowerCase().trim();
        let visibleCount = 0;

        cards.forEach((card) => {
          const name = card.dataset.name || '';
          const location = card.dataset.location || '';
          const cause = card.dataset.cause || '';
          const match =
            !query || name.includes(query) || location.includes(query) || cause.includes(query);
          card.style.display = match ? '' : 'none';
          if (match) visibleCount++;
        });

        if (noResults) {
          noResults.classList.toggle('hidden', visibleCount > 0);
        }
      });
    }
  </script>
</Layout>
