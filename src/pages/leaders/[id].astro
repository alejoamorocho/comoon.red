---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ContactButtons from '../../components/ContactButtons';
import ShareButtons from '../../components/ShareButtons';
import { LeaderTagsList } from '../../components/LeaderTagBadge';
import { formatCOP as formatCurrency } from '../../utils/format';
import {
  MapPin,
  UsersThree,
  Star,
  Image,
  Quotes,
  Moon,
  Heart,
  CheckCircle,
  ArrowLeft,
  ShoppingBag,
  Buildings,
  HandHeart,
  Lightbulb,
  Trophy,
  Camera,
  Users,
  CalendarBlank,
} from '@phosphor-icons/react';

const { id } = Astro.params;
if (!id) {
  return Astro.redirect('/404');
}

const db = Astro.locals.runtime?.env?.DB;
let leader: Record<string, any> | null = null;
let myCauses: Array<Record<string, any>> = [];
let products: Array<Record<string, any>> = [];
let contactInfo: Record<string, string> = {};

if (db) {
  leader = (await db
    .prepare('SELECT * FROM leaders WHERE id = ?')
    .bind(parseInt(id))
    .first()) as Record<string, any> | null;

  if (leader) {
    try {
      contactInfo = JSON.parse(leader.contact_info || '{}');
    } catch {}
    const parsedTags = leader.tags ? JSON.parse(leader.tags as string) : [];
    leader.parsedTags = parsedTags;

    // Fetch causes
    const { results: causeRows } = await db
      .prepare(
        "SELECT * FROM causes WHERE leader_id = ? ORDER BY CASE WHEN status = 'active' THEN 0 ELSE 1 END, created_at DESC",
      )
      .bind(parseInt(id))
      .all();
    myCauses = (causeRows || []).map((c: any) => ({
      id: c.id,
      title: c.title,
      description: c.description,
      goal: c.target_goal || 0,
      raised: c.current_amount || 0,
      status: c.status,
      photo_url: c.photo_url,
    }));

    // Fetch products: leader's own + entrepreneurs linked to their causes
    const { results: productRows } = await db
      .prepare(
        `
            SELECT p.*,
                CASE WHEN p.leader_id IS NOT NULL THEN pl.name ELSE e.store_name END as seller_name,
                CASE WHEN p.leader_id IS NOT NULL THEN pl.contact_info ELSE e.contact_info END as seller_contact_json,
                c.title as cause_title
            FROM products p
            LEFT JOIN entrepreneurs e ON p.entrepreneur_id = e.id
            LEFT JOIN leaders pl ON p.leader_id = pl.id
            JOIN causes c ON p.cause_id = c.id
            WHERE (p.leader_id = ? OR c.leader_id = ?) AND p.is_active = 1
            ORDER BY p.created_at DESC
        `,
      )
      .bind(parseInt(id), parseInt(id))
      .all();

    products = (productRows || []).map((p: any) => {
      let phone = '';
      try {
        const c = JSON.parse(p.seller_contact_json || '{}');
        phone = c.whatsapp || c.phone || '';
      } catch {}
      return {
        id: String(p.id),
        name: p.name,
        price: p.price,
        entrepreneur: p.seller_name || 'Vendedor',
        entrepreneurPhone: phone,
        cause: p.cause_title,
        causeId: String(p.cause_id),
        leaderName: leader!.name,
        contributionText:
          p.contribution_text ||
          (p.contribution_type === 'percentage'
            ? `${p.contribution_amount}% de cada compra`
            : `$${p.contribution_amount?.toLocaleString('es-CO')} por compra`),
        photoUrl: p.photo_url,
      };
    });
  }
}

if (!leader) {
  return Astro.redirect('/404');
}

const activeCause = myCauses.find((c) => c.status === 'active');
const progressPercent =
  activeCause && activeCause.goal > 0
    ? Math.round((activeCause.raised / activeCause.goal) * 100)
    : 0;
const location =
  [leader.city, leader.department].filter(Boolean).join(', ') || leader.location || '';

// Parse enhanced profile JSON fields safely
let achievements: Array<Record<string, any>> = [];
try {
  achievements = JSON.parse(leader.achievements || '[]');
} catch {}

let testimonials: Array<Record<string, any>> = [];
try {
  testimonials = JSON.parse(leader.testimonials || '[]');
} catch {}

let mediaGallery: string[] = [];
try {
  mediaGallery = JSON.parse(leader.media_gallery || '[]');
} catch {}

const activeCausesCount = myCauses.filter((c) => c.status === 'active').length;
const hasStats = leader.people_impacted || leader.years_active || activeCausesCount > 0;
---

<Layout
  title={`${leader.name} - Lider`}
  description={leader.bio || `Conoce a ${leader.name}, lider social en Comoon.`}
  ogImage={leader.photo_url}
  ogType="profile"
>
  {/* Cover Banner */}
  {
    leader.cover_url && (
      <div class="w-full h-64 md:h-80 relative overflow-hidden">
        <img
          src={leader.cover_url}
          alt={`Portada de ${leader.name}`}
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-dracula-bg via-transparent to-transparent" />
      </div>
    )
  }

  <div class="max-w-5xl mx-auto py-8 px-4">
    <!-- Back Button -->
    <a
      href="/leaders"
      class="inline-flex items-center gap-2 text-dracula-comment hover:text-white mb-8 transition-colors group"
    >
      <ArrowLeft class="group-hover:-translate-x-1 transition-transform" />
      Volver a Lideres
    </a>

    <!-- Header Profile Card -->
    <div class="glass p-8 rounded-2xl mb-12 border border-leader/30 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-leader/10 rounded-full blur-3xl -z-10"></div>

      <div class="md:flex gap-10 items-start">
        {
          leader.photo_url ? (
            <img
              src={leader.photo_url}
              alt={leader.name}
              class="w-40 h-40 md:w-48 md:h-48 rounded-2xl object-cover shadow-2xl mx-auto md:mx-0 -mt-20 md:mt-0 border-4 border-dracula-bg"
            />
          ) : (
            <div class="w-40 h-40 md:w-48 md:h-48 rounded-2xl bg-leader/20 flex items-center justify-center mx-auto md:mx-0 -mt-20 md:mt-0 border-4 border-dracula-bg">
              <span class="text-6xl font-bold text-leader">{leader.name?.charAt(0)}</span>
            </div>
          )
        }
        <div class="mt-8 md:mt-0 flex-1">
          <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-4">
            <div>
              <div class="flex items-center gap-3 mb-2">
                <h1 class="text-3xl md:text-4xl font-bold text-white">{leader.name}</h1>
                {
                  leader.is_verified && (
                    <span class="bg-dracula-green/20 text-dracula-green px-2 py-1 rounded-full text-xs font-bold flex items-center gap-1">
                      <CheckCircle size={14} weight="fill" />
                      Verificado
                    </span>
                  )
                }
              </div>
              {
                leader.organization_name && (
                  <p class="text-leader/80 font-medium flex items-center gap-2 mb-1">
                    <Buildings size={18} weight="duotone" />
                    {leader.organization_name}
                  </p>
                )
              }
              {
                location && (
                  <div class="flex items-center gap-2 text-leader font-medium mb-2">
                    <MapPin size={20} weight="duotone" />
                    <span>{location}</span>
                  </div>
                )
              }
              {
                leader.parsedTags && leader.parsedTags.length > 0 && (
                  <LeaderTagsList
                    client:visible
                    tags={leader.parsedTags}
                    size="md"
                    maxVisible={4}
                  />
                )
              }
            </div>
          </div>

          {
            leader.bio && (
              <p class="text-lg text-dracula-fg/90 mb-6 italic border-l-4 border-leader pl-4">
                {leader.bio}
              </p>
            )
          }

          <!-- Contact Buttons -->
          <div class="mb-6">
            <ContactButtons client:visible contactInfo={contactInfo} size="md" />
          </div>

          <div
            class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-t border-white/10 pt-4"
          >
            <div class="flex items-center gap-2">
              <span class="text-sm text-dracula-comment flex items-center gap-2">
                <Moon size={16} weight="duotone" className="text-comoon-purple" />
                Difusion Lunar
              </span>
              <ShareButtons
                client:visible
                title={leader.name}
                text={`Conoce a ${leader.name}, lider social en ${location}. Apoya su causa en comoon`}
              />
            </div>
            {
              activeCause && (
                <a href="#causa" class="btn-primary flex items-center gap-2 text-sm px-6">
                  <Heart size={18} weight="fill" />
                  Ver Causa Activa
                </a>
              )
            }
          </div>
        </div>
      </div>
    </div>

    {/* Quiénes Somos */}
    {
      leader.who_we_are && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
            <Heart size={28} weight="duotone" className="text-dracula-pink" />
            Quiénes Somos
          </h2>
          <div class="glass p-8 rounded-2xl border border-dracula-pink/20 bg-dracula-pink/5">
            <p class="text-lg text-dracula-fg/90 leading-relaxed whitespace-pre-line">
              {leader.who_we_are}
            </p>
          </div>
        </div>
      )
    }

    {/* Por qué hacemos lo que hacemos */}
    {
      leader.our_why && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
            <Lightbulb size={28} weight="duotone" className="text-dracula-yellow" />
            Por qué hacemos lo que hacemos
          </h2>
          <div class="glass p-8 rounded-2xl border-l-4 border-dracula-yellow bg-dracula-yellow/5">
            <p class="text-lg text-dracula-fg/90 leading-relaxed italic whitespace-pre-line">
              "{leader.our_why}"
            </p>
          </div>
        </div>
      )
    }

    {/* Con qué nos puedes ayudar */}
    {
      leader.how_to_help && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
            <HandHeart size={28} weight="duotone" className="text-dracula-green" />
            Con qué nos puedes ayudar
          </h2>
          <div class="glass p-8 rounded-2xl border-2 border-dracula-green/30 bg-dracula-green/5 relative overflow-hidden">
            <div class="absolute -right-4 -top-4 text-dracula-green/10">
              <HandHeart size={100} weight="fill" />
            </div>
            <p class="text-lg text-dracula-fg/90 leading-relaxed relative z-10 whitespace-pre-line">
              {leader.how_to_help}
            </p>
          </div>
        </div>
      )
    }

    {/* Impact Stats */}
    {
      hasStats && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
            <Star size={28} weight="duotone" className="text-leader" />
            Impacto
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {leader.people_impacted && (
              <div class="glass p-6 rounded-2xl text-center border border-leader/20">
                <Users size={32} className="text-leader mx-auto mb-2" weight="duotone" />
                <p class="text-3xl font-bold text-white">
                  {Number(leader.people_impacted).toLocaleString('es-CO')}
                </p>
                <p class="text-sm text-dracula-comment">Personas impactadas</p>
              </div>
            )}
            {leader.years_active && (
              <div class="glass p-6 rounded-2xl text-center border border-leader/20">
                <CalendarBlank size={32} className="text-leader mx-auto mb-2" weight="duotone" />
                <p class="text-3xl font-bold text-white">{leader.years_active}</p>
                <p class="text-sm text-dracula-comment">Años activo(a)</p>
              </div>
            )}
            {activeCausesCount > 0 && (
              <div class="glass p-6 rounded-2xl text-center border border-leader/20">
                <Heart size={32} className="text-leader mx-auto mb-2" weight="duotone" />
                <p class="text-3xl font-bold text-white">{activeCausesCount}</p>
                <p class="text-sm text-dracula-comment">Causas activas</p>
              </div>
            )}
          </div>
        </div>
      )
    }

    {/* Achievements / Logros */}
    {
      achievements.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
            <Trophy size={28} weight="duotone" className="text-dracula-yellow" />
            Logros
          </h2>
          <div class="space-y-4">
            {achievements.map((a: any, i: number) => (
              <div class="glass p-6 rounded-2xl border-l-4 border-dracula-yellow/60 flex gap-4 items-start">
                <div class="shrink-0 w-10 h-10 rounded-full bg-dracula-yellow/20 flex items-center justify-center">
                  <span class="text-dracula-yellow font-bold text-sm">{i + 1}</span>
                </div>
                <div>
                  {a.title && <h3 class="text-lg font-bold text-white mb-1">{a.title}</h3>}
                  {a.description && (
                    <p class="text-dracula-fg/80 text-sm leading-relaxed">{a.description}</p>
                  )}
                  {a.date && <p class="text-xs text-dracula-comment mt-2">{a.date}</p>}
                </div>
              </div>
            ))}
          </div>
        </div>
      )
    }

    {/* Testimonials / Testimonios */}
    {
      testimonials.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
            <Quotes size={28} weight="duotone" className="text-dracula-cyan" />
            Testimonios
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {testimonials.map((t: any) => (
              <div class="glass p-6 rounded-2xl border border-dracula-cyan/20 relative">
                <div class="absolute top-4 right-4 text-dracula-cyan/20">
                  <Quotes size={40} weight="fill" />
                </div>
                <p class="text-dracula-fg/90 italic mb-4 leading-relaxed relative z-10">
                  "{t.quote || t.text}"
                </p>
                <div class="flex items-center gap-3 border-t border-white/10 pt-4">
                  {t.photo && (
                    <img
                      src={t.photo}
                      alt={t.name || 'Testimonio'}
                      class="w-10 h-10 rounded-full object-cover border-2 border-dracula-cyan/40"
                    />
                  )}
                  <div>
                    {t.name && <p class="text-white font-bold text-sm">{t.name}</p>}
                    {t.role && <p class="text-xs text-dracula-comment">{t.role}</p>}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )
    }

    {/* Media Gallery / Galería */}
    {
      mediaGallery.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
            <Camera size={28} weight="duotone" className="text-dracula-purple" />
            Galería
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            {mediaGallery.map((photo: string, i: number) => (
              <div class="rounded-xl overflow-hidden border border-white/10 hover:border-leader/40 transition-colors">
                <img
                  src={photo}
                  alt={`Galería ${i + 1}`}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
                />
              </div>
            ))}
          </div>
        </div>
      )
    }

    <!-- Active Cause -->
    {
      activeCause && (
        <div id="causa" class="mb-16 scroll-mt-24">
          <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
            <UsersThree size={28} className="text-leader" />
            Causa Activa
          </h2>
          <div class="glass p-8 rounded-2xl border border-leader/30">
            <h3 class="text-2xl font-bold text-leader mb-4">{activeCause.title}</h3>
            {activeCause.description && (
              <p class="text-dracula-fg/80 mb-6 text-lg leading-relaxed">
                {activeCause.description}
              </p>
            )}

            {activeCause.goal > 0 && (
              <div class="mb-6">
                <div class="flex justify-between text-sm font-bold mb-2">
                  <span class="text-dracula-green">
                    {formatCurrency(activeCause.raised)} recaudados
                  </span>
                  <span class="text-dracula-comment">Meta: {formatCurrency(activeCause.goal)}</span>
                </div>
                <div
                  class="w-full bg-dracula-bg rounded-full h-4 overflow-hidden"
                  role="progressbar"
                  aria-valuenow={activeCause.raised}
                  aria-valuemin={0}
                  aria-valuemax={activeCause.goal}
                  aria-label="Progreso de la causa"
                >
                  <div
                    class="bg-gradient-to-r from-dracula-green to-dracula-cyan h-full rounded-full transition-all duration-1000"
                    style={`width: ${progressPercent}%`}
                  />
                </div>
                <p class="text-center text-dracula-comment text-sm mt-2">
                  {progressPercent}% de la meta alcanzada
                </p>
              </div>
            )}

            <div class="flex flex-col sm:flex-row gap-4 justify-between items-center">
              <a
                href={`/causes/${activeCause.id}`}
                class="text-leader hover:underline flex items-center gap-2"
              >
                <Star size={18} />
                Ver detalles completos de la causa
              </a>
              <a
                href={`/store?causa=${activeCause.id}`}
                class="btn-primary flex items-center gap-2"
              >
                <Heart size={18} weight="fill" />
                Ver productos que apoyan esta causa
              </a>
            </div>
          </div>
        </div>
      )
    }

    <!-- Products (Leader's Store) -->
    {
      products.length > 0 && (
        <div>
          <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
            <ShoppingBag size={28} className="text-entrepreneur" />
            Tienda del Lider
          </h2>
          <p class="text-dracula-comment mb-6">
            Productos propios y de emprendedores aliados. Cada compra genera impacto directo.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {products.map((product) => (
              <ProductCard
                id={product.id}
                name={product.name}
                price={product.price}
                entrepreneur={product.entrepreneur}
                entrepreneurPhone={product.entrepreneurPhone}
                cause={product.cause}
                causeId={product.causeId}
                leaderName={product.leaderName}
                contributionText={product.contributionText}
                photoUrl={product.photoUrl}
              />
            ))}
          </div>
        </div>
      )
    }
  </div>
</Layout>
