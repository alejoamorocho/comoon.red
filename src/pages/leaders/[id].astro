---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ContactButtons from '../../components/ContactButtons';
import ShareButtons from '../../components/ShareButtons';
import { LeaderTagsList } from '../../components/LeaderTagBadge';
import { formatCOP as formatCurrency } from '../../utils/format';
import {
  MapPin,
  UsersThree,
  Star,
  Quotes,
  Moon,
  Heart,
  CheckCircle,
  ArrowLeft,
  ShoppingBag,
  Buildings,
  HandHeart,
  Lightbulb,
  Trophy,
  Camera,
  Users,
  CalendarBlank,
} from '@phosphor-icons/react';

const { id } = Astro.params;
if (!id) {
  return Astro.redirect('/404');
}

const db = Astro.locals.runtime?.env?.DB;
let leader: Record<string, any> | null = null;
let myCauses: Array<Record<string, any>> = [];
let products: Array<Record<string, any>> = [];
let contactInfo: Record<string, string> = {};

if (db) {
  leader = (await db
    .prepare('SELECT * FROM leaders WHERE id = ?')
    .bind(parseInt(id))
    .first()) as Record<string, any> | null;

  if (leader) {
    try {
      contactInfo = JSON.parse(leader.contact_info || '{}');
    } catch {}
    const parsedTags = leader.tags ? JSON.parse(leader.tags as string) : [];
    leader.parsedTags = parsedTags;

    // Fetch causes
    const { results: causeRows } = await db
      .prepare(
        "SELECT * FROM causes WHERE leader_id = ? ORDER BY CASE WHEN status = 'active' THEN 0 ELSE 1 END, created_at DESC",
      )
      .bind(parseInt(id))
      .all();
    myCauses = (causeRows || []).map((c: any) => ({
      id: c.id,
      title: c.title,
      description: c.description,
      goal: c.target_goal || 0,
      raised: c.current_amount || 0,
      status: c.status,
      photo_url: c.photo_url,
    }));

    // Fetch products: leader's own + entrepreneurs linked to their causes
    const { results: productRows } = await db
      .prepare(
        `
            SELECT p.*,
                CASE WHEN p.leader_id IS NOT NULL THEN pl.name ELSE e.store_name END as seller_name,
                CASE WHEN p.leader_id IS NOT NULL THEN pl.contact_info ELSE e.contact_info END as seller_contact_json,
                c.title as cause_title
            FROM products p
            LEFT JOIN entrepreneurs e ON p.entrepreneur_id = e.id
            LEFT JOIN leaders pl ON p.leader_id = pl.id
            JOIN causes c ON p.cause_id = c.id
            WHERE (p.leader_id = ? OR c.leader_id = ?) AND p.is_active = 1
            ORDER BY p.created_at DESC
        `,
      )
      .bind(parseInt(id), parseInt(id))
      .all();

    products = (productRows || []).map((p: any) => {
      let phone = '';
      try {
        const c = JSON.parse(p.seller_contact_json || '{}');
        phone = c.whatsapp || c.phone || '';
      } catch {}
      return {
        id: String(p.id),
        name: p.name,
        price: p.price,
        entrepreneur: p.seller_name || 'Vendedor',
        entrepreneurPhone: phone,
        cause: p.cause_title,
        causeId: String(p.cause_id),
        leaderName: leader!.name,
        contributionText:
          p.contribution_text ||
          (p.contribution_type === 'percentage'
            ? `${p.contribution_amount}% de cada compra`
            : `$${p.contribution_amount?.toLocaleString('es-CO')} por compra`),
        photoUrl: p.photo_url,
      };
    });
  }
}

if (!leader) {
  return Astro.redirect('/404');
}

const activeCause = myCauses.find((c) => c.status === 'active');
const progressPercent =
  activeCause && activeCause.goal > 0
    ? Math.round((activeCause.raised / activeCause.goal) * 100)
    : 0;
const location =
  [leader.city, leader.department].filter(Boolean).join(', ') || leader.location || '';

// Parse enhanced profile JSON fields safely
let achievements: Array<Record<string, any>> = [];
try {
  achievements = JSON.parse(leader.achievements || '[]');
} catch {}

let testimonials: Array<Record<string, any>> = [];
try {
  testimonials = JSON.parse(leader.testimonials || '[]');
} catch {}

let mediaGallery: string[] = [];
try {
  mediaGallery = JSON.parse(leader.media_gallery || '[]');
} catch {}

const activeCausesCount = myCauses.filter((c) => c.status === 'active').length;
const hasStats = leader.people_impacted || leader.years_active || activeCausesCount > 0;
---

<Layout
  title={`${leader.name} - Lider`}
  description={leader.bio || `Conoce a ${leader.name}, lider social en Comoon.`}
  ogImage={leader.photo_url}
  ogType="profile"
  fullWidth
>
  <!-- ===== HEADER / COVER ===== -->
  <section class="relative overflow-hidden">
    <!-- Ambient lights -->
    <div
      class="absolute top-0 left-1/3 w-[700px] h-[700px] bg-leader/10 rounded-full blur-[180px] pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-comoon-purple/8 rounded-full blur-[140px] pointer-events-none"
    >
    </div>

    {/* Cover image */}
    {
      leader.cover_url && (
        <div class="w-full h-64 md:h-80 relative overflow-hidden">
          <img
            src={leader.cover_url}
            alt={`Portada de ${leader.name}`}
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-dracula-bg via-dracula-bg/50 to-transparent" />
        </div>
      )
    }

    <div class="relative z-10 max-w-5xl mx-auto px-6 py-8">
      <!-- Back -->
      <a
        href="/leaders"
        class="inline-flex items-center gap-2 text-dracula-comment hover:text-white transition-colors group text-sm mb-10"
      >
        <ArrowLeft
          size={16}
          className="group-hover:-translate-x-1 transition-transform"
          weight="duotone"
        />
        Volver a Lideres
      </a>

      <!-- Profile card -->
      <div class="md:flex gap-10 items-start">
        {/* Photo */}
        <div class="shrink-0 mx-auto md:mx-0 mb-8 md:mb-0">
          {
            leader.photo_url ? (
              <img
                src={leader.photo_url}
                alt={leader.name}
                class="w-36 h-36 md:w-44 md:h-44 rounded-2xl object-cover shadow-2xl border-2 border-leader/20"
              />
            ) : (
              <div class="w-36 h-36 md:w-44 md:h-44 rounded-2xl bg-leader/10 flex items-center justify-center border-2 border-leader/20">
                <span class="text-5xl font-bold text-leader/60">{leader.name?.charAt(0)}</span>
              </div>
            )
          }
        </div>

        {/* Info */}
        <div class="flex-1 text-center md:text-left">
          <div class="flex flex-col md:flex-row items-center md:items-start gap-3 mb-3">
            <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-white">{leader.name}</h1>
            {
              leader.is_verified && (
                <span class="shrink-0 bg-dracula-green/15 text-dracula-green px-3 py-1 rounded-full text-xs font-bold flex items-center gap-1.5 border border-dracula-green/20">
                  <CheckCircle size={14} weight="fill" />
                  Verificado
                </span>
              )
            }
          </div>

          {
            leader.organization_name && (
              <p class="text-leader/70 font-medium flex items-center gap-2 justify-center md:justify-start mb-2">
                <Buildings size={16} weight="duotone" />
                {leader.organization_name}
              </p>
            )
          }

          {
            location && (
              <p class="text-dracula-comment-accessible flex items-center gap-2 justify-center md:justify-start mb-4 text-sm">
                <MapPin size={16} weight="duotone" className="text-leader" />
                {location}
              </p>
            )
          }

          {
            leader.parsedTags && leader.parsedTags.length > 0 && (
              <div class="mb-5 flex justify-center md:justify-start">
                <LeaderTagsList client:visible tags={leader.parsedTags} size="md" maxVisible={4} />
              </div>
            )
          }

          {
            leader.bio && (
              <p class="text-dracula-fg/80 text-lg leading-relaxed mb-6 max-w-2xl">{leader.bio}</p>
            )
          }

          <!-- Actions row -->
          <div class="flex flex-col sm:flex-row items-center gap-4">
            <div class="flex items-center gap-3">
              <ContactButtons client:visible contactInfo={contactInfo} size="md" />
            </div>
            <div class="flex items-center gap-3">
              <span class="text-dracula-comment text-sm flex items-center gap-1.5">
                <Moon size={14} weight="duotone" className="text-comoon-purple" />
                Difusion Lunar
              </span>
              <ShareButtons
                client:visible
                title={leader.name}
                text={`Conoce a ${leader.name}, lider social en ${location}. Apoya su causa en comoon`}
              />
            </div>
            {
              activeCause && (
                <a
                  href="#causa"
                  class="ml-auto px-6 py-2.5 bg-leader text-dracula-bg font-bold text-sm rounded-full hover:shadow-[0_0_30px_rgba(45,212,191,0.25)] transition-all duration-300 flex items-center gap-2"
                >
                  <Heart size={16} weight="fill" />
                  Ver Causa Activa
                </a>
              )
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== IMPACT STATS ===== -->
  {
    hasStats && (
      <section class="border-t border-white/5 py-20 px-6">
        <div class="max-w-5xl mx-auto">
          <p class="text-leader text-xs font-bold uppercase tracking-[0.2em] mb-3 text-center">
            Impacto
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white text-center mb-12">
            Numeros que hablan
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
            {leader.people_impacted && (
              <div class="glass rounded-2xl p-8 text-center border border-white/10 hover:border-leader/20 transition-colors">
                <Users size={28} className="text-leader mx-auto mb-3" weight="duotone" />
                <p class="text-3xl font-bold text-white mb-1">
                  {Number(leader.people_impacted).toLocaleString('es-CO')}
                </p>
                <p class="text-sm text-dracula-comment">Personas impactadas</p>
              </div>
            )}
            {leader.years_active && (
              <div class="glass rounded-2xl p-8 text-center border border-white/10 hover:border-leader/20 transition-colors">
                <CalendarBlank size={28} className="text-leader mx-auto mb-3" weight="duotone" />
                <p class="text-3xl font-bold text-white mb-1">{leader.years_active}</p>
                <p class="text-sm text-dracula-comment">Anos activo(a)</p>
              </div>
            )}
            {activeCausesCount > 0 && (
              <div class="glass rounded-2xl p-8 text-center border border-white/10 hover:border-leader/20 transition-colors">
                <Heart size={28} className="text-leader mx-auto mb-3" weight="duotone" />
                <p class="text-3xl font-bold text-white mb-1">{activeCausesCount}</p>
                <p class="text-sm text-dracula-comment">Causas activas</p>
              </div>
            )}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== QUIENES SOMOS ===== -->
  {
    leader.who_we_are && (
      <section class="border-t border-white/5 py-20 px-6">
        <div class="max-w-5xl mx-auto">
          <p class="text-dracula-pink text-xs font-bold uppercase tracking-[0.2em] mb-3">
            Nuestra Historia
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-8">
            Quienes Somos
          </h2>
          <div class="glass rounded-2xl p-8 md:p-10 border border-white/10 hover:border-dracula-pink/20 transition-colors">
            <p class="text-lg text-dracula-fg/85 leading-relaxed whitespace-pre-line">
              {leader.who_we_are}
            </p>
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== POR QUE LO HACEMOS ===== -->
  {
    leader.our_why && (
      <section class="border-t border-white/5 py-20 px-6">
        <div class="max-w-5xl mx-auto">
          <p class="text-dracula-yellow text-xs font-bold uppercase tracking-[0.2em] mb-3">
            Nuestro Proposito
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-8">
            Por que hacemos lo que hacemos
          </h2>
          <div class="glass rounded-2xl p-8 md:p-10 border border-white/10 hover:border-dracula-yellow/20 transition-colors relative overflow-hidden">
            <div class="absolute top-6 right-6 text-dracula-yellow/10">
              <Lightbulb size={80} weight="fill" />
            </div>
            <p class="text-lg text-dracula-fg/85 leading-relaxed italic relative z-10 whitespace-pre-line">
              "{leader.our_why}"
            </p>
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== COMO AYUDAR ===== -->
  {
    leader.how_to_help && (
      <section class="border-t border-white/5 py-20 px-6">
        <div class="max-w-5xl mx-auto">
          <p class="text-dracula-green text-xs font-bold uppercase tracking-[0.2em] mb-3">
            Colabora
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-8">
            Como nos puedes ayudar
          </h2>
          <div class="glass rounded-2xl p-8 md:p-10 border border-white/10 hover:border-dracula-green/20 transition-colors relative overflow-hidden">
            <div class="absolute -right-4 -bottom-4 text-dracula-green/8">
              <HandHeart size={120} weight="fill" />
            </div>
            <p class="text-lg text-dracula-fg/85 leading-relaxed relative z-10 whitespace-pre-line">
              {leader.how_to_help}
            </p>
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== ACHIEVEMENTS ===== -->
  {
    achievements.length > 0 && (
      <section class="border-t border-white/5 py-20 px-6">
        <div class="max-w-5xl mx-auto">
          <p class="text-dracula-yellow text-xs font-bold uppercase tracking-[0.2em] mb-3">
            Reconocimientos
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-10">Logros</h2>
          <div class="space-y-4">
            {achievements.map((a: any, i: number) => (
              <div class="glass rounded-2xl p-6 border border-white/10 hover:border-dracula-yellow/20 transition-colors flex gap-5 items-start">
                <div class="shrink-0 w-10 h-10 rounded-full bg-dracula-yellow/15 flex items-center justify-center border border-dracula-yellow/20">
                  <span class="text-dracula-yellow font-bold text-sm">{i + 1}</span>
                </div>
                <div>
                  {a.title && <h3 class="text-lg font-bold text-white mb-1">{a.title}</h3>}
                  {a.description && (
                    <p class="text-dracula-fg/75 text-sm leading-relaxed">{a.description}</p>
                  )}
                  {a.date && <p class="text-xs text-dracula-comment mt-2">{a.date}</p>}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== TESTIMONIALS ===== -->
  {
    testimonials.length > 0 && (
      <section class="border-t border-white/5 py-20 px-6">
        <div class="max-w-5xl mx-auto">
          <p class="text-dracula-cyan text-xs font-bold uppercase tracking-[0.2em] mb-3">
            Voces de la Comunidad
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-10">
            Testimonios
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {testimonials.map((t: any) => (
              <div class="glass rounded-2xl p-6 border border-white/10 hover:border-dracula-cyan/20 transition-colors relative">
                <div class="absolute top-5 right-5 text-dracula-cyan/15">
                  <Quotes size={36} weight="fill" />
                </div>
                <p class="text-dracula-fg/85 italic mb-5 leading-relaxed relative z-10">
                  "{t.quote || t.text}"
                </p>
                <div class="flex items-center gap-3 border-t border-white/5 pt-4">
                  {t.photo && (
                    <img
                      src={t.photo}
                      alt={t.name || 'Testimonio'}
                      class="w-10 h-10 rounded-full object-cover border border-dracula-cyan/30"
                    />
                  )}
                  <div>
                    {t.name && <p class="text-white font-semibold text-sm">{t.name}</p>}
                    {t.role && <p class="text-xs text-dracula-comment">{t.role}</p>}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== MEDIA GALLERY ===== -->
  {
    mediaGallery.length > 0 && (
      <section class="border-t border-white/5 py-20 px-6">
        <div class="max-w-5xl mx-auto">
          <p class="text-dracula-purple text-xs font-bold uppercase tracking-[0.2em] mb-3">
            Momentos
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-10">Galeria</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            {mediaGallery.map((photo: string, i: number) => (
              <div class="rounded-2xl overflow-hidden border border-white/10 hover:border-leader/30 transition-all duration-300 group">
                <img
                  src={photo}
                  alt={`Galeria ${i + 1}`}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== ACTIVE CAUSE ===== -->
  {
    activeCause && (
      <section id="causa" class="border-t border-white/5 py-20 px-6 scroll-mt-24">
        <div class="max-w-5xl mx-auto">
          <p class="text-leader text-xs font-bold uppercase tracking-[0.2em] mb-3">Apoya Ahora</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-10">
            Causa Activa
          </h2>

          <div class="glass rounded-2xl p-8 md:p-10 border border-white/10 hover:border-leader/20 transition-colors relative overflow-hidden">
            {/* Ambient glow */}
            <div class="absolute top-0 right-0 w-64 h-64 bg-leader/8 rounded-full blur-[80px] pointer-events-none" />

            <h3 class="text-2xl font-bold text-white mb-4">{activeCause.title}</h3>
            {activeCause.description && (
              <p class="text-dracula-fg/75 mb-8 text-lg leading-relaxed max-w-3xl">
                {activeCause.description}
              </p>
            )}

            {activeCause.goal > 0 && (
              <div class="mb-8 max-w-2xl">
                <div class="flex justify-between text-sm font-semibold mb-3">
                  <span class="text-dracula-green">
                    {formatCurrency(activeCause.raised)} recaudados
                  </span>
                  <span class="text-dracula-comment">Meta: {formatCurrency(activeCause.goal)}</span>
                </div>
                <div
                  class="w-full bg-white/5 rounded-full h-3 overflow-hidden"
                  role="progressbar"
                  aria-valuenow={activeCause.raised}
                  aria-valuemin={0}
                  aria-valuemax={activeCause.goal}
                  aria-label="Progreso de la causa"
                >
                  <div
                    class="bg-gradient-to-r from-leader to-dracula-green h-full rounded-full transition-all duration-1000"
                    style={`width: ${Math.min(progressPercent, 100)}%`}
                  />
                </div>
                <p class="text-center text-dracula-comment text-sm mt-3">
                  {progressPercent}% de la meta alcanzada
                </p>
              </div>
            )}

            <div class="flex flex-col sm:flex-row gap-4 items-center">
              <a
                href={`/causes/${activeCause.id}`}
                class="px-6 py-2.5 border border-leader/30 text-leader font-semibold text-sm rounded-full hover:bg-leader/10 hover:border-leader/50 transition-all duration-300 flex items-center gap-2"
              >
                <Star size={16} weight="duotone" />
                Ver detalles de la causa
              </a>
              <a
                href={`/store?causa=${activeCause.id}`}
                class="px-6 py-2.5 bg-leader text-dracula-bg font-bold text-sm rounded-full hover:shadow-[0_0_30px_rgba(45,212,191,0.25)] transition-all duration-300 flex items-center gap-2"
              >
                <Heart size={16} weight="fill" />
                Productos que apoyan esta causa
              </a>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== PRODUCTS ===== -->
  {
    products.length > 0 && (
      <section class="border-t border-white/5 py-20 px-6">
        <div class="max-w-5xl mx-auto">
          <p class="text-entrepreneur text-xs font-bold uppercase tracking-[0.2em] mb-3">
            Tienda Social
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-3">
            Tienda del Lider
          </h2>
          <p class="text-dracula-comment-accessible mb-10 text-lg">
            Productos propios y de emprendedores aliados. Cada compra genera impacto directo.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {products.map((product) => (
              <ProductCard
                id={product.id}
                name={product.name}
                price={product.price}
                entrepreneur={product.entrepreneur}
                entrepreneurPhone={product.entrepreneurPhone}
                cause={product.cause}
                causeId={product.causeId}
                leaderName={product.leaderName}
                contributionText={product.contributionText}
                photoUrl={product.photoUrl}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }
</Layout>
