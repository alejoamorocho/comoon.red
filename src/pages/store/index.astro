---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import StoreFilters from '../../components/StoreFilters';
import { ShoppingBag, Heart } from '@phosphor-icons/react';

// Get filter from URL params
const url = new URL(Astro.request.url);
const filterCause = url.searchParams.get('causa');
const filterLeader = url.searchParams.get('lider');

const db = Astro.locals.runtime?.env?.DB;

let allProducts: Array<Record<string, any>> = [];
let causes: Array<Record<string, any>> = [];
let leaders: Array<Record<string, any>> = [];

if (db) {
  // Fetch real products with LEFT JOIN for leader-owned products
  let productQuery = `
        SELECT p.*,
            CASE WHEN p.leader_id IS NOT NULL THEN pl.name ELSE e.store_name END as seller_name,
            CASE WHEN p.leader_id IS NOT NULL THEN pl.contact_info ELSE e.contact_info END as seller_contact,
            c.title as cause_title, c.leader_id as cause_leader_id,
            l.name as leader_name
        FROM products p
        LEFT JOIN entrepreneurs e ON p.entrepreneur_id = e.id
        LEFT JOIN leaders pl ON p.leader_id = pl.id
        JOIN causes c ON p.cause_id = c.id
        JOIN leaders l ON c.leader_id = l.id
        WHERE p.is_active = 1
    `;
  const params: (string | number)[] = [];

  if (filterCause) {
    productQuery += ' AND p.cause_id = ?';
    params.push(parseInt(filterCause));
  }
  if (filterLeader) {
    productQuery += ' AND (c.leader_id = ? OR p.leader_id = ?)';
    params.push(parseInt(filterLeader), parseInt(filterLeader));
  }

  productQuery += ' ORDER BY p.created_at DESC LIMIT 50';

  const { results: productRows } = await db
    .prepare(productQuery)
    .bind(...params)
    .all();
  allProducts = (productRows || []).map((p: any) => {
    let contactPhone = '';
    try {
      const contact = JSON.parse(p.seller_contact || '{}');
      contactPhone = contact.whatsapp || contact.phone || '';
    } catch {}
    return {
      id: String(p.id),
      name: p.name,
      price: p.price,
      entrepreneur: p.seller_name || 'Vendedor',
      entrepreneurPhone: contactPhone,
      cause: p.cause_title,
      causeId: String(p.cause_id),
      leaderName: p.leader_name,
      leaderId: String(p.cause_leader_id),
      contributionText:
        p.contribution_text ||
        (p.contribution_type === 'percentage'
          ? `${p.contribution_amount}% de cada compra`
          : `$${p.contribution_amount?.toLocaleString('es-CO')} por compra`),
      photoUrl: p.photo_url,
    };
  });

  // Fetch causes for filters
  const { results: causeRows } = await db
    .prepare(
      "SELECT c.id, c.title, l.name as leader_name FROM causes c JOIN leaders l ON c.leader_id = l.id WHERE c.status = 'active' ORDER BY c.title",
    )
    .all();
  causes = (causeRows || []).map((c: any) => ({
    id: String(c.id),
    title: c.title,
    leaderName: c.leader_name,
  }));

  // Fetch leaders for filters
  const { results: leaderRows } = await db
    .prepare('SELECT id, name, city as location FROM leaders ORDER BY name')
    .all();
  leaders = (leaderRows || []).map((l: any) => ({
    id: String(l.id),
    name: l.name,
    location: l.location || '',
  }));
}

// Active filter info
let activeFilter: { type: string; value?: string } | null = null;
if (filterCause) {
  activeFilter = { type: 'causa', value: causes.find((c) => c.id === filterCause)?.title };
}
if (filterLeader) {
  activeFilter = { type: 'lider', value: leaders.find((l) => l.id === filterLeader)?.name };
}
---

<Layout title="Tienda con Proposito">
  <div class="py-8">
    <!-- Header -->
    <div class="text-center mb-10">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        <span class="text-entrepreneur">Tienda</span> con <span class="text-comoon-purple"
          >Proposito</span
        >
      </h1>
      <p class="text-lg text-dracula-fg/70 max-w-2xl mx-auto">
        Productos unicos de emprendedores y lideres colombianos. <span
          class="text-dracula-green font-medium">Cada compra ilumina una causa social.</span
        >
      </p>
    </div>

    <!-- Filters Component -->
    <StoreFilters
      client:idle
      causes={causes}
      leaders={leaders}
      activeCauseId={filterCause}
      activeLeaderId={filterLeader}
    />

    <!-- Active Filter Badge -->
    {
      activeFilter && (
        <div class="flex items-center justify-center gap-2 mb-6">
          <span class="text-dracula-comment text-sm">Filtrando por {activeFilter.type}:</span>
          <span class="bg-leader/20 text-leader px-3 py-1 rounded-full text-sm font-bold flex items-center gap-2">
            {activeFilter.type === 'causa' ? <Heart size={14} /> : null}
            {activeFilter.value}
            <a href="/store" class="ml-2 hover:text-white">
              &times;
            </a>
          </span>
        </div>
      )
    }

    <!-- Results Count -->
    <div class="flex items-center justify-between mb-6 px-2">
      <p class="text-sm text-dracula-comment flex items-center gap-2">
        <ShoppingBag size={18} />
        Mostrando <span class="text-white font-bold">{allProducts.length}</span> productos
      </p>
    </div>

    <!-- Products Grid -->
    {
      allProducts.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {allProducts.map((product) => (
            <ProductCard
              id={product.id}
              name={product.name}
              price={product.price}
              entrepreneur={product.entrepreneur}
              entrepreneurPhone={product.entrepreneurPhone}
              cause={product.cause}
              causeId={product.causeId}
              leaderName={product.leaderName}
              contributionText={product.contributionText}
              photoUrl={product.photoUrl}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-16 glass rounded-2xl">
          <ShoppingBag size={64} className="mx-auto mb-4 text-dracula-comment" />
          <h3 class="text-xl font-bold text-white mb-2">No hay productos</h3>
          <p class="text-dracula-comment mb-4">No encontramos productos con estos filtros.</p>
          <a href="/store" class="btn-primary inline-block">
            Ver todos los productos
          </a>
        </div>
      )
    }

    <!-- CTA Section -->
    <div class="mt-16 text-center glass p-8 rounded-2xl border border-entrepreneur/30">
      <h2 class="text-2xl font-bold text-white mb-4">Eres emprendedor o lider?</h2>
      <p class="text-dracula-fg/70 mb-6 max-w-xl mx-auto">
        Publica tus productos y vinculalos a causas sociales. Vende con proposito y genera impacto
        real.
      </p>
      <a href="/register" class="btn-primary inline-block">Crear mi Tienda</a>
    </div>
  </div>
</Layout>
