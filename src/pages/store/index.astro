---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import StoreFilters from '../../components/StoreFilters';
import { ShoppingBag, Heart, Storefront, ArrowRight } from '@phosphor-icons/react';

// Get filter from URL params
const url = new URL(Astro.request.url);
const filterCause = url.searchParams.get('causa');
const filterLeader = url.searchParams.get('lider');

const db = Astro.locals.runtime?.env?.DB;

let allProducts: Array<Record<string, any>> = [];
let causes: Array<Record<string, any>> = [];
let leaders: Array<Record<string, any>> = [];

if (db) {
  // Fetch real products with LEFT JOIN for leader-owned products
  let productQuery = `
        SELECT p.*,
            CASE WHEN p.leader_id IS NOT NULL THEN pl.name ELSE e.store_name END as seller_name,
            CASE WHEN p.leader_id IS NOT NULL THEN pl.contact_info ELSE e.contact_info END as seller_contact,
            c.title as cause_title, c.leader_id as cause_leader_id,
            l.name as leader_name
        FROM products p
        LEFT JOIN entrepreneurs e ON p.entrepreneur_id = e.id
        LEFT JOIN leaders pl ON p.leader_id = pl.id
        JOIN causes c ON p.cause_id = c.id
        JOIN leaders l ON c.leader_id = l.id
        WHERE p.is_active = 1
    `;
  const params: (string | number)[] = [];

  if (filterCause) {
    productQuery += ' AND p.cause_id = ?';
    params.push(parseInt(filterCause));
  }
  if (filterLeader) {
    productQuery += ' AND (c.leader_id = ? OR p.leader_id = ?)';
    params.push(parseInt(filterLeader), parseInt(filterLeader));
  }

  productQuery += ' ORDER BY p.created_at DESC LIMIT 50';

  const { results: productRows } = await db
    .prepare(productQuery)
    .bind(...params)
    .all();
  allProducts = (productRows || []).map((p: any) => {
    let contactPhone = '';
    try {
      const contact = JSON.parse(p.seller_contact || '{}');
      contactPhone = contact.whatsapp || contact.phone || '';
    } catch {}
    return {
      id: String(p.id),
      name: p.name,
      price: p.price,
      entrepreneur: p.seller_name || 'Vendedor',
      entrepreneurPhone: contactPhone,
      cause: p.cause_title,
      causeId: String(p.cause_id),
      leaderName: p.leader_name,
      leaderId: String(p.cause_leader_id),
      contributionText:
        p.contribution_text ||
        (p.contribution_type === 'percentage'
          ? `${p.contribution_amount}% de cada compra`
          : `$${p.contribution_amount?.toLocaleString('es-CO')} por compra`),
      photoUrl: p.photo_url,
    };
  });

  // Fetch causes for filters
  const { results: causeRows } = await db
    .prepare(
      "SELECT c.id, c.title, l.name as leader_name FROM causes c JOIN leaders l ON c.leader_id = l.id WHERE c.status = 'active' ORDER BY c.title",
    )
    .all();
  causes = (causeRows || []).map((c: any) => ({
    id: String(c.id),
    title: c.title,
    leaderName: c.leader_name,
  }));

  // Fetch leaders for filters
  const { results: leaderRows } = await db
    .prepare('SELECT id, name, city as location FROM leaders ORDER BY name')
    .all();
  leaders = (leaderRows || []).map((l: any) => ({
    id: String(l.id),
    name: l.name,
    location: l.location || '',
  }));
}

// Active filter info
let activeFilter: { type: string; value?: string } | null = null;
if (filterCause) {
  activeFilter = { type: 'causa', value: causes.find((c) => c.id === filterCause)?.title };
}
if (filterLeader) {
  activeFilter = { type: 'lider', value: leaders.find((l) => l.id === filterLeader)?.name };
}
---

<Layout title="Tienda con Propósito" fullWidth>
  <!-- ===== HERO HEADER ===== -->
  <section
    class="relative py-20 px-6 overflow-hidden bg-gradient-to-b from-entrepreneur/[0.07] to-transparent"
  >
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-entrepreneur/15 rounded-full blur-[140px] pointer-events-none"
    >
    </div>

    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <p class="text-entrepreneur text-xs font-bold uppercase tracking-[0.2em] mb-4">
        Tienda con Propósito
      </p>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-white mb-4">
        Productos que transforman
      </h1>
      <p class="text-lg text-dracula-comment-accessible leading-relaxed max-w-2xl mx-auto">
        Productos únicos de emprendedores y líderes colombianos.
        <span class="text-entrepreneur font-medium">Cada compra ilumina una causa social.</span>
      </p>
    </div>
  </section>

  <!-- ===== FILTERS & CONTENT ===== -->
  <section class="border-t border-white/5 px-6 py-12">
    <div class="max-w-7xl mx-auto">
      <!-- Filters Component -->
      <div class="mb-8">
        <StoreFilters
          client:idle
          causes={causes}
          leaders={leaders}
          activeCauseId={filterCause}
          activeLeaderId={filterLeader}
        />
      </div>

      <!-- Active Filter Badge + Results Count -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
        <p class="text-sm text-dracula-comment-accessible flex items-center gap-2">
          <ShoppingBag size={18} weight="duotone" />
          Mostrando <span class="text-white font-bold">{allProducts.length}</span> productos
        </p>

        {
          activeFilter && (
            <div class="flex items-center gap-2">
              <span class="text-dracula-comment-accessible text-sm">
                Filtrando por {activeFilter.type}:
              </span>
              <span class="bg-entrepreneur/10 text-entrepreneur border border-entrepreneur/20 px-4 py-1.5 rounded-full text-sm font-medium flex items-center gap-2">
                {activeFilter.type === 'causa' ? <Heart size={14} weight="duotone" /> : null}
                {activeFilter.value}
                <a
                  href="/store"
                  class="ml-1 text-entrepreneur/60 hover:text-white transition-colors"
                >
                  &times;
                </a>
              </span>
            </div>
          )
        }
      </div>

      <!-- Products Grid -->
      {
        allProducts.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {allProducts.map((product) => (
              <ProductCard
                id={product.id}
                name={product.name}
                price={product.price}
                entrepreneur={product.entrepreneur}
                entrepreneurPhone={product.entrepreneurPhone}
                cause={product.cause}
                causeId={product.causeId}
                leaderName={product.leaderName}
                contributionText={product.contributionText}
                photoUrl={product.photoUrl}
              />
            ))}
          </div>
        ) : (
          <div class="text-center py-24">
            <div class="glass rounded-2xl p-12 max-w-md mx-auto border border-white/10">
              <ShoppingBag
                size={56}
                weight="duotone"
                className="mx-auto mb-6 text-dracula-comment"
              />
              <h3 class="text-xl font-bold text-white mb-2">No hay productos</h3>
              <p class="text-dracula-comment-accessible mb-8">
                No encontramos productos con estos filtros.
              </p>
              <a
                href="/store"
                class="inline-flex items-center gap-2 px-6 py-3 bg-white text-dracula-bg font-bold text-sm rounded-full hover:shadow-[0_0_30px_rgba(255,255,255,0.15)] transition-all duration-300"
              >
                Ver todos los productos
                <ArrowRight size={16} />
              </a>
            </div>
          </div>
        )
      }
    </div>
  </section>

  <!-- ===== CTA SECTION ===== -->
  <section class="border-t border-white/5 px-6 py-24">
    <div class="relative max-w-3xl mx-auto text-center">
      <!-- Ambient glow -->
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-entrepreneur/8 rounded-full blur-[120px] pointer-events-none"
      >
      </div>

      <div class="relative z-10 glass rounded-2xl p-12 border border-entrepreneur/20">
        <Storefront size={40} weight="duotone" className="mx-auto mb-4 text-entrepreneur" />
        <p class="text-entrepreneur text-xs font-bold uppercase tracking-[0.2em] mb-3">
          Vende con Propósito
        </p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-white mb-4">
          ¿Eres emprendedor o líder?
        </h2>
        <p class="text-dracula-comment-accessible mb-8 max-w-lg mx-auto leading-relaxed">
          Publica tus productos y vincúlalos a causas sociales. Vende con propósito y genera impacto
          real en tu comunidad.
        </p>
        <a
          href="/register"
          class="inline-flex items-center gap-2 px-8 py-4 bg-entrepreneur text-white font-bold text-sm rounded-full hover:shadow-[0_0_30px_rgba(34,197,94,0.3)] transition-all duration-300 group"
        >
          Crear mi Tienda
          <ArrowRight size={16} className="transition-transform group-hover:translate-x-1" />
        </a>
      </div>
    </div>
  </section>
</Layout>
