---
import Layout from '../../layouts/Layout.astro';
import ContactButtons from '../../components/ContactButtons';
import ShareButtons from '../../components/ShareButtons';
import {
  ArrowLeft,
  Tag,
  Heart,
  Storefront,
  MapPin,
  Moon,
  UsersThree,
  Images,
  CheckCircle,
  Clock as ClockIcon,
  ArrowRight,
  ShoppingBag,
} from '@phosphor-icons/react';

const { id } = Astro.params;
if (!id) {
  return Astro.redirect('/404');
}

const db = Astro.locals.runtime?.env?.DB;
let product: Record<string, any> | null = null;
let sellerContact: Record<string, string> = {};
let sellerName = '';
let sellerLocation = '';
let sellerType = '';
let sellerId = '';

if (db) {
  const row = await db
    .prepare(
      `
        SELECT p.*,
            e.store_name, e.photo_url as entrepreneur_photo, e.contact_info as entrepreneur_contact,
            e.city as entrepreneur_city, e.department as entrepreneur_department,
            pl.name as product_leader_name, pl.photo_url as product_leader_photo,
            pl.contact_info as product_leader_contact, pl.city as product_leader_city, pl.department as product_leader_department,
            c.title as cause_title, c.leader_id as cause_leader_id,
            l.name as leader_name
        FROM products p
        LEFT JOIN entrepreneurs e ON p.entrepreneur_id = e.id
        LEFT JOIN leaders pl ON p.leader_id = pl.id
        JOIN causes c ON p.cause_id = c.id
        JOIN leaders l ON c.leader_id = l.id
        WHERE p.id = ?
    `,
    )
    .bind(parseInt(id))
    .first();

  if (row) {
    product = row as Record<string, any>;

    if (product.leader_id) {
      sellerType = 'leader';
      sellerName = product.product_leader_name || '';
      sellerLocation = [product.product_leader_city, product.product_leader_department]
        .filter(Boolean)
        .join(', ');
      sellerId = String(product.leader_id);
      try {
        sellerContact = JSON.parse(product.product_leader_contact || '{}');
      } catch {}
    } else {
      sellerType = 'entrepreneur';
      sellerName = product.store_name || '';
      sellerLocation = [product.entrepreneur_city, product.entrepreneur_department]
        .filter(Boolean)
        .join(', ');
      sellerId = String(product.entrepreneur_id);
      try {
        sellerContact = JSON.parse(product.entrepreneur_contact || '{}');
      } catch {}
    }
  }
}

if (!product) {
  return Astro.redirect('/404');
}

const formattedPrice = new Intl.NumberFormat('es-CO', {
  style: 'currency',
  currency: 'COP',
  maximumFractionDigits: 0,
}).format(product.price);

const contributionDisplay =
  product.contribution_text ||
  (product.contribution_type === 'percentage'
    ? `${product.contribution_amount}% de cada compra se dona`
    : `$${product.contribution_amount?.toLocaleString('es-CO')} por compra se donan`);

const sellerProfileUrl =
  sellerType === 'leader' ? `/leaders/${sellerId}` : `/entrepreneurs/${sellerId}`;

let galleryPhotos: string[] = [];
try {
  galleryPhotos = JSON.parse(product.gallery_photos || '[]');
} catch {}

const availabilityMap: Record<string, { label: string; classes: string }> = {
  available: {
    label: 'Disponible',
    classes: 'bg-dracula-green/10 text-dracula-green border-dracula-green/30',
  },
  out_of_stock: {
    label: 'Agotado',
    classes: 'bg-dracula-red/10 text-dracula-red border-dracula-red/30',
  },
  pre_order: {
    label: 'Pre-orden',
    classes: 'bg-dracula-yellow/10 text-dracula-yellow border-dracula-yellow/30',
  },
};
const availability = product.availability ? availabilityMap[product.availability] || null : null;

const sellerColor = sellerType === 'leader' ? 'leader' : 'entrepreneur';
---

<Layout
  title={product.name}
  description={`${product.name} - ${contributionDisplay} a "${product.cause_title}". Compra con proposito en Comoon.`}
  ogImage={product.photo_url}
  ogType="product"
  fullWidth
>
  <!-- ===== BACK NAV ===== -->
  <section class="px-6 pt-8">
    <div class="max-w-7xl mx-auto">
      <a
        href="/store"
        class="inline-flex items-center gap-2 text-sm text-dracula-comment-accessible hover:text-white transition-colors group"
      >
        <ArrowLeft size={16} className="transition-transform group-hover:-translate-x-1" />
        Volver a la Tienda
      </a>
    </div>
  </section>

  <!-- ===== PRODUCT DETAIL ===== -->
  <section class="relative px-6 py-12">
    <!-- Ambient lights -->
    <div
      class="absolute top-0 right-0 w-[500px] h-[500px] bg-entrepreneur/6 rounded-full blur-[140px] pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-1/4 left-0 w-[400px] h-[400px] bg-comoon-purple/6 rounded-full blur-[120px] pointer-events-none"
    >
    </div>

    <div class="relative z-10 max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- ===== LEFT: Product Image ===== -->
        <div class="space-y-4">
          <div class="glass rounded-2xl overflow-hidden border border-white/10">
            {
              product.photo_url ? (
                <img
                  id="main-product-image"
                  src={product.photo_url}
                  alt={product.name}
                  class="w-full h-auto object-cover"
                />
              ) : (
                <div class="w-full aspect-square bg-dracula-current/30 flex items-center justify-center">
                  <ShoppingBag size={80} weight="duotone" className="text-dracula-comment" />
                </div>
              )
            }
          </div>

          <!-- Gallery Thumbnails -->
          {
            galleryPhotos.length > 0 && (
              <div>
                <p class="text-xs text-dracula-comment-accessible mb-3 flex items-center gap-1.5 uppercase tracking-wider font-bold">
                  <Images size={14} weight="duotone" />
                  Galeria ({galleryPhotos.length + (product.photo_url ? 1 : 0)} fotos)
                </p>
                <div class="flex gap-2 overflow-x-auto pb-2">
                  {product.photo_url && (
                    <button
                      class="gallery-thumb shrink-0 w-16 h-16 rounded-xl overflow-hidden border-2 border-entrepreneur/40 hover:border-entrepreneur transition-colors"
                      data-src={product.photo_url}
                      onclick="document.getElementById('main-product-image').src = this.dataset.src"
                    >
                      <img
                        src={product.photo_url}
                        alt="Principal"
                        class="w-full h-full object-cover"
                      />
                    </button>
                  )}
                  {galleryPhotos.map((photo: string, i: number) => (
                    <button
                      class="gallery-thumb shrink-0 w-16 h-16 rounded-xl overflow-hidden border-2 border-white/10 hover:border-entrepreneur/40 transition-colors"
                      data-src={photo}
                      onclick="document.getElementById('main-product-image').src = this.dataset.src"
                    >
                      <img
                        src={photo}
                        alt={`Foto ${i + 1}`}
                        loading="lazy"
                        class="w-full h-full object-cover"
                      />
                    </button>
                  ))}
                </div>
              </div>
            )
          }
        </div>

        <!-- ===== RIGHT: Product Details ===== -->
        <div class="space-y-8">
          <!-- Badges Row -->
          <div class="flex flex-wrap items-center gap-2">
            <span
              class={`px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider flex items-center gap-1.5 border ${
                sellerType === 'leader'
                  ? 'bg-leader/10 text-leader border-leader/20'
                  : 'bg-entrepreneur/10 text-entrepreneur border-entrepreneur/20'
              }`}
            >
              {
                sellerType === 'leader' ? (
                  <UsersThree size={14} weight="duotone" />
                ) : (
                  <Tag size={14} weight="duotone" />
                )
              }
              {sellerType === 'leader' ? 'Producto de Lider' : 'Producto'}
            </span>
            {
              product.category && (
                <span class="px-3 py-1.5 rounded-full text-xs font-medium bg-comoon-purple/10 text-comoon-purple border border-comoon-purple/20 flex items-center gap-1.5">
                  <Tag size={12} weight="duotone" />
                  {product.category}
                </span>
              )
            }
            {
              availability && (
                <span
                  class={`px-3 py-1.5 rounded-full text-xs font-bold border flex items-center gap-1.5 ${availability.classes}`}
                >
                  {product.availability === 'available' && <CheckCircle size={14} weight="fill" />}
                  {product.availability === 'out_of_stock' && <ClockIcon size={14} weight="fill" />}
                  {product.availability === 'pre_order' && <ClockIcon size={14} weight="fill" />}
                  {availability.label}
                </span>
              )
            }
          </div>

          <!-- Title & Price -->
          <div>
            <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-3 leading-tight">
              {product.name}
            </h1>
            <p class="text-4xl font-bold text-entrepreneur">{formattedPrice}</p>
          </div>

          <!-- Description -->
          {
            product.description && (
              <p class="text-lg text-dracula-comment-accessible leading-relaxed">
                {product.description}
              </p>
            )
          }

          <!-- ===== Impact Section ===== -->
          <div class="glass rounded-2xl p-8 border border-leader/20 relative overflow-hidden">
            <!-- Background decoration -->
            <div class="absolute -right-8 -top-8 pointer-events-none opacity-[0.06]">
              <Heart size={160} weight="fill" />
            </div>

            <div class="relative">
              <p
                class="text-xs font-bold uppercase tracking-[0.2em] text-leader mb-3 flex items-center gap-2"
              >
                <Heart size={16} weight="duotone" />
                Tu compra genera impacto real
              </p>
              <p class="text-2xl font-bold text-white mb-5">{contributionDisplay}</p>
              <a
                href={`/causes/${product.cause_id}`}
                class="block glass rounded-xl p-5 border border-leader/10 hover:border-leader/30 transition-all group"
              >
                <p class="text-leader font-bold text-lg mb-1 group-hover:underline">
                  &ldquo;{product.cause_title}&rdquo;
                </p>
                <p class="text-sm text-dracula-comment-accessible">
                  Causa liderada por <span class="text-white font-medium"
                    >{product.leader_name}</span
                  >
                </p>
              </a>
            </div>
          </div>

          <!-- ===== Contact Buttons ===== -->
          <div>
            <p
              class="text-xs font-bold uppercase tracking-[0.2em] text-dracula-comment-accessible mb-4"
            >
              Contactar al vendedor
            </p>
            <ContactButtons
              client:idle
              contactInfo={sellerContact}
              productName={product.name}
              size="lg"
            />
          </div>

          <!-- ===== Seller Info Card ===== -->
          <div
            class="glass rounded-2xl p-5 border border-white/10 flex items-center justify-between"
          >
            <div class="flex items-center gap-3">
              {
                sellerType === 'leader' ? (
                  <div class="w-10 h-10 rounded-full bg-leader/10 flex items-center justify-center">
                    <UsersThree size={20} weight="duotone" className="text-leader" />
                  </div>
                ) : (
                  <div class="w-10 h-10 rounded-full bg-entrepreneur/10 flex items-center justify-center">
                    <Storefront size={20} weight="duotone" className="text-entrepreneur" />
                  </div>
                )
              }
              <div>
                <a
                  href={sellerProfileUrl}
                  class={`font-bold text-white hover:text-${sellerColor} transition-colors`}
                >
                  {sellerName}
                </a>
                {
                  sellerLocation && (
                    <p class="text-xs text-dracula-comment-accessible flex items-center gap-1">
                      <MapPin size={12} weight="duotone" />
                      {sellerLocation}
                    </p>
                  )
                }
              </div>
            </div>
            <a
              href={sellerProfileUrl}
              class={`text-sm font-medium text-${sellerColor} hover:underline flex items-center gap-1 group`}
            >
              Ver perfil
              <ArrowRight size={14} className="transition-transform group-hover:translate-x-0.5" />
            </a>
          </div>

          <!-- ===== Share Section ===== -->
          <div class="pt-6 border-t border-white/5">
            <div class="flex items-center justify-between">
              <span
                class="text-xs text-dracula-comment-accessible flex items-center gap-2 uppercase tracking-wider font-bold"
              >
                <Moon size={14} weight="duotone" className="text-comoon-purple" />
                Difusion Lunar
              </span>
              <ShareButtons
                client:visible
                title={product.name}
                text={`Mira este producto en comoon: ${product.name}. Tu compra apoya la causa "${product.cause_title}"`}
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== RELATED PRODUCTS ===== -->
  <section class="border-t border-white/5 px-6 py-24">
    <div class="max-w-7xl mx-auto text-center">
      <p class="text-leader text-xs font-bold uppercase tracking-[0.2em] mb-4">Descubre mas</p>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-white mb-10">
        Mas productos que apoyan esta causa
      </h2>
      <a
        href={`/store?causa=${product.cause_id}`}
        class="inline-flex glass rounded-2xl p-8 border border-white/10 hover:border-leader/30 transition-all duration-300 group items-center gap-6"
      >
        <Heart size={36} weight="duotone" className="text-leader shrink-0" />
        <div class="text-left">
          <p class="font-bold text-white mb-1 group-hover:text-leader transition-colors">
            Ver mas productos
          </p>
          <p class="text-sm text-dracula-comment-accessible">
            que apoyan &ldquo;{product.cause_title}&rdquo;
          </p>
        </div>
        <ArrowRight
          size={20}
          className="text-dracula-comment ml-4 transition-transform group-hover:translate-x-1"
        />
      </a>
    </div>
  </section>
</Layout>
