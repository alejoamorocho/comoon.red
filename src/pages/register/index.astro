---
import Layout from '../../layouts/Layout.astro';
import RegisterForm from '../../components/RegisterForm';
---

<Layout title="Registro en comoon" fullWidth>
  <!-- ===== HERO ===== -->
  <section
    class="relative py-20 px-6 overflow-hidden bg-gradient-to-b from-comoon-purple/[0.07] to-transparent"
  >
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-comoon-purple/15 rounded-full blur-[140px] pointer-events-none"
    >
    </div>

    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <p class="text-comoon-purple text-xs font-bold uppercase tracking-[0.2em] mb-4">Únete</p>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-white mb-4">
        <span class="text-white">co</span><span class="text-comoon-purple">moon</span>
      </h1>
      <p class="text-lg text-dracula-comment-accessible leading-relaxed max-w-2xl mx-auto">
        Ya sea que lideres una causa o emprendas con propósito, tu lugar está aquí.
      </p>
    </div>
  </section>

  <div class="max-w-3xl mx-auto pb-12 px-6">
    <div class="glass p-8 rounded-2xl shadow-2xl border border-white/5">
      <RegisterForm client:only="react" />
    </div>
  </div>
</Layout>
