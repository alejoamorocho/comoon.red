---
import Layout from '../../layouts/Layout.astro';
import RegisterForm from '../../components/RegisterForm';
---

<Layout title="Registro en comoon">
  <div class="max-w-3xl mx-auto py-12 px-4">
    <div class="text-center mb-10">
      <h1 class="text-4xl font-bold text-white mb-4">Únete a <span class="text-white">co</span><span class="text-comoon-purple">moon</span></h1>
      <p class="text-lg text-dracula-fg/80">
        Ya sea que lideres una causa o emprendas con propósito, tu lugar está aquí.
      </p>
    </div>

    <div class="glass p-8 rounded-2xl shadow-2xl border border-white/5">
      <RegisterForm client:only="react" />
    </div>
  </div>
</Layout>
