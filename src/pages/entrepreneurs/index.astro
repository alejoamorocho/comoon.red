---
import Layout from '../../layouts/Layout.astro';
import ProfileCompleteBadge from '../../components/ProfileCompleteBadge';
import { Storefront, MapPin } from '@phosphor-icons/react';
import { isEntrepreneurProfileComplete } from '../../utils/profileCompletion';

// Fetch entrepreneurs from database
const db = Astro.locals.runtime?.env?.DB;

let entrepreneursData: Array<{
  id: string;
  store_name: string;
  bio: string;
  location: string;
  photoUrl: string;
  category: string;
  activeProductsCount: number;
}> = [];

if (db) {
  try {
    const { results } = await db
      .prepare(
        `
      SELECT e.*,
        (SELECT COUNT(*) FROM products WHERE entrepreneur_id = e.id AND is_active = 1) as active_products_count
      FROM entrepreneurs e
      ORDER BY e.is_verified DESC, e.created_at DESC
    `,
      )
      .all();

    entrepreneursData = (results || []).map((e: any) => ({
      id: String(e.id),
      store_name: e.store_name,
      bio: e.bio || '',
      location: [e.city, e.department].filter(Boolean).join(', ') || e.location || '',
      photoUrl: e.photo_url || '',
      category: '',
      activeProductsCount: e.active_products_count || 0,
    }));
  } catch (e) {
    console.error('Failed to fetch entrepreneurs:', e);
    entrepreneursData = [];
  }
}

// Sort by profile completeness (complete profiles first)
const entrepreneurs = entrepreneursData
  .map((ent) => ({
    ...ent,
    isComplete: isEntrepreneurProfileComplete({
      store_name: ent.store_name,
      bio: ent.bio,
      photo_url: ent.photoUrl,
      location: ent.location,
      activeProductsCount: ent.activeProductsCount,
    }),
  }))
  .sort((a, b) => (b.isComplete ? 1 : 0) - (a.isComplete ? 1 : 0));
---

<Layout title="Emprendedores">
  <div class="py-12 px-4">
    <div class="text-center mb-16">
      <h1 class="text-4xl font-bold mb-4 text-entrepreneur flex items-center justify-center gap-3">
        <Storefront weight="duotone" /> Emprendedores con Proposito
      </h1>
      <p class="text-lg text-dracula-fg/70 max-w-2xl mx-auto">
        Conoce a los creadores detrás de los productos. Cada emprendimiento aquí tiene una historia
        de resiliencia y compromiso social.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      {
        entrepreneurs.map((ent) => (
          <a
            href={`/entrepreneurs/${ent.id}`}
            class="glass block rounded-2xl overflow-hidden hover:scale-[1.02] transition-transform duration-300 group relative"
          >
            {ent.isComplete && (
              <div class="absolute top-2 left-2 z-10">
                <ProfileCompleteBadge client:visible isComplete={true} size="sm" />
              </div>
            )}
            <div class="h-48 overflow-hidden relative">
              <img
                src={ent.photoUrl}
                alt={ent.store_name}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              />
              <div class="absolute top-4 right-4 bg-dracula-bg/80 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-entrepreneur border border-entrepreneur/30">
                {ent.category}
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-white mb-2 group-hover:text-entrepreneur transition-colors">
                {ent.store_name}
              </h3>
              <div class="flex items-center gap-2 text-entrepreneur-dark text-sm font-medium mb-3">
                <MapPin size={18} weight="duotone" /> {ent.location}
              </div>
              <p class="text-dracula-fg/70 text-sm line-clamp-3">{ent.bio}</p>
              <span class="inline-block mt-4 text-entrepreneur font-bold text-sm">
                Ver Tienda &rarr;
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Layout>
