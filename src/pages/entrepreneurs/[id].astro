---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ContactButtons from '../../components/ContactButtons';
import ShareButtons from '../../components/ShareButtons';
import { formatCOP as formatCurrency } from '../../utils/format';
import {
  Storefront,
  MapPin,
  Heart,
  ShoppingBag,
  UsersThree,
  Moon,
  BookOpen,
  Sparkle,
  Handshake,
  CalendarBlank,
  Package,
  Truck,
} from '@phosphor-icons/react';

const { id } = Astro.params;
if (!id) return Astro.redirect('/404');

const db = Astro.locals.runtime?.env?.DB;
let entrepreneur: Record<string, any> | null = null;
let products: Array<Record<string, any>> = [];
let contactInfo: Record<string, string> = {};
let causesSupported: Array<Record<string, any>> = [];

if (db) {
  entrepreneur = (await db
    .prepare('SELECT * FROM entrepreneurs WHERE id = ?')
    .bind(parseInt(id))
    .first()) as Record<string, any> | null;

  if (entrepreneur) {
    try {
      contactInfo = JSON.parse(entrepreneur.contact_info || '{}');
    } catch {}

    // Fetch products
    const { results: productRows } = await db
      .prepare(
        `
            SELECT p.*, c.title as cause_title, l.name as leader_name
            FROM products p
            JOIN causes c ON p.cause_id = c.id
            JOIN leaders l ON c.leader_id = l.id
            WHERE p.entrepreneur_id = ? AND p.is_active = 1
            ORDER BY p.created_at DESC
        `,
      )
      .bind(parseInt(id))
      .all();
    products = (productRows || []).map((p: any) => ({
      id: String(p.id),
      name: p.name,
      price: p.price,
      entrepreneur: entrepreneur!.store_name,
      cause: p.cause_title,
      leaderName: p.leader_name,
      contributionText:
        p.contribution_text ||
        (p.contribution_type === 'percentage'
          ? `${p.contribution_amount}% de cada compra`
          : `$${p.contribution_amount?.toLocaleString('es-CO')} por compra`),
      photoUrl: p.photo_url,
    }));

    // Fetch causes supported (distinct causes from products)
    const { results: causeRows } = await db
      .prepare(
        `
            SELECT DISTINCT c.id, c.title, c.current_amount, c.target_goal, c.status, c.photo_url,
                l.name as leader_name, l.id as leader_id
            FROM causes c
            JOIN products p ON p.cause_id = c.id
            JOIN leaders l ON c.leader_id = l.id
            WHERE p.entrepreneur_id = ?
            ORDER BY c.created_at DESC
        `,
      )
      .bind(parseInt(id))
      .all();
    causesSupported = (causeRows || []) as Array<Record<string, any>>;
  }
}

if (!entrepreneur) return Astro.redirect('/404');

const location =
  [entrepreneur.city, entrepreneur.department].filter(Boolean).join(', ') ||
  entrepreneur.location ||
  '';
const totalProducts = products.length;
const totalCausesSupported = causesSupported.length;

let storePolicies: string = '';
try {
  storePolicies = entrepreneur.store_policies || '';
} catch {}
let shippingInfo: string = '';
try {
  shippingInfo = entrepreneur.shipping_info || '';
} catch {}
---

<Layout
  title={`${entrepreneur.store_name} - Emprendedor`}
  description={entrepreneur.bio || `Conoce a ${entrepreneur.store_name}, emprendedor en Comoon.`}
  ogImage={entrepreneur.photo_url}
  ogType="profile"
  fullWidth
>
  <!-- ===== COVER / HEADER ===== -->
  <section class="relative h-72 md:h-80 w-full overflow-hidden">
    <!-- Cover image -->
    {
      entrepreneur.cover_url || entrepreneur.photo_url ? (
        <img
          src={entrepreneur.cover_url || entrepreneur.photo_url}
          alt={entrepreneur.store_name}
          class="w-full h-full object-cover opacity-40"
        />
      ) : (
        <div class="w-full h-full bg-entrepreneur/10" />
      )
    }

    <!-- Ambient light overlays -->
    <div class="absolute inset-0 bg-gradient-to-t from-dracula-bg via-dracula-bg/60 to-transparent">
    </div>
    <div
      class="absolute top-1/2 left-1/3 w-[500px] h-[500px] bg-entrepreneur/15 rounded-full blur-[160px] pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-0 right-1/4 w-[300px] h-[300px] bg-comoon-purple/10 rounded-full blur-[120px] pointer-events-none"
    >
    </div>
  </section>

  <!-- ===== PROFILE CARD (overlaps cover) ===== -->
  <section class="relative z-10 -mt-32 px-6 pb-12">
    <div class="max-w-5xl mx-auto">
      <div
        class="glass rounded-2xl p-8 md:p-10 border border-white/10 hover:border-entrepreneur/20 transition-all duration-300"
      >
        <div class="md:flex gap-8 items-start">
          <!-- Avatar -->
          <div class="relative shrink-0 mx-auto md:mx-0 mb-6 md:mb-0">
            <div
              class="w-28 h-28 md:w-36 md:h-36 rounded-2xl overflow-hidden border-2 border-entrepreneur/30 shadow-[0_0_40px_rgba(34,197,94,0.1)] bg-dracula-bg"
            >
              {
                entrepreneur.photo_url ? (
                  <img
                    src={entrepreneur.photo_url}
                    alt={entrepreneur.store_name}
                    class="w-full h-full object-cover"
                  />
                ) : (
                  <div class="w-full h-full bg-entrepreneur/10 flex items-center justify-center">
                    <span class="text-4xl font-bold text-entrepreneur">
                      {entrepreneur.store_name?.charAt(0)}
                    </span>
                  </div>
                )
              }
            </div>
            {
              entrepreneur.logo_url && (
                <img
                  src={entrepreneur.logo_url}
                  alt={`Logo de ${entrepreneur.store_name}`}
                  class="absolute -bottom-2 -right-2 w-10 h-10 rounded-full object-cover border-2 border-dracula-bg shadow-lg bg-white"
                />
              )
            }
          </div>

          <!-- Info -->
          <div class="text-center md:text-left flex-1 min-w-0">
            <p class="text-entrepreneur text-xs font-bold uppercase tracking-[0.2em] mb-2">
              Emprendedor
            </p>
            <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-3">
              {entrepreneur.store_name}
            </h1>

            {
              location && (
                <div class="flex items-center justify-center md:justify-start gap-2 text-dracula-comment mb-4">
                  <MapPin size={18} weight="duotone" className="text-entrepreneur/60" />
                  <span class="text-sm">{location}</span>
                </div>
              )
            }

            {
              entrepreneur.bio && (
                <p class="text-dracula-comment-accessible leading-relaxed mb-6 max-w-2xl">
                  {entrepreneur.bio}
                </p>
              )
            }

            <!-- Contact & share -->
            <div class="flex flex-col sm:flex-row items-center gap-4">
              <ContactButtons client:idle contactInfo={contactInfo} size="md" />
              <div class="flex items-center gap-2 text-sm text-dracula-comment">
                <Moon size={16} weight="duotone" className="text-comoon-purple" />
                <span>Difusión Lunar</span>
                <ShareButtons
                  client:visible
                  title={entrepreneur.store_name}
                  text={`Descubre la tienda ${entrepreneur.store_name} en comoon`}
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== STATS ===== -->
  <section class="px-6 pb-16">
    <div class="max-w-5xl mx-auto">
      <div
        class={`grid gap-6 ${entrepreneur.years_in_business ? 'grid-cols-1 sm:grid-cols-3' : 'grid-cols-1 sm:grid-cols-2'}`}
      >
        <div
          class="glass rounded-2xl p-6 border border-white/10 text-center hover:border-entrepreneur/20 transition-all duration-300"
        >
          <ShoppingBag size={24} weight="duotone" className="text-entrepreneur mx-auto mb-2" />
          <p class="text-2xl font-bold text-white">{totalProducts}</p>
          <p class="text-xs text-dracula-comment uppercase tracking-wider mt-1">Productos</p>
        </div>
        <div
          class="glass rounded-2xl p-6 border border-white/10 text-center hover:border-entrepreneur/20 transition-all duration-300"
        >
          <Heart size={24} weight="duotone" className="text-entrepreneur mx-auto mb-2" />
          <p class="text-2xl font-bold text-white">{totalCausesSupported}</p>
          <p class="text-xs text-dracula-comment uppercase tracking-wider mt-1">Causas apoyadas</p>
        </div>
        {
          entrepreneur.years_in_business && (
            <div class="glass rounded-2xl p-6 border border-white/10 text-center hover:border-entrepreneur/20 transition-all duration-300">
              <CalendarBlank
                size={24}
                weight="duotone"
                className="text-entrepreneur mx-auto mb-2"
              />
              <p class="text-2xl font-bold text-white">{entrepreneur.years_in_business}</p>
              <p class="text-xs text-dracula-comment uppercase tracking-wider mt-1">
                Años en el negocio
              </p>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <!-- ===== STORY SECTIONS ===== -->
  {
    (entrepreneur.store_story ||
      entrepreneur.what_makes_special ||
      entrepreneur.social_connection) && (
      <section class="py-24 px-6 border-t border-white/5">
        <div class="max-w-5xl mx-auto space-y-16">
          {/* Nuestra Historia */}
          {entrepreneur.store_story && (
            <div>
              <div class="mb-6">
                <p class="text-entrepreneur text-xs font-bold uppercase tracking-[0.2em] mb-2 flex items-center gap-2">
                  <BookOpen size={16} weight="duotone" />
                  Nuestra Historia
                </p>
                <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white">
                  De dónde venimos
                </h2>
              </div>
              <div class="glass rounded-2xl p-8 md:p-10 border border-white/10">
                <p class="text-dracula-comment-accessible text-lg leading-relaxed whitespace-pre-line">
                  {entrepreneur.store_story}
                </p>
              </div>
            </div>
          )}

          {/* Lo que nos hace especiales */}
          {entrepreneur.what_makes_special && (
            <div>
              <div class="mb-6">
                <p class="text-community text-xs font-bold uppercase tracking-[0.2em] mb-2 flex items-center gap-2">
                  <Sparkle size={16} weight="duotone" />
                  Lo que nos hace especiales
                </p>
                <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white">
                  Nuestro diferencial
                </h2>
              </div>
              <div class="glass rounded-2xl p-8 md:p-10 border border-white/10 hover:border-community/20 transition-all duration-300">
                <p class="text-dracula-comment-accessible text-lg leading-relaxed whitespace-pre-line">
                  {entrepreneur.what_makes_special}
                </p>
              </div>
            </div>
          )}

          {/* Nuestra conexión social */}
          {entrepreneur.social_connection && (
            <div>
              <div class="mb-6">
                <p class="text-comoon-purple text-xs font-bold uppercase tracking-[0.2em] mb-2 flex items-center gap-2">
                  <Handshake size={16} weight="duotone" />
                  Conexión social
                </p>
                <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white">
                  Nuestro compromiso
                </h2>
              </div>
              <div class="glass rounded-2xl p-8 md:p-10 border border-white/10 hover:border-comoon-purple/20 transition-all duration-300">
                <p class="text-dracula-comment-accessible text-lg leading-relaxed whitespace-pre-line">
                  {entrepreneur.social_connection}
                </p>
              </div>
            </div>
          )}
        </div>
      </section>
    )
  }

  <!-- ===== STORE POLICIES & SHIPPING ===== -->
  {
    (storePolicies || shippingInfo) && (
      <section class="py-24 px-6 border-t border-white/5">
        <div class="max-w-5xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {storePolicies && (
              <div class="glass rounded-2xl p-8 border border-white/10 hover:border-leader/20 transition-all duration-300">
                <div class="flex items-center gap-2 mb-4">
                  <Package size={20} weight="duotone" className="text-leader" />
                  <h3 class="text-sm font-bold uppercase tracking-[0.15em] text-leader">
                    Políticas de la tienda
                  </h3>
                </div>
                <p class="text-dracula-comment-accessible leading-relaxed whitespace-pre-line">
                  {storePolicies}
                </p>
              </div>
            )}
            {shippingInfo && (
              <div class="glass rounded-2xl p-8 border border-white/10 hover:border-entrepreneur/20 transition-all duration-300">
                <div class="flex items-center gap-2 mb-4">
                  <Truck size={20} weight="duotone" className="text-entrepreneur" />
                  <h3 class="text-sm font-bold uppercase tracking-[0.15em] text-entrepreneur">
                    Información de envío
                  </h3>
                </div>
                <p class="text-dracula-comment-accessible leading-relaxed whitespace-pre-line">
                  {shippingInfo}
                </p>
              </div>
            )}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== PRODUCTS ===== -->
  <section class="py-24 px-6 border-t border-white/5">
    <div class="max-w-7xl mx-auto">
      <!-- Section header -->
      <div class="mb-12">
        <p class="text-entrepreneur text-xs font-bold uppercase tracking-[0.2em] mb-2">Catálogo</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white">Productos</h2>
      </div>

      {
        products.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {products.map((product) => (
              <ProductCard
                id={product.id}
                name={product.name}
                price={product.price}
                entrepreneur={product.entrepreneur}
                cause={product.cause}
                leaderName={product.leaderName}
                contributionText={product.contributionText}
                photoUrl={product.photoUrl}
              />
            ))}
          </div>
        ) : (
          <div class="glass rounded-2xl p-16 text-center border border-white/10">
            <ShoppingBag size={48} weight="duotone" className="text-entrepreneur/20 mx-auto mb-4" />
            <p class="text-dracula-comment text-lg">
              Este emprendedor aún no tiene productos publicados.
            </p>
          </div>
        )
      }
    </div>
  </section>

  <!-- ===== CAUSES SUPPORTED ===== -->
  <section class="py-24 px-6 border-t border-white/5 relative overflow-hidden">
    <!-- Ambient light -->
    <div
      class="absolute top-1/2 right-0 w-[400px] h-[400px] bg-entrepreneur/8 rounded-full blur-[140px] pointer-events-none"
    >
    </div>

    <div class="max-w-5xl mx-auto relative z-10">
      <!-- Section header -->
      <div class="mb-12">
        <p class="text-entrepreneur text-xs font-bold uppercase tracking-[0.2em] mb-2">
          Impacto social
        </p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white">Causas que apoya</h2>
      </div>

      {
        causesSupported.length > 0 ? (
          <div class="space-y-6">
            {causesSupported.map((cause) => {
              const progress =
                cause.target_goal > 0
                  ? Math.round((cause.current_amount / cause.target_goal) * 100)
                  : 0;
              return (
                <a
                  href={`/causes/${cause.id}`}
                  class="glass rounded-2xl p-6 md:p-8 border border-white/10 hover:border-entrepreneur/30 transition-all duration-300 block group"
                >
                  <div class="flex flex-col sm:flex-row gap-6 items-start">
                    {cause.photo_url && (
                      <img
                        src={cause.photo_url}
                        alt={cause.title}
                        class="w-20 h-20 rounded-xl object-cover shrink-0 border border-white/10"
                      />
                    )}
                    <div class="flex-1 w-full min-w-0">
                      <div class="flex flex-wrap items-center gap-3 mb-2">
                        <h3 class="text-lg font-bold text-white group-hover:text-entrepreneur transition-colors">
                          {cause.title}
                        </h3>
                        {cause.status && (
                          <span
                            class={`text-xs font-bold px-2.5 py-0.5 rounded-full ${cause.status === 'active' ? 'bg-entrepreneur/15 text-entrepreneur' : 'bg-dracula-comment/15 text-dracula-comment'}`}
                          >
                            {cause.status === 'active' ? 'Activa' : 'Finalizada'}
                          </span>
                        )}
                      </div>
                      <p class="text-sm text-dracula-comment mb-4">
                        Liderada por{' '}
                        <span class="text-leader font-medium">{cause.leader_name}</span>
                      </p>

                      {cause.target_goal > 0 && (
                        <div>
                          <div class="flex justify-between text-sm mb-2">
                            <span class="text-entrepreneur font-semibold">
                              {formatCurrency(cause.current_amount || 0)} recaudados
                            </span>
                            <span class="text-dracula-comment">
                              Meta: {formatCurrency(cause.target_goal)}
                            </span>
                          </div>
                          <div
                            class="w-full bg-dracula-bg/60 rounded-full h-2 overflow-hidden"
                            role="progressbar"
                            aria-valuenow={cause.current_amount || 0}
                            aria-valuemin={0}
                            aria-valuemax={cause.target_goal}
                            aria-label={`Progreso de ${cause.title}`}
                          >
                            <div
                              class="bg-gradient-to-r from-entrepreneur to-leader h-full rounded-full transition-all duration-1000"
                              style={`width: ${Math.min(progress, 100)}%`}
                            />
                          </div>
                          <p class="text-xs text-dracula-comment mt-1.5">
                            {progress}% de la meta alcanzada
                          </p>
                        </div>
                      )}
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <div class="glass rounded-2xl p-16 text-center border border-white/10">
            <Heart size={48} weight="duotone" className="text-entrepreneur/20 mx-auto mb-4" />
            <p class="text-dracula-comment text-lg">Este emprendedor aún no apoya ninguna causa.</p>
          </div>
        )
      }
    </div>
  </section>
</Layout>
