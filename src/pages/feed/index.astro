---
import Layout from '../../layouts/Layout.astro';
import { FeedContainer } from '../../components/Feed';

const isAuthenticated = Astro.locals.isAuthenticated || false;
---

<Layout title="Feed - Comoon" fullWidth>
  <!-- Header -->
  <section
    class="relative py-20 px-6 overflow-hidden bg-gradient-to-b from-comoon-purple/[0.07] to-transparent"
  >
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-comoon-purple/15 rounded-full blur-[140px] pointer-events-none"
    >
    </div>

    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <p class="text-comoon-purple text-xs font-bold uppercase tracking-[0.2em] mb-4">Comunidad</p>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-white mb-4">Feed</h1>
      <p class="text-lg text-dracula-comment-accessible leading-relaxed max-w-2xl mx-auto">
        Descubre productos, causas y actualizaciones que transforman comunidades.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-12 px-6">
    <div class="max-w-2xl mx-auto">
      {
        !isAuthenticated && (
          <div class="glass rounded-2xl p-8 border border-white/10 mb-10 text-center">
            <p class="text-dracula-comment mb-5">
              ¿Quieres publicar? Crea tu cuenta como líder o emprendedor.
            </p>
            <div class="flex gap-4 justify-center">
              <a
                href="/login"
                class="px-6 py-2.5 rounded-full border border-white/20 text-white text-sm font-medium hover:bg-white/5 hover:border-white/30 transition-all"
              >
                Ingresar
              </a>
              <a
                href="/register"
                class="px-6 py-2.5 rounded-full bg-comoon-purple text-white text-sm font-bold hover:shadow-[0_0_30px_rgba(153,134,191,0.3)] transition-all"
              >
                Únete
              </a>
            </div>
          </div>
        )
      }

      <!-- Feed Container -->
      <FeedContainer client:load />
    </div>
  </section>
</Layout>
