---
import Layout from '../../layouts/Layout.astro';
import { FeedContainer } from '../../components/Feed';
import CreatePostForm from '../../components/Feed/CreatePostForm';

const isAuthenticated = Astro.locals.isAuthenticated || false;
const user = Astro.locals.user;
const userRole = user?.role;
const userName = user?.name;

// Get user photo from DB if authenticated
let userPhoto: string | undefined;
if (isAuthenticated && user?.profileId) {
  const db = Astro.locals.runtime?.env?.DB;
  if (db) {
    if (userRole === 'leader') {
      const leader = await db
        .prepare('SELECT photo_url FROM leaders WHERE id = ?')
        .bind(user.profileId)
        .first<{ photo_url: string | null }>();
      userPhoto = leader?.photo_url || undefined;
    } else if (userRole === 'entrepreneur') {
      const ent = await db
        .prepare('SELECT photo_url FROM entrepreneurs WHERE id = ?')
        .bind(user.profileId)
        .first<{ photo_url: string | null }>();
      userPhoto = ent?.photo_url || undefined;
    }
  }
}
---

<Layout title="Feed - Comoon" fullWidth>
  <!-- Header -->
  <section class="relative py-24 px-6 border-b border-white/5">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-comoon-purple/8 rounded-full blur-[120px] -z-10"
    >
    </div>

    <div class="max-w-7xl mx-auto text-center">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-comoon-purple mb-4">Comunidad</p>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-white">Feed</h1>
      <p class="text-dracula-comment max-w-lg mx-auto mt-4">
        Descubre productos, causas y actualizaciones que transforman comunidades.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-12 px-6">
    <div class="max-w-2xl mx-auto">
      <!-- Create Post Form (only for authenticated users) -->
      {
        isAuthenticated && (userRole === 'leader' || userRole === 'entrepreneur') && (
          <div class="mb-8">
            <CreatePostForm
              client:load
              userRole={userRole}
              userName={userName}
              userPhoto={userPhoto}
            />
          </div>
        )
      }

      {
        !isAuthenticated && (
          <div class="glass rounded-2xl p-8 border border-white/10 mb-10 text-center">
            <p class="text-dracula-comment mb-5">
              Quieres publicar? Crea tu cuenta como lider o emprendedor.
            </p>
            <div class="flex gap-4 justify-center">
              <a
                href="/login"
                class="px-6 py-2.5 rounded-full border border-white/20 text-white text-sm font-medium hover:bg-white/5 hover:border-white/30 transition-all"
              >
                Ingresar
              </a>
              <a
                href="/register"
                class="px-6 py-2.5 rounded-full bg-comoon-purple text-white text-sm font-bold hover:shadow-[0_0_30px_rgba(153,134,191,0.3)] transition-all"
              >
                Unete
              </a>
            </div>
          </div>
        )
      }

      <!-- Feed Container -->
      <FeedContainer client:load />
    </div>
  </section>
</Layout>
