---
import Layout from '../../layouts/Layout.astro';
import LoginForm from '../../components/LoginForm';
---

<Layout title="Iniciar Sesion" fullWidth>
  <!-- ===== HERO ===== -->
  <section class="relative py-20 px-6 overflow-hidden">
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-comoon-purple/8 rounded-full blur-[140px] pointer-events-none"
    >
    </div>

    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <p class="text-comoon-purple text-xs font-bold uppercase tracking-[0.2em] mb-4">Bienvenido</p>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-white mb-4">Iniciar Sesion</h1>
      <p class="text-lg text-dracula-comment-accessible leading-relaxed max-w-2xl mx-auto">
        Accede a tu panel de control
      </p>
    </div>
  </section>

  <div class="max-w-md mx-auto pb-12 px-6">
    <div class="glass p-8 rounded-2xl">
      <LoginForm client:load />
    </div>
  </div>
</Layout>
