---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ShareButtons from '../../components/ShareButtons';
import {
  UsersThree,
  Star,
  Money,
  TrendUp,
  Newspaper,
  Trophy,
  Heart,
  CheckCircle,
  Clock,
  ArrowRight,
  Image,
  MapPin,
  Users,
  CalendarBlank,
  Tag,
  HandHeart,
  ChartBar,
  ListChecks,
} from '@phosphor-icons/react';

const { id } = Astro.params;
if (!id) return Astro.redirect('/404');

// Get runtime for D1 access
const runtime = Astro.locals.runtime;

let cause = null;
let leader = null;
interface ProductRow {
  id: number;
  name: string;
  price: number;
  entrepreneur_name: string;
  entrepreneur_photo: string;
  contribution_text: string;
  photo_url: string;
  [key: string]: unknown;
}

interface CauseUpdateRow {
  id: number;
  title: string;
  content: string;
  photo_url: string;
  update_type: string;
  is_closing: number | boolean;
  created_at: string;
  leader_name: string;
  leader_photo: string;
  [key: string]: unknown;
}

let products: ProductRow[] = [];
let causeUpdates: CauseUpdateRow[] = [];

if (runtime?.env?.DB) {
  // Fetch cause with leader info
  cause = await runtime.env.DB.prepare(
    `
        SELECT
            c.*,
            l.id as leader_id, l.name as leader_name, l.photo_url as leader_photo,
            l.bio as leader_bio, l.city as leader_city, l.department as leader_department
        FROM causes c
        JOIN leaders l ON c.leader_id = l.id
        WHERE c.id = ?
    `,
  )
    .bind(id)
    .first();

  if (cause) {
    leader = {
      id: cause.leader_id,
      name: cause.leader_name,
      photo_url: cause.leader_photo,
      bio: cause.leader_bio,
      city: cause.leader_city,
      department: cause.leader_department,
    };

    // Fetch products linked to this cause
    const { results: productResults } = await runtime.env.DB.prepare(
      `
            SELECT
                p.*,
                CASE WHEN p.leader_id IS NOT NULL THEN pl.name ELSE e.store_name END as entrepreneur_name,
                CASE WHEN p.leader_id IS NOT NULL THEN pl.photo_url ELSE e.photo_url END as entrepreneur_photo
            FROM products p
            LEFT JOIN entrepreneurs e ON p.entrepreneur_id = e.id
            LEFT JOIN leaders pl ON p.leader_id = pl.id
            WHERE p.cause_id = ? AND p.is_active = 1
            ORDER BY p.created_at DESC
            LIMIT 6
        `,
    )
      .bind(id)
      .all();
    products = (productResults as ProductRow[]) || [];

    // Fetch cause updates
    const { results: updateResults } = await runtime.env.DB.prepare(
      `
            SELECT
                cu.*,
                l.name as leader_name, l.photo_url as leader_photo
            FROM cause_updates cu
            JOIN leaders l ON cu.leader_id = l.id
            WHERE cu.cause_id = ?
            ORDER BY cu.created_at DESC
            LIMIT 10
        `,
    )
      .bind(id)
      .all();
    causeUpdates = (updateResults as CauseUpdateRow[]) || [];
  }
}

// Redirect if cause not found
if (!cause) {
  return Astro.redirect('/404');
}

const progress = cause.target_goal ? (cause.current_amount / cause.target_goal) * 100 : 0;
const isCompleted = cause.status === 'completed';

let evidencePhotos: string[] = [];
try {
  evidencePhotos = JSON.parse(cause.evidence_photos || '[]');
} catch {}

let needs: Array<Record<string, any>> = [];
try {
  needs = JSON.parse(cause.needs || '[]');
} catch {}

let impactMetrics: Array<Record<string, any>> = [];
try {
  impactMetrics = JSON.parse(cause.impact_metrics || '[]');
} catch {}

const needsColorMap: Record<string, string> = {
  voluntarios: 'bg-dracula-purple/20 text-dracula-purple border-dracula-purple/40',
  dinero: 'bg-dracula-green/20 text-dracula-green border-dracula-green/40',
  insumos: 'bg-dracula-orange/20 text-dracula-orange border-dracula-orange/40',
  transporte: 'bg-dracula-cyan/20 text-dracula-cyan border-dracula-cyan/40',
  difusion: 'bg-dracula-pink/20 text-dracula-pink border-dracula-pink/40',
  equipamiento: 'bg-dracula-yellow/20 text-dracula-yellow border-dracula-yellow/40',
};
const defaultNeedColor = 'bg-white/10 text-white border-white/20';

import { getRelativeTime } from '../../utils/format';
import { UPDATE_TYPE_CONFIG } from '../../types/feed';
---

<Layout title={cause.title}>
  <div class="max-w-4xl mx-auto py-12 px-4">
    <!-- Header -->
    <div class="text-center mb-12">
      <div class="flex items-center justify-center gap-2 mb-4">
        {
          isCompleted ? (
            <span class="inline-flex items-center gap-2 bg-dracula-green/20 text-dracula-green px-4 py-1 rounded-full text-sm font-bold border border-dracula-green/50">
              <CheckCircle weight="fill" /> Causa Completada
            </span>
          ) : (
            <span class="inline-flex items-center gap-2 bg-leader/20 text-leader px-4 py-1 rounded-full text-sm font-bold border border-leader/50">
              <Star weight="fill" /> Causa Activa
            </span>
          )
        }
      </div>
      {
        (leader?.city || leader?.department) && (
          <p class="text-dracula-comment flex items-center justify-center gap-1 mt-2">
            <MapPin size={16} />
            {[leader?.city, leader?.department].filter(Boolean).join(', ')}
          </p>
        )
      }
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">{cause.title}</h1>
      <p class="text-xl text-dracula-fg/80 max-w-2xl mx-auto leading-relaxed">
        {cause.description}
      </p>

      {/* Metadata badges row */}
      <div class="flex flex-wrap items-center justify-center gap-3 mt-6">
        {
          cause.category && (
            <span class="inline-flex items-center gap-1 bg-dracula-purple/20 text-dracula-purple px-3 py-1 rounded-full text-sm font-bold border border-dracula-purple/40">
              <Tag size={14} weight="fill" />
              {cause.category}
            </span>
          )
        }
        {
          cause.location && (
            <span class="inline-flex items-center gap-1 bg-leader/20 text-leader px-3 py-1 rounded-full text-sm font-medium border border-leader/40">
              <MapPin size={14} weight="fill" />
              {cause.location}
            </span>
          )
        }
        {
          cause.beneficiary_count && (
            <span class="inline-flex items-center gap-1 bg-dracula-cyan/20 text-dracula-cyan px-3 py-1 rounded-full text-sm font-medium border border-dracula-cyan/40">
              <Users size={14} weight="fill" />
              {Number(cause.beneficiary_count).toLocaleString('es-CO')} beneficiarios
            </span>
          )
        }
      </div>

      {/* Timeline */}
      {
        (cause.start_date || cause.end_date) && (
          <div class="flex items-center justify-center gap-4 mt-4 text-sm text-dracula-comment">
            <CalendarBlank size={16} className="text-dracula-yellow" />
            {cause.start_date && (
              <span>Inicio: {new Date(cause.start_date).toLocaleDateString('es-CO')}</span>
            )}
            {cause.start_date && cause.end_date && <span class="text-white/20">|</span>}
            {cause.end_date && (
              <span>Fin: {new Date(cause.end_date).toLocaleDateString('es-CO')}</span>
            )}
          </div>
        )
      }
    </div>

    {/* Needs / Necesidades */}
    {
      needs.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
            <ListChecks size={28} className="text-dracula-orange" weight="duotone" />
            Qué necesitamos
          </h2>
          <div class="flex flex-wrap gap-3">
            {needs.map((need: any) => {
              const label = typeof need === 'string' ? need : need.label || need.type || '';
              const key = label.toLowerCase();
              const colorClass = needsColorMap[key] || defaultNeedColor;
              return (
                <span
                  class={`inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-bold border ${colorClass}`}
                >
                  <HandHeart size={16} weight="fill" />
                  {label}
                  {need.detail && <span class="font-normal opacity-80">&mdash; {need.detail}</span>}
                </span>
              );
            })}
          </div>
        </div>
      )
    }

    {/* Fund Usage / Uso de fondos */}
    {
      cause.fund_usage && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
            <Money size={28} className="text-dracula-green" weight="duotone" />
            Uso de los fondos
          </h2>
          <div class="glass p-8 rounded-2xl border border-dracula-green/20 bg-dracula-green/5 relative overflow-hidden">
            <div class="absolute -right-4 -top-4 text-dracula-green/10">
              <Money size={100} weight="fill" />
            </div>
            <p class="text-lg text-dracula-fg/90 leading-relaxed relative z-10 whitespace-pre-line">
              {cause.fund_usage}
            </p>
          </div>
        </div>
      )
    }

    {/* Impact Metrics */}
    {
      impactMetrics.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
            <ChartBar size={28} className="text-dracula-cyan" weight="duotone" />
            Métricas de impacto
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            {impactMetrics.map((m: any) => (
              <div class="glass p-5 rounded-2xl text-center border border-dracula-cyan/20">
                <p class="text-3xl font-bold text-dracula-cyan">{m.value}</p>
                <p class="text-sm text-dracula-comment mt-1">{m.label || m.name}</p>
              </div>
            ))}
          </div>
        </div>
      )
    }

    <!-- Progress Card -->
    <div
      class={`glass p-8 rounded-2xl mb-12 border shadow-[0_0_30px_rgba(80,250,123,0.1)] ${isCompleted ? 'border-dracula-green/50' : 'border-dracula-green/30'}`}
    >
      <div class="flex flex-col md:flex-row justify-between items-end mb-4 gap-4">
        <div>
          <p class="text-dracula-comment text-sm font-bold uppercase tracking-wider mb-1">
            Recaudado
          </p>
          <p class="text-4xl font-bold text-dracula-green flex items-center gap-2">
            <Money /> ${(cause.current_amount || 0).toLocaleString()}
          </p>
        </div>
        {
          cause.target_goal && (
            <div class="text-right">
              <p class="text-dracula-comment text-sm font-bold uppercase tracking-wider mb-1">
                Meta
              </p>
              <p class="text-2xl font-bold text-white">${cause.target_goal.toLocaleString()}</p>
            </div>
          )
        }
      </div>

      {
        cause.target_goal && (
          <>
            <div
              class="w-full bg-dracula-bg h-6 rounded-full overflow-hidden border border-white/5 relative"
              role="progressbar"
              aria-valuenow={cause.current_amount}
              aria-valuemin={0}
              aria-valuemax={cause.target_goal}
              aria-label="Progreso de la causa"
            >
              <div
                class={`h-full rounded-full transition-all duration-1000 ease-out ${isCompleted ? 'bg-dracula-green' : 'bg-gradient-to-r from-dracula-green to-emerald-400'}`}
                style={`width: ${Math.min(progress, 100)}%`}
              />
            </div>
            <p class="text-right text-xs text-dracula-cyan mt-2 font-bold flex justify-end items-center gap-1">
              <TrendUp /> {progress.toFixed(1)}% completado
            </p>
          </>
        )
      }

      <div class="grid grid-cols-3 gap-4 mt-6 pt-4 border-t border-white/10">
        <div class="text-center">
          <p class="text-2xl font-bold text-dracula-cyan">{causeUpdates.length}</p>
          <p class="text-xs text-dracula-comment">Actualizaciones</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-entrepreneur">{products.length}</p>
          <p class="text-xs text-dracula-comment">Productos</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-dracula-purple">{getRelativeTime(cause.created_at)}</p>
          <p class="text-xs text-dracula-comment">Creada</p>
        </div>
      </div>

      <div
        class="mt-8 pt-6 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4"
      >
        <div class="flex items-center gap-4">
          {
            leader?.photo_url ? (
              <img
                src={leader.photo_url}
                width={48}
                height={48}
                loading="lazy"
                decoding="async"
                class="w-12 h-12 rounded-full object-cover border-2 border-leader"
                alt={leader.name}
              />
            ) : (
              <div class="w-12 h-12 rounded-full bg-leader/20 flex items-center justify-center border-2 border-leader">
                <span class="text-leader font-bold text-lg">{leader?.name?.charAt(0)}</span>
              </div>
            )
          }
          <div>
            <p class="text-xs text-dracula-comment">Liderado por</p>
            <a
              href={`/leaders/${leader?.id}`}
              class="text-white font-bold hover:text-leader transition-colors"
            >
              {leader?.name}
            </a>
          </div>
        </div>
        <ShareButtons
          client:visible
          title={cause.title}
          text={`Ayuda a la causa "${cause.title}" comprando productos en comoon`}
        />
      </div>
    </div>

    <!-- Evidence Photos Gallery -->
    {
      evidencePhotos.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
            <Image size={28} className="text-dracula-purple" />
            Galeria de Evidencia
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            {evidencePhotos.map((photo: string, i: number) => (
              <div class="rounded-xl overflow-hidden border border-white/10 hover:border-white/20 transition-colors">
                <img
                  src={photo}
                  alt={`Evidencia ${i + 1}`}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
                />
              </div>
            ))}
          </div>
        </div>
      )
    }

    <!-- Cause Updates Section -->
    {
      causeUpdates.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
            <Newspaper size={28} className="text-dracula-cyan" />
            Actualizaciones de la causa
          </h2>

          <div class="space-y-4">
            {causeUpdates.map((update: CauseUpdateRow) => {
              const config = UPDATE_TYPE_CONFIG[update.update_type] || UPDATE_TYPE_CONFIG.progress;
              return (
                <div
                  class={`glass rounded-xl p-5 border border-white/5 hover:border-white/10 transition-colors ${update.is_closing ? 'border-dracula-green/30' : ''}`}
                >
                  <div class="flex items-start justify-between gap-4 mb-3">
                    <div class="flex items-center gap-3">
                      <span
                        class={`px-3 py-1 rounded-full text-xs font-bold ${config.bgClass} ${config.textClass}`}
                      >
                        {config.label}
                      </span>
                      {update.is_closing && (
                        <span class="px-2 py-0.5 rounded-full text-xs bg-dracula-green/20 text-dracula-green font-medium">
                          Cierre Final
                        </span>
                      )}
                    </div>
                    <span class="text-xs text-dracula-comment flex items-center gap-1">
                      <Clock size={12} />
                      {getRelativeTime(update.created_at)}
                    </span>
                  </div>

                  <h3 class="text-lg font-bold text-white mb-2">{update.title}</h3>
                  <p class="text-sm text-dracula-fg/80 leading-relaxed">{update.content}</p>

                  {update.photo_url && (
                    <img
                      src={update.photo_url}
                      alt={update.title}
                      width={800}
                      height={192}
                      loading="lazy"
                      decoding="async"
                      class="mt-4 rounded-lg w-full h-48 object-cover"
                    />
                  )}
                </div>
              );
            })}
          </div>
        </div>
      )
    }

    <!-- Linked Products -->
    {
      products.length > 0 && (
        <div>
          <h2 class="text-3xl font-bold text-entrepreneur mb-8 text-center">
            Productos que financian esta causa
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {products.map((p: ProductRow) => (
              <ProductCard
                id={p.id}
                name={p.name}
                price={p.price}
                entrepreneur={p.entrepreneur_name}
                cause={cause.title}
                leaderName={leader?.name}
                contributionText={p.contribution_text}
                photoUrl={p.photo_url}
              />
            ))}
          </div>
        </div>
      )
    }

    {
      products.length === 0 && !isCompleted && (
        <div class="text-center py-12 glass rounded-xl border border-white/5">
          <p class="text-dracula-comment mb-4">Aun no hay productos vinculados a esta causa.</p>
          <p class="text-sm text-dracula-fg/60">Pronto emprendedores se uniran para apoyarla.</p>
        </div>
      )
    }
  </div>
</Layout>
