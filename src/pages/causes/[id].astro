---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ShareButtons from '../../components/ShareButtons';
import {
  UsersThree,
  Star,
  Money,
  TrendUp,
  Newspaper,
  Trophy,
  Heart,
  CheckCircle,
  Clock,
  ArrowRight,
  Image,
  MapPin,
  Users,
  CalendarBlank,
  Tag,
  HandHeart,
  ChartBar,
  ListChecks,
  Target,
} from '@phosphor-icons/react';

const { id } = Astro.params;
if (!id) return Astro.redirect('/404');

// Get runtime for D1 access
const runtime = Astro.locals.runtime;

let cause = null;
let leader = null;
interface ProductRow {
  id: number;
  name: string;
  price: number;
  entrepreneur_name: string;
  entrepreneur_photo: string;
  contribution_text: string;
  photo_url: string;
  [key: string]: unknown;
}

interface CauseUpdateRow {
  id: number;
  title: string;
  content: string;
  photo_url: string;
  update_type: string;
  is_closing: number | boolean;
  created_at: string;
  leader_name: string;
  leader_photo: string;
  [key: string]: unknown;
}

let products: ProductRow[] = [];
let causeUpdates: CauseUpdateRow[] = [];

if (runtime?.env?.DB) {
  // Fetch cause with leader info
  cause = await runtime.env.DB.prepare(
    `
        SELECT
            c.*,
            l.id as leader_id, l.name as leader_name, l.photo_url as leader_photo,
            l.bio as leader_bio, l.city as leader_city, l.department as leader_department
        FROM causes c
        JOIN leaders l ON c.leader_id = l.id
        WHERE c.id = ?
    `,
  )
    .bind(id)
    .first();

  if (cause) {
    leader = {
      id: cause.leader_id,
      name: cause.leader_name,
      photo_url: cause.leader_photo,
      bio: cause.leader_bio,
      city: cause.leader_city,
      department: cause.leader_department,
    };

    // Fetch products linked to this cause
    const { results: productResults } = await runtime.env.DB.prepare(
      `
            SELECT
                p.*,
                CASE WHEN p.leader_id IS NOT NULL THEN pl.name ELSE e.store_name END as entrepreneur_name,
                CASE WHEN p.leader_id IS NOT NULL THEN pl.photo_url ELSE e.photo_url END as entrepreneur_photo
            FROM products p
            LEFT JOIN entrepreneurs e ON p.entrepreneur_id = e.id
            LEFT JOIN leaders pl ON p.leader_id = pl.id
            WHERE p.cause_id = ? AND p.is_active = 1
            ORDER BY p.created_at DESC
            LIMIT 6
        `,
    )
      .bind(id)
      .all();
    products = (productResults as ProductRow[]) || [];

    // Fetch cause updates
    const { results: updateResults } = await runtime.env.DB.prepare(
      `
            SELECT
                cu.*,
                l.name as leader_name, l.photo_url as leader_photo
            FROM cause_updates cu
            JOIN leaders l ON cu.leader_id = l.id
            WHERE cu.cause_id = ?
            ORDER BY cu.created_at DESC
            LIMIT 10
        `,
    )
      .bind(id)
      .all();
    causeUpdates = (updateResults as CauseUpdateRow[]) || [];
  }
}

let causeObjectives: any[] = [];
if (runtime?.env?.DB) {
  try {
    const { results: objResults } = await runtime.env.DB.prepare(
      'SELECT * FROM cause_objectives WHERE cause_id = ? ORDER BY sort_order ASC, created_at ASC',
    )
      .bind(id)
      .all();
    causeObjectives = objResults || [];
  } catch {}
}

// Redirect if cause not found
if (!cause) {
  return Astro.redirect('/404');
}

const progress = cause.target_goal ? (cause.current_amount / cause.target_goal) * 100 : 0;
const isCompleted = cause.status === 'completed';

let evidencePhotos: string[] = [];
try {
  evidencePhotos = JSON.parse(cause.evidence_photos || '[]');
} catch {}

let needs: Array<Record<string, any>> = [];
try {
  needs = JSON.parse(cause.needs || '[]');
} catch {}

let impactMetrics: Array<Record<string, any>> = [];
try {
  impactMetrics = JSON.parse(cause.impact_metrics || '[]');
} catch {}

const needsColorMap: Record<string, string> = {
  voluntarios: 'bg-dracula-purple/20 text-dracula-purple border-dracula-purple/40',
  dinero: 'bg-dracula-green/20 text-dracula-green border-dracula-green/40',
  insumos: 'bg-dracula-orange/20 text-dracula-orange border-dracula-orange/40',
  transporte: 'bg-dracula-cyan/20 text-dracula-cyan border-dracula-cyan/40',
  difusion: 'bg-dracula-pink/20 text-dracula-pink border-dracula-pink/40',
  equipamiento: 'bg-dracula-yellow/20 text-dracula-yellow border-dracula-yellow/40',
};
const defaultNeedColor = 'bg-white/10 text-white border-white/20';

import { getRelativeTime } from '../../utils/format';
import { UPDATE_TYPE_CONFIG } from '../../types/feed';
---

<Layout title={cause.title} fullWidth>
  <!-- Hero Header -->
  <section
    class="relative py-20 px-6 overflow-hidden bg-gradient-to-b from-leader/[0.07] to-transparent"
  >
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-leader/15 rounded-full blur-[140px] pointer-events-none"
    >
    </div>

    <div class="max-w-4xl mx-auto text-center">
      <!-- Status Badge -->
      <div class="mb-6">
        {
          isCompleted ? (
            <span class="inline-flex items-center gap-2 bg-dracula-green/15 text-dracula-green px-5 py-1.5 rounded-full text-xs font-bold uppercase tracking-[0.15em] border border-dracula-green/30">
              <CheckCircle weight="fill" size={14} /> Completada
            </span>
          ) : (
            <span class="inline-flex items-center gap-2 bg-leader/15 text-leader px-5 py-1.5 rounded-full text-xs font-bold uppercase tracking-[0.15em] border border-leader/30">
              <Star weight="fill" size={14} /> Activa
            </span>
          )
        }
      </div>

      <!-- Location -->
      {
        (leader?.city || leader?.department) && (
          <p class="text-dracula-comment text-sm flex items-center justify-center gap-1.5 mb-4">
            <MapPin size={14} weight="duotone" />
            {[leader?.city, leader?.department].filter(Boolean).join(', ')}
          </p>
        )
      }

      <!-- Title -->
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-white mb-6">
        {cause.title}
      </h1>

      <!-- Description -->
      <p class="text-lg text-dracula-fg/70 max-w-2xl mx-auto leading-relaxed">
        {cause.description}
      </p>

      <!-- Metadata Badges -->
      <div class="flex flex-wrap items-center justify-center gap-3 mt-8">
        {
          cause.category && (
            <span class="inline-flex items-center gap-1.5 bg-dracula-purple/10 text-dracula-purple px-4 py-1.5 rounded-full text-xs font-bold border border-dracula-purple/20">
              <Tag size={13} weight="duotone" />
              {cause.category}
            </span>
          )
        }
        {
          cause.location && (
            <span class="inline-flex items-center gap-1.5 bg-leader/10 text-leader px-4 py-1.5 rounded-full text-xs font-bold border border-leader/20">
              <MapPin size={13} weight="duotone" />
              {cause.location}
            </span>
          )
        }
        {
          cause.beneficiary_count && (
            <span class="inline-flex items-center gap-1.5 bg-dracula-cyan/10 text-dracula-cyan px-4 py-1.5 rounded-full text-xs font-bold border border-dracula-cyan/20">
              <Users size={13} weight="duotone" />
              {Number(cause.beneficiary_count).toLocaleString('es-CO')} beneficiarios
            </span>
          )
        }
      </div>

      <!-- Timeline -->
      {
        (cause.start_date || cause.end_date) && (
          <div class="flex items-center justify-center gap-4 mt-5 text-xs text-dracula-comment">
            <CalendarBlank size={14} className="text-dracula-yellow" weight="duotone" />
            {cause.start_date && (
              <span>Inicio: {new Date(cause.start_date).toLocaleDateString('es-CO')}</span>
            )}
            {cause.start_date && cause.end_date && <span class="text-white/10">|</span>}
            {cause.end_date && (
              <span>Fin: {new Date(cause.end_date).toLocaleDateString('es-CO')}</span>
            )}
          </div>
        )
      }
    </div>
  </section>

  <!-- Main Content -->
  <div class="max-w-4xl mx-auto px-6">
    <!-- Progress Card -->
    <section class="py-12 border-b border-white/5">
      <div
        class={`glass rounded-2xl p-8 border ${isCompleted ? 'border-dracula-green/30 shadow-[0_0_40px_rgba(80,250,123,0.08)]' : 'border-white/10 hover:border-dracula-green/20'} transition-all`}
      >
        <div class="flex flex-col md:flex-row justify-between items-end mb-6 gap-4">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-dracula-comment mb-2">
              Recaudado
            </p>
            <p class="text-4xl font-bold text-dracula-green flex items-center gap-3">
              <Money weight="duotone" size={32} />
              ${(cause.current_amount || 0).toLocaleString()}
            </p>
          </div>
          {
            cause.target_goal && (
              <div class="text-right">
                <p class="text-xs font-bold uppercase tracking-[0.2em] text-dracula-comment mb-2">
                  Meta
                </p>
                <p class="text-2xl font-bold text-white">${cause.target_goal.toLocaleString()}</p>
              </div>
            )
          }
        </div>

        {
          cause.target_goal && (
            <>
              <div
                class="w-full bg-dracula-bg h-4 rounded-full overflow-hidden border border-white/5"
                role="progressbar"
                aria-valuenow={cause.current_amount}
                aria-valuemin={0}
                aria-valuemax={cause.target_goal}
                aria-label="Progreso de la causa"
              >
                <div
                  class={`h-full rounded-full transition-all duration-1000 ease-out ${isCompleted ? 'bg-dracula-green' : 'bg-gradient-to-r from-dracula-green to-emerald-400'}`}
                  style={`width: ${Math.min(progress, 100)}%`}
                />
              </div>
              <p class="text-right text-xs text-dracula-comment mt-2 font-medium flex justify-end items-center gap-1">
                <TrendUp size={12} /> {progress.toFixed(1)}% completado
              </p>
            </>
          )
        }

        <!-- Stats Row -->
        <div class="grid grid-cols-3 gap-4 mt-8 pt-6 border-t border-white/5">
          <div class="text-center">
            <p class="text-2xl font-bold text-dracula-cyan">{causeUpdates.length}</p>
            <p class="text-xs text-dracula-comment mt-1">Actualizaciones</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-entrepreneur">{products.length}</p>
            <p class="text-xs text-dracula-comment mt-1">Productos</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-dracula-purple">
              {getRelativeTime(cause.created_at)}
            </p>
            <p class="text-xs text-dracula-comment mt-1">Creada</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Cause Objectives -->
    {
      causeObjectives.length > 0 && (
        <section class="py-12 border-b border-white/5">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-dracula-yellow mb-3">
            Objetivos
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-8 flex items-center gap-3">
            <Target size={32} className="text-dracula-yellow" weight="duotone" />
            Metas de la causa
          </h2>

          <div class="space-y-4">
            {causeObjectives.map((obj: any) => {
              const isObjCompleted = obj.is_completed === 1 || obj.is_completed === true;
              const hasTarget = obj.target_value && obj.target_value > 0;
              const objProgress = hasTarget
                ? Math.min(((obj.current_value || 0) / obj.target_value) * 100, 100)
                : 0;
              return (
                <div
                  class={`glass rounded-2xl p-6 border transition-all ${isObjCompleted ? 'border-dracula-green/20 bg-dracula-green/[0.03]' : 'border-white/5 hover:border-white/10'}`}
                >
                  <div class="flex items-start gap-4">
                    <div class="mt-1 shrink-0">
                      {isObjCompleted ? (
                        <CheckCircle weight="fill" size={24} className="text-dracula-green" />
                      ) : (
                        <div class="w-6 h-6 rounded-full border-2 border-white/20" />
                      )}
                    </div>
                    <div class="flex-1 min-w-0">
                      <h3
                        class={`text-lg font-bold ${isObjCompleted ? 'text-dracula-green' : 'text-white'}`}
                      >
                        {obj.title}
                      </h3>
                      {obj.description && (
                        <p class="text-sm text-dracula-fg/60 mt-1 leading-relaxed">
                          {obj.description}
                        </p>
                      )}
                      {hasTarget && (
                        <div class="mt-3">
                          <div class="flex items-center justify-between text-xs text-dracula-comment mb-1.5">
                            <span>
                              {(obj.current_value || 0).toLocaleString('es-CO')} /{' '}
                              {obj.target_value.toLocaleString('es-CO')}
                              {obj.unit && <span class="ml-1">{obj.unit}</span>}
                            </span>
                            <span class="font-bold text-dracula-yellow">
                              {objProgress.toFixed(0)}%
                            </span>
                          </div>
                          <div class="w-full bg-dracula-bg h-2 rounded-full overflow-hidden border border-white/5">
                            <div
                              class={`h-full rounded-full transition-all duration-700 ${isObjCompleted ? 'bg-dracula-green' : 'bg-gradient-to-r from-dracula-yellow to-dracula-orange'}`}
                              style={`width: ${objProgress}%`}
                            />
                          </div>
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      )
    }

    <!-- Leader Info Card -->
    <section class="py-12 border-b border-white/5">
      <div
        class="glass rounded-2xl p-6 border border-white/10 hover:border-leader/20 transition-all"
      >
        <div class="flex flex-col md:flex-row justify-between items-center gap-6">
          <div class="flex items-center gap-4">
            {
              leader?.photo_url ? (
                <img
                  src={leader.photo_url}
                  width={56}
                  height={56}
                  loading="lazy"
                  decoding="async"
                  class="w-14 h-14 rounded-full object-cover border-2 border-leader/40"
                  alt={leader.name}
                />
              ) : (
                <div class="w-14 h-14 rounded-full bg-leader/10 flex items-center justify-center border-2 border-leader/30">
                  <span class="text-leader font-bold text-xl">{leader?.name?.charAt(0)}</span>
                </div>
              )
            }
            <div>
              <p class="text-xs font-bold uppercase tracking-[0.15em] text-dracula-comment mb-1">
                Liderado por
              </p>
              <a
                href={`/leaders/${leader?.id}`}
                class="text-white font-bold text-lg hover:text-leader transition-colors"
              >
                {leader?.name}
              </a>
              {
                leader?.bio && (
                  <p class="text-sm text-dracula-comment mt-0.5 line-clamp-1">{leader.bio}</p>
                )
              }
            </div>
          </div>
          <div class="flex items-center gap-4">
            <ShareButtons
              client:visible
              title={cause.title}
              text={`Ayuda a la causa "${cause.title}" comprando productos en comoon`}
              causeId={Number(id)}
            />
            <a
              href={`/leaders/${leader?.id}`}
              class="px-5 py-2 rounded-full border border-leader/30 text-leader text-sm font-bold hover:bg-leader/10 hover:shadow-[0_0_20px_rgba(45,212,191,0.15)] transition-all flex items-center gap-2"
            >
              Ver perfil <ArrowRight size={14} />
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Needs Section -->
    {
      needs.length > 0 && (
        <section class="py-12 border-b border-white/5">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-dracula-orange mb-3">
            Necesidades
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-8 flex items-center gap-3">
            <ListChecks size={32} className="text-dracula-orange" weight="duotone" />
            ¿Qué necesitamos?
          </h2>
          <div class="flex flex-wrap gap-3">
            {needs.map((need: any) => {
              const label = typeof need === 'string' ? need : need.label || need.type || '';
              const key = label.toLowerCase();
              const colorClass = needsColorMap[key] || defaultNeedColor;
              return (
                <span
                  class={`inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-bold border ${colorClass}`}
                >
                  <HandHeart size={16} weight="duotone" />
                  {label}
                  {need.detail && <span class="font-normal opacity-70">&mdash; {need.detail}</span>}
                </span>
              );
            })}
          </div>
        </section>
      )
    }

    <!-- Fund Usage -->
    {
      cause.fund_usage && (
        <section class="py-12 border-b border-white/5">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-dracula-green mb-3">
            Transparencia
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-8 flex items-center gap-3">
            <Money size={32} className="text-dracula-green" weight="duotone" />
            Uso de los fondos
          </h2>
          <div class="glass rounded-2xl p-8 border border-dracula-green/15 relative overflow-hidden">
            <div class="absolute -right-6 -top-6 text-dracula-green/5">
              <Money size={120} weight="fill" />
            </div>
            <p class="text-lg text-dracula-fg/80 leading-relaxed relative z-10 whitespace-pre-line">
              {cause.fund_usage}
            </p>
          </div>
        </section>
      )
    }

    <!-- Impact Metrics -->
    {
      impactMetrics.length > 0 && (
        <section class="py-12 border-b border-white/5">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-dracula-cyan mb-3">
            Resultados
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-8 flex items-center gap-3">
            <ChartBar size={32} className="text-dracula-cyan" weight="duotone" />
            Métricas de impacto
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            {impactMetrics.map((m: any) => (
              <div class="glass rounded-2xl p-6 text-center border border-white/10 hover:border-dracula-cyan/20 transition-all">
                <p class="text-3xl font-bold text-dracula-cyan">{m.value}</p>
                <p class="text-sm text-dracula-comment mt-2">{m.label || m.name}</p>
              </div>
            ))}
          </div>
        </section>
      )
    }

    <!-- Evidence Photos Gallery -->
    {
      evidencePhotos.length > 0 && (
        <section class="py-12 border-b border-white/5">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-dracula-purple mb-3">
            Evidencia
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-8 flex items-center gap-3">
            <Image size={32} className="text-dracula-purple" weight="duotone" />
            Galería
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            {evidencePhotos.map((photo: string, i: number) => (
              <div class="rounded-2xl overflow-hidden border border-white/10 hover:border-dracula-purple/30 transition-all group">
                <img
                  src={photo}
                  alt={`Evidencia ${i + 1}`}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            ))}
          </div>
        </section>
      )
    }

    <!-- Cause Updates Timeline -->
    {
      causeUpdates.length > 0 && (
        <section class="py-12 border-b border-white/5">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-dracula-cyan mb-3">
            Historial
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-8 flex items-center gap-3">
            <Newspaper size={32} className="text-dracula-cyan" weight="duotone" />
            Actualizaciones
          </h2>

          <div class="space-y-4">
            {causeUpdates.map((update: CauseUpdateRow) => {
              const config = UPDATE_TYPE_CONFIG[update.update_type] || UPDATE_TYPE_CONFIG.progress;
              return (
                <div
                  class={`glass rounded-2xl p-6 border transition-all ${update.is_closing ? 'border-dracula-green/20 hover:border-dracula-green/30' : 'border-white/10 hover:border-white/15'}`}
                >
                  <div class="flex items-start justify-between gap-4 mb-4">
                    <div class="flex items-center gap-3">
                      <span
                        class={`px-3 py-1 rounded-full text-xs font-bold ${config.bgClass} ${config.textClass}`}
                      >
                        {config.label}
                      </span>
                      {update.is_closing && (
                        <span class="px-3 py-1 rounded-full text-xs bg-dracula-green/15 text-dracula-green font-bold border border-dracula-green/20">
                          Cierre Final
                        </span>
                      )}
                    </div>
                    <span class="text-xs text-dracula-comment flex items-center gap-1.5 shrink-0">
                      <Clock size={12} weight="duotone" />
                      {getRelativeTime(update.created_at)}
                    </span>
                  </div>

                  <h3 class="text-lg font-bold text-white mb-2">{update.title}</h3>
                  <p class="text-sm text-dracula-fg/70 leading-relaxed">{update.content}</p>

                  {update.photo_url && (
                    <img
                      src={update.photo_url}
                      alt={update.title}
                      width={800}
                      height={192}
                      loading="lazy"
                      decoding="async"
                      class="mt-5 rounded-xl w-full h-48 object-cover border border-white/5"
                    />
                  )}
                </div>
              );
            })}
          </div>
        </section>
      )
    }

    <!-- Linked Products -->
    {
      products.length > 0 && (
        <section class="py-12">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-entrepreneur mb-3">
            Marketplace
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-8">
            Productos que financian esta causa
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {products.map((p: ProductRow) => (
              <ProductCard
                id={p.id}
                name={p.name}
                price={p.price}
                entrepreneur={p.entrepreneur_name}
                cause={cause.title}
                leaderName={leader?.name}
                contributionText={p.contribution_text}
                photoUrl={p.photo_url}
              />
            ))}
          </div>
        </section>
      )
    }

    {
      products.length === 0 && !isCompleted && (
        <section class="py-12">
          <div class="text-center py-16 glass rounded-2xl border border-white/5">
            <p class="text-dracula-comment mb-3">Aún no hay productos vinculados a esta causa.</p>
            <p class="text-sm text-dracula-fg/50">Pronto emprendedores se unirán para apoyarla.</p>
          </div>
        </section>
      )
    }
  </div>
</Layout>
