        </div>
      </div>
    </div>
  </section>

  <!-- Se Parte del Cambio (Comunidad) -->
  <section id="comunidad" aria-labelledby="comunidad-heading" class="py-24 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-community text-sm font-bold uppercase tracking-widest mb-4 block"
          >Se Parte del Cambio</span
        >
        <h2 id="comunidad-heading" class="text-4xl md:text-5xl font-bold text-white mb-6">
          Todos Podemos <span class="text-community">Generar Impacto</span>
        </h2>
        <p class="text-xl text-dracula-fg/70 max-w-3xl mx-auto">
          No necesitas ser lider ni emprendedor para transformar el mundo. Cada accion cuenta:
          comparte, compra y conecta.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <div
          class="glass p-8 rounded-2xl text-center border border-community/20 hover:border-community/50 transition-colors"
        >
          <div
            class="bg-community/20 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6"
