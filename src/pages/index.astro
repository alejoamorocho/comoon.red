---
import Layout from '../layouts/Layout.astro';
import { LeaderTagsList } from '../components/LeaderTagBadge';
import {
  UsersThree,
  Storefront,
  ArrowDown,
  Heart,
  Handshake,
  TrendUp,
  CheckCircle,
  Share,
  ShoppingBag,
  Star,
  Leaf,
  BookOpen,
  FirstAid,
  Quotes,
  ArrowRight,
  Rocket,
} from '@phosphor-icons/react';

// Fetch real stats from DB
const db = Astro.locals.runtime?.env?.DB;
let stats = { leaders: 0, entrepreneurs: 0, products: 0, raised: 0 };
if (db) {
  const [leaderCount, entrepreneurCount, productCount, raisedSum] = await Promise.all([
    db.prepare('SELECT COUNT(*) as c FROM leaders').first<{ c: number }>(),
    db.prepare('SELECT COUNT(*) as c FROM entrepreneurs').first<{ c: number }>(),
    db.prepare('SELECT COUNT(*) as c FROM products WHERE is_active = 1').first<{ c: number }>(),
    db.prepare('SELECT COALESCE(SUM(current_amount), 0) as c FROM causes').first<{ c: number }>(),
  ]);
  stats = {
    leaders: leaderCount?.c || 0,
    entrepreneurs: entrepreneurCount?.c || 0,
    products: productCount?.c || 0,
    raised: raisedSum?.c || 0,
  };
}
const formatCompact = (n: number) => {
  if (n >= 1000000) return `$${Math.round(n / 1000000)}M`;
  if (n >= 1000) return `${Math.round(n / 1000)}K`;
  return String(n);
};
---

<Layout title="Inicio">
  <!-- Hero Section -->
  <section
    aria-labelledby="hero-heading"
    class="min-h-[90vh] flex flex-col items-center justify-center text-center relative px-4 py-16"
  >
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-comoon-purple/20 rounded-full blur-[120px] -z-10 animate-pulse"
    >
    </div>
    <div
      class="absolute bottom-20 right-10 w-[400px] h-[400px] bg-leader/10 rounded-full blur-[100px] -z-10"
    >
    </div>
    <div
      class="absolute top-40 left-10 w-[300px] h-[300px] bg-entrepreneur/10 rounded-full blur-[80px] -z-10"
    >
    </div>

    <!-- Logo Grande -->
    <div class="mb-8">
      <h1
        id="hero-heading"
        class="text-6xl md:text-8xl font-bold tracking-tight animate-comoon-logo"
      >
        <span class="text-white">co</span><span class="text-comoon-purple animate-moon-text"
          >moon</span
        >
      </h1>
      <p class="text-dracula-comment-accessible text-lg mt-2">Economia Solidaria con Proposito</p>
    </div>

    <h2 class="text-3xl md:text-5xl font-bold mb-6 tracking-tight leading-tight max-w-4xl">
      Tu compra ilumina <br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-leader to-entrepreneur"
        >una causa real.</span
      >
    </h2>

    <p class="text-xl text-dracula-fg/70 max-w-2xl mx-auto mb-10 leading-relaxed">
      Conectamos <span class="text-leader font-medium">Lideres</span> que transforman comunidades y <span
        class="text-entrepreneur font-medium">Emprendedores</span
      > que venden con proposito. Juntos, multiplicamos el impacto.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 mb-16">
      <a
        href="/store"
        class="px-8 py-4 bg-white text-dracula-bg font-bold text-lg rounded-full hover:scale-105 transition-transform shadow-xl flex items-center gap-2"
      >
        <ShoppingBag size={20} />
        Explorar la Tienda
      </a>
      <a
        href="#como-funciona"
        class="px-8 py-4 border-2 border-comoon-purple text-comoon-purple font-bold text-lg rounded-full hover:bg-comoon-purple/10 transition-colors flex items-center gap-2"
      >
        Conocer mas
        <ArrowDown size={20} />
      </a>
    </div>

    <a
      href="#porque-comoon"
      class="animate-bounce text-dracula-comment hover:text-white transition-colors flex flex-col items-center gap-2"
    >
      <span class="text-sm font-bold uppercase tracking-widest">Descubre por que existimos</span>
      <ArrowDown size={24} />
    </a>
  </section>

  <!-- Por que Comoon -->
  <section
    id="porque-comoon"
    aria-labelledby="porque-comoon-heading"
    class="py-24 px-4 bg-dracula-current/10"
  >
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-comoon-purple text-sm font-bold uppercase tracking-widest mb-4 block"
          >Nuestra Razon de Ser</span
        >
        <h2 id="porque-comoon-heading" class="text-4xl md:text-5xl font-bold text-white mb-6">
          ¿Por que <span class="text-white">co</span><span class="text-comoon-purple">moon</span>?
        </h2>
        <p class="text-xl text-dracula-fg/70 max-w-3xl mx-auto">
          En Colombia hay miles de lideres sociales haciendo un trabajo increible, pero
          invisibilizado. Y miles de emprendedores que quieren vender con proposito pero no saben
          como.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="glass p-8 rounded-2xl text-center">
          <div
            class="bg-dracula-red/20 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6"
          >
            <Heart size={40} className="text-dracula-red" weight="fill" />
          </div>
          <h3 class="text-xl font-bold text-white mb-4">El Problema</h3>
          <p class="text-dracula-fg/70">
            Los lideres sociales necesitan recursos pero no tienen acceso a financiacion. Los
            consumidores quieren ayudar pero no saben como.
          </p>
        </div>

        <div class="glass p-8 rounded-2xl text-center">
          <div
            class="bg-comoon-purple/20 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6"
          >
            <Handshake size={40} className="text-comoon-purple" weight="fill" />
          </div>
          <h3 class="text-xl font-bold text-white mb-4">La Conexion</h3>
          <p class="text-dracula-fg/70">
            Comoon conecta la necesidad con la solucion. Cada venta de un emprendedor genera una
            donacion a una causa de un lider.
          </p>
        </div>

        <div class="glass p-8 rounded-2xl text-center">
          <div
            class="bg-dracula-green/20 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6"
          >
            <TrendUp size={40} className="text-dracula-green" weight="fill" />
          </div>
          <h3 class="text-xl font-bold text-white mb-4">El Impacto</h3>
          <p class="text-dracula-fg/70">
            Creamos un ecosistema donde comprar es ayudar. Donde emprender es transformar. Donde
            liderar es inspirar.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Como Funciona -->
  <section id="como-funciona" aria-labelledby="como-funciona-heading" class="py-24 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-leader text-sm font-bold uppercase tracking-widest mb-4 block"
          >El Ciclo del Impacto</span
        >
        <h2 id="como-funciona-heading" class="text-4xl md:text-5xl font-bold text-white mb-6">
          ¿Como Funciona?
        </h2>
        <p class="text-xl text-dracula-fg/70 max-w-2xl mx-auto">
          Un flujo simple que genera impacto real y medible.
        </p>
      </div>

      <div class="grid md:grid-cols-4 gap-6 mb-12">
        <div class="text-center relative">
          <div
            class="bg-leader w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 text-dracula-bg font-bold text-xl"
          >
            1
          </div>
          <h4 class="font-bold text-white mb-2">Lider Publica</h4>
          <p class="text-sm text-dracula-fg/70">
            Un lider crea su causa con metas claras y evidencia de su trabajo.
          </p>
          <ArrowRight
            size={24}
            className="absolute right-0 top-6 text-dracula-comment hidden md:block"
          />
        </div>
        <div class="text-center relative">
          <div
            class="bg-entrepreneur w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 text-dracula-bg font-bold text-xl"
          >
            2
          </div>
          <h4 class="font-bold text-white mb-2">Emprendedor Vincula</h4>
          <p class="text-sm text-dracula-fg/70">
            Un emprendedor vincula sus productos a la causa y define su aporte.
          </p>
          <ArrowRight
            size={24}
            className="absolute right-0 top-6 text-dracula-comment hidden md:block"
          />
        </div>
        <div class="text-center relative">
          <div
            class="bg-community w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 text-dracula-bg font-bold text-xl"
          >
            3
          </div>
          <h4 class="font-bold text-white mb-2">Comunidad Comparte</h4>
          <p class="text-sm text-dracula-fg/70">
            La comunidad difunde y compra productos, multiplicando el alcance.
          </p>
          <ArrowRight
            size={24}
            className="absolute right-0 top-6 text-dracula-comment hidden md:block"
          />
        </div>
        <div class="text-center">
          <div
            class="bg-dracula-green w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 text-dracula-bg font-bold text-xl"
          >
            4
          </div>
          <h4 class="font-bold text-white mb-2">Causa Crece</h4>
          <p class="text-sm text-dracula-fg/70">
            La causa recibe fondos y el lider transforma su comunidad.
          </p>
        </div>
      </div>

      <div class="glass p-8 rounded-2xl text-center border border-comoon-purple/30">
        <p class="text-xl text-dracula-fg/90">
          <span class="text-comoon-purple font-bold">El resultado:</span> Un ecosistema donde todos ganan.
          El lider recibe recursos, el emprendedor vende mas, la comunidad genera impacto.
        </p>
      </div>
    </div>
  </section>

  <!-- Que Queremos Lograr -->
  <section
    aria-labelledby="vision-heading"
    class="py-24 px-4 bg-gradient-to-b from-transparent to-dracula-current/20"
  >
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
