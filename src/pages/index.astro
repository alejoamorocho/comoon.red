  <!-- Quienes son los Lideres -->
  <section id="lideres" aria-labelledby="lideres-heading" class="py-24 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-leader text-sm font-bold uppercase tracking-widest mb-4 block"
            >Transformadores</span
          >
          <h2 id="lideres-heading" class="text-4xl md:text-5xl font-bold text-white mb-6">
            ¿Quienes son los <span class="text-leader">Lideres</span>?
          </h2>
          <p class="text-xl text-dracula-fg/70 mb-8">
            Son personas que dedican su vida a transformar sus comunidades. Organizan comedores,
            construyen escuelas, protegen el medio ambiente, preservan la cultura.
          </p>

          <h4 class="font-bold text-white mb-4">Tipos de causas:</h4>
          <div class="flex flex-wrap gap-2 mb-8">
            <LeaderTagsList
              client:visible
              tags={[
                'ambiental',
                'social',
                'educacion',
                'alimentacion',
                'salud',
                'cultura',
                'comunidad',
                'animales',
              ]}
              size="md"
              maxVisible={8}
            />
          </div>

          <ul class="space-y-3 mb-8">
            <li class="flex items-center gap-3 text-dracula-fg/80">
              <CheckCircle size={20} className="text-leader" weight="fill" />
