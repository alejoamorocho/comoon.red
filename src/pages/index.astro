---
import Layout from '../layouts/Layout.astro';
import SearchHero from '../components/SearchHero';
import { UsersThree, Storefront, ArrowDown } from '@phosphor-icons/react';
---

<Layout title="Inicio">
  <!-- Hero Section -->
  <section class="min-h-[80vh] flex flex-col items-center justify-center text-center relative px-4">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-dracula-purple/20 rounded-full blur-[120px] -z-10 animate-pulse"></div>
      
      <span class="mb-4 px-4 py-1 rounded-full border border-dracula-cyan/30 text-dracula-cyan text-sm font-bold bg-dracula-cyan/10 backdrop-blur">
          🌑 Ecosistema de Impacto Social
      </span>
      
      <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight leading-tight">
          Tu compra ilumina <br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-dracula-purple to-dracula-pink">una causa real.</span>
      </h1>
      
      <p class="text-xl text-dracula-fg/70 max-w-2xl mx-auto mb-10 leading-relaxed">
          <b>comoon</b> conecta a <span class="text-white">Líderes Sociales</span> que necesitan recursos con <span class="text-white">Emprendedores</span> que quieren vender con propósito.
      </p>

      <div class="w-full max-w-xl mx-auto mb-16">
          <SearchHero client:visible />
      </div>

      <a href="#como-funciona" class="animate-bounce text-dracula-comment hover:text-white transition-colors flex flex-col items-center gap-2">
          <span class="text-sm font-bold uppercase tracking-widest">Descubre cómo funciona</span>
          <ArrowDown size={24} />
      </a>
  </section>

  <!-- How it Works (The Funnel) -->
  <section id="como-funciona" class="py-24 px-4 bg-dracula-current/10">
      <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold text-center mb-16">¿Cuál es tu rol en esta historia?</h2>
          
          <div class="grid md:grid-cols-2 gap-12">
              <!-- Leader Path -->
              <div class="glass p-8 rounded-2xl border-l-4 border-dracula-purple hover:shadow-[0_0_30px_rgba(189,147,249,0.2)] transition-all group">
                  <div class="bg-dracula-purple/20 w-16 h-16 rounded-full flex items-center justify-center mb-6 text-dracula-purple group-hover:scale-110 transition-transform">
                      <UsersThree size={32} weight="fill" />
                  </div>
                  <h3 class="text-2xl font-bold text-white mb-4">Soy Líder Social</h3>
                  <p class="text-dracula-fg/80 mb-6 min-h-[80px]">
                      Lidero una causa en mi comunidad pero necesito recursos y visibilidad para aumentar mi impacto.
                  </p>
                  <ul class="space-y-3 mb-8 text-dracula-fg/70">
                      <li class="flex items-center gap-2"><span class="text-dracula-green">✓</span> Publica tus causas verificadas</li>
                      <li class="flex items-center gap-2"><span class="text-dracula-green">✓</span> Recibe apoyo de ventas de productos</li>
                      <li class="flex items-center gap-2"><span class="text-dracula-green">✓</span> Gestiona tu perfil y transparencia</li>
                  </ul>
                  <a href="/register" class="w-full block text-center bg-dracula-purple text-dracula-bg font-bold py-3 rounded-xl hover:brightness-110">
                      Registrarme como Líder
                  </a>
              </div>

              <!-- Entrepreneur Path -->
              <div class="glass p-8 rounded-2xl border-l-4 border-dracula-cyan hover:shadow-[0_0_30px_rgba(139,233,253,0.2)] transition-all group">
                  <div class="bg-dracula-cyan/20 w-16 h-16 rounded-full flex items-center justify-center mb-6 text-dracula-cyan group-hover:scale-110 transition-transform">
                      <Storefront size={32} weight="fill" />
                  </div>
                  <h3 class="text-2xl font-bold text-white mb-4">Soy Emprendedor</h3>
                  <p class="text-dracula-fg/80 mb-6 min-h-[80px]">
                      Tengo productos o servicios y quiero que mis ventas tengan un impacto social directo y medible.
                  </p>
                  <ul class="space-y-3 mb-8 text-dracula-fg/70">
                      <li class="flex items-center gap-2"><span class="text-dracula-green">✓</span> Crea tu tienda digital</li>
                      <li class="flex items-center gap-2"><span class="text-dracula-green">✓</span> Vincula productos a causas reales</li>
                      <li class="flex items-center gap-2"><span class="text-dracula-green">✓</span> Fideliza clientes con propósito</li>
                  </ul>
                  <a href="/register" class="w-full block text-center bg-dracula-cyan text-dracula-bg font-bold py-3 rounded-xl hover:brightness-110">
                      Crear mi Tienda
                  </a>
              </div>
          </div>
      </div>
  </section>

  <!-- CTA Final -->
  <section class="py-24 text-center px-4 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-t from-dracula-purple/10 to-transparent pointer-events-none"></div>
      <h2 class="text-3xl md:text-5xl font-bold mb-6">Únete a la revolución de la <br/><span class="text-dracula-green">Economía Solidaria</span></h2>
      <p class="text-xl mb-10 text-dracula-fg/70">Ya somos más de 500 líderes y 200 marcas cambiando el país.</p>
      <a href="/store" class="inline-block px-8 py-4 bg-white text-dracula-bg font-bold text-lg rounded-full hover:scale-105 transition-transform shadow-xl">
          Explorar la Tienda
      </a>
  </section>
</Layout>
