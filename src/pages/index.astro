        </div>
        <div class="glass p-8 rounded-2xl border border-dracula-green/30">
          <h3 class="text-2xl font-bold text-white mb-6 text-center">Nuestras Metas 2025</h3>
          <div class="grid grid-cols-2 gap-6 text-center">
            <div>
              <p class="text-4xl font-bold text-leader">1,000</p>
              <p class="text-sm text-dracula-comment-accessible">Lideres activos</p>
