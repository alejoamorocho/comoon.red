---
import Layout from '../layouts/Layout.astro';
import HeroAuth from '../components/HeroAuth';
import {
  ArrowRight,
  MagnifyingGlass,
  ShoppingBag,
  UsersThree,
  Storefront,
  Heart,
  Rows,
  Leaf,
  HandHeart,
  BookOpen,
  FirstAid,
  PawPrint,
  Palette,
  Users,
  BowlFood,
} from '@phosphor-icons/react';

// Auth state
const isLoggedIn = Astro.locals.isAuthenticated || false;

// DB
const db = Astro.locals.runtime?.env?.DB;

// Fetch featured causes with leaders
let featuredCauses: any[] = [];
if (db) {
  const result = await db
    .prepare(
      `SELECT c.id, c.title, c.description, c.photo_url, c.current_amount, c.target_goal,
              l.name as leader_name, l.photo_url as leader_photo, l.location as leader_location
       FROM causes c
       LEFT JOIN leaders l ON c.leader_id = l.id
       WHERE c.status = 'active'
       ORDER BY c.current_amount DESC
       LIMIT 6`,
    )
    .all();
  featuredCauses = result?.results || [];
}

// Fetch featured products
let featuredProducts: any[] = [];
if (db) {
  const result = await db
    .prepare(
      `SELECT p.id, p.name, p.price, p.photo_url, p.contribution_amount,
              e.store_name, e.location as store_location
       FROM products p
       LEFT JOIN entrepreneurs e ON p.entrepreneur_id = e.id
       WHERE p.is_active = 1
       ORDER BY p.created_at DESC
       LIMIT 6`,
    )
    .all();
  featuredProducts = result?.results || [];
}

const formatCurrency = (n: number) => {
  if (n >= 1000000) return `$${(n / 1000000).toFixed(1)}M`;
  if (n >= 1000) return `$${(n / 1000).toFixed(0)}K`;
  return `$${n.toLocaleString('es-CO')}`;
};

const causeImages = [
  'https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?auto=format&fit=crop&w=600&q=80',
  'https://images.unsplash.com/photo-1532629345422-7515f3d16bb6?auto=format&fit=crop&w=600&q=80',
  'https://images.unsplash.com/photo-1559027615-cd4628902d4a?auto=format&fit=crop&w=600&q=80',
  'https://images.unsplash.com/photo-1593113598332-cd288d649433?auto=format&fit=crop&w=600&q=80',
  'https://images.unsplash.com/photo-1517486808906-6ca8b3f04846?auto=format&fit=crop&w=600&q=80',
  'https://images.unsplash.com/photo-1469571486292-0ba58a3f068b?auto=format&fit=crop&w=600&q=80',
];

const productImages = [
  'https://images.unsplash.com/photo-1559056199-641a0ac8b55e?auto=format&fit=crop&w=600&q=80',
  'https://images.unsplash.com/photo-1553062407-98eeb64c6a62?auto=format&fit=crop&w=600&q=80',
  'https://images.unsplash.com/photo-1606312619070-d48b4c652a52?auto=format&fit=crop&w=600&q=80',
  'https://images.unsplash.com/photo-1474979528491-35740d4de2b2?auto=format&fit=crop&w=600&q=80',
  'https://images.unsplash.com/photo-1509440159596-0249088772ff?auto=format&fit=crop&w=600&q=80',
  'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?auto=format&fit=crop&w=600&q=80',
];

// Placeholder data for when DB is empty
const placeholderCauses = [
  {
    id: 0,
    title: 'Comedor Comunitario Esperanza',
    description: 'Alimentacion para 200 familias vulnerables',
    leader_name: 'Elena Marin',
    leader_location: 'Buenaventura',
    current_amount: 850000,
    target_goal: 2000000,
  },
  {
    id: 0,
    title: 'Escuela de Musica Ancestral',
    description: 'Preservando tradiciones musicales del Pacifico',
    leader_name: 'Carlos Perea',
    leader_location: 'Tumaco',
    current_amount: 420000,
    target_goal: 1500000,
  },
  {
    id: 0,
    title: 'Huerta Urbana Sembrando Vida',
    description: 'Agricultura sostenible en barrios populares',
    leader_name: 'Rosa Caicedo',
    leader_location: 'Cali',
    current_amount: 1200000,
    target_goal: 3000000,
  },
  {
    id: 0,
    title: 'Biblioteca Movil del Choco',
    description: 'Libros y educacion para comunidades rurales',
    leader_name: 'Juan Mosquera',
    leader_location: 'Quibdo',
    current_amount: 680000,
    target_goal: 1800000,
  },
];

const placeholderProducts = [
  {
    id: 0,
    name: 'Cafe de Origen Especial',
    price: 35000,
    contribution_amount: 5000,
    store_name: 'Cafe Origen',
    store_location: 'Manizales',
  },
  {
    id: 0,
    name: 'Mochila Wayuu Artesanal',
    price: 120000,
    contribution_amount: 15000,
    store_name: 'Tejidos del Desierto',
    store_location: 'Riohacha',
  },
  {
    id: 0,
    name: 'Chocolate Chocoano 70%',
    price: 28000,
    contribution_amount: 4000,
    store_name: 'Cacao del Pacifico',
    store_location: 'Quibdo',
  },
  {
    id: 0,
    name: 'Mermelada de Borojo',
    price: 18000,
    contribution_amount: 3000,
    store_name: 'Frutas Nativas',
    store_location: 'Buenaventura',
  },
];

const causes = featuredCauses.length > 0 ? featuredCauses : placeholderCauses;
const products = featuredProducts.length > 0 ? featuredProducts : placeholderProducts;
---

<Layout title="Inicio" fullWidth>
  <!-- ===== HERO ===== -->
  <section class="relative flex items-center justify-center px-6 pt-12 pb-14 overflow-hidden">
    <!-- Ambient -->
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-comoon-purple/8 rounded-full blur-[140px] pointer-events-none"
    >
    </div>

    <div class="relative z-10 w-full max-w-2xl mx-auto text-center">
      <!-- Brand -->
      <h1 class="text-4xl md:text-6xl font-bold tracking-tighter mb-2">
        <span class="text-white">co</span><span class="text-comoon-purple">moon</span>
      </h1>
      <p class="text-dracula-comment-accessible text-sm mb-6">
        Descubre y apoya causas reales a traves del comercio consciente
      </p>

      {
        isLoggedIn ? (
          <div class="max-w-lg mx-auto">
            <form action="/store" method="get" class="relative mb-5">
              <MagnifyingGlass
                size={18}
                className="absolute left-4 top-1/2 -translate-y-1/2 text-dracula-comment"
              />
              <input
                type="text"
                name="q"
                placeholder="Buscar productos, causas, lideres..."
                class="w-full rounded-full border border-white/10 bg-dracula-current/30 backdrop-blur-sm pl-11 pr-5 py-3 text-sm text-white placeholder-dracula-comment outline-none transition-all focus:border-comoon-purple/40 focus:bg-dracula-current/50"
              />
            </form>

            {/* Quick nav pills */}
            <div class="flex flex-wrap items-center justify-center gap-2">
              <a
                href="/feed"
                class="flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-white/8 bg-dracula-current/20 text-xs font-medium text-dracula-fg/70 hover:text-white hover:border-white/20 transition-all"
              >
                <Rows size={13} weight="duotone" /> Feed
              </a>
              <a
                href="/leaders"
                class="flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-leader/15 bg-leader/5 text-xs font-medium text-leader/80 hover:text-leader hover:border-leader/30 transition-all"
              >
                <UsersThree size={13} weight="duotone" /> Lideres
              </a>
              <a
                href="/store"
                class="flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-entrepreneur/15 bg-entrepreneur/5 text-xs font-medium text-entrepreneur/80 hover:text-entrepreneur hover:border-entrepreneur/30 transition-all"
              >
                <Storefront size={13} weight="duotone" /> Tienda
              </a>
              <a
                href="/entrepreneurs"
                class="flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-community/15 bg-community/5 text-xs font-medium text-community/80 hover:text-community hover:border-community/30 transition-all"
              >
                <ShoppingBag size={13} weight="duotone" /> Emprendedores
              </a>
            </div>

            {/* Category tags */}
            <div class="flex flex-wrap items-center justify-center gap-1.5 mt-3">
              {[
                {
                  tag: 'Ambiental',
                  icon: 'leaf',
                  color:
                    'text-dracula-green/60 hover:text-dracula-green border-dracula-green/10 hover:border-dracula-green/25',
                },
                {
                  tag: 'Social',
                  icon: 'heart',
                  color:
                    'text-dracula-pink/60 hover:text-dracula-pink border-dracula-pink/10 hover:border-dracula-pink/25',
                },
                {
                  tag: 'Educacion',
                  icon: 'book',
                  color:
                    'text-dracula-cyan/60 hover:text-dracula-cyan border-dracula-cyan/10 hover:border-dracula-cyan/25',
                },
                {
                  tag: 'Salud',
                  icon: 'first-aid',
                  color:
                    'text-dracula-red/60 hover:text-dracula-red border-dracula-red/10 hover:border-dracula-red/25',
                },
                {
                  tag: 'Cultura',
                  icon: 'palette',
                  color:
                    'text-dracula-orange/60 hover:text-dracula-orange border-dracula-orange/10 hover:border-dracula-orange/25',
                },
                {
                  tag: 'Animales',
                  icon: 'paw',
                  color:
                    'text-dracula-yellow/60 hover:text-dracula-yellow border-dracula-yellow/10 hover:border-dracula-yellow/25',
                },
                {
                  tag: 'Alimentacion',
                  icon: 'bowl',
                  color:
                    'text-community/60 hover:text-community border-community/10 hover:border-community/25',
                },
                {
                  tag: 'Comunidad',
                  icon: 'users',
                  color:
                    'text-dracula-purple/60 hover:text-dracula-purple border-dracula-purple/10 hover:border-dracula-purple/25',
                },
              ].map((item) => (
                <a
                  href={`/leaders?tag=${item.tag.toLowerCase()}`}
                  class={`px-2.5 py-1 rounded-full border text-[10px] font-medium transition-all ${item.color}`}
                >
                  {item.tag}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <div class="max-w-md mx-auto">
            <HeroAuth client:load />
          </div>
        )
      }
    </div>
  </section>

  <!-- ===== FEATURED CAUSES ===== -->
  <section class="px-6 pb-16">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-semibold text-white">Causas destacadas</h2>
        <a
          href="/leaders"
          class="text-sm text-dracula-comment-accessible hover:text-white transition-colors flex items-center gap-1 group"
        >
          Ver todas <ArrowRight
            size={14}
            className="group-hover:translate-x-0.5 transition-transform"
          />
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {
          causes.slice(0, 4).map((cause: any, i: number) => (
            <a
              href={cause.id ? `/causes/${cause.id}` : '/leaders'}
              class="group glass rounded-xl overflow-hidden hover:border-leader/20 transition-all duration-200"
            >
              <div class="relative h-36 overflow-hidden">
                <img
                  src={cause.photo_url || causeImages[i % causeImages.length]}
                  alt={cause.title}
                  width="600"
                  height="144"
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-dracula-bg/70 to-transparent" />
                {cause.target_goal > 0 && (
                  <div class="absolute bottom-2 left-3 right-3">
                    <div class="h-1 bg-white/15 rounded-full overflow-hidden">
                      <div
                        class="h-full bg-leader rounded-full"
                        style={`width: ${Math.min(100, Math.round(((cause.current_amount || 0) / cause.target_goal) * 100))}%`}
                      />
                    </div>
                  </div>
                )}
              </div>
              <div class="p-4">
                <h3 class="font-semibold text-white text-sm mb-1 group-hover:text-leader transition-colors">
                  {cause.title}
                </h3>
                <p class="text-xs text-dracula-comment-accessible line-clamp-1 mb-3">
                  {cause.description}
                </p>
                <div class="flex items-center gap-2">
                  {cause.leader_photo ? (
                    <img
                      src={cause.leader_photo}
                      alt=""
                      width="20"
                      height="20"
                      class="w-5 h-5 rounded-full object-cover"
                    />
                  ) : (
                    <div class="w-5 h-5 rounded-full bg-leader/20 flex items-center justify-center text-leader text-[10px] font-bold">
                      {(cause.leader_name || 'L')[0]}
                    </div>
                  )}
                  <span class="text-xs text-dracula-comment">{cause.leader_name}</span>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== PRODUCTS ===== -->
  <section class="px-6 pb-20">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-semibold text-white">Productos con proposito</h2>
        <a
          href="/store"
          class="text-sm text-dracula-comment-accessible hover:text-white transition-colors flex items-center gap-1 group"
        >
          Ver tienda <ArrowRight
            size={14}
            className="group-hover:translate-x-0.5 transition-transform"
          />
        </a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4">
        {
          products.slice(0, 6).map((product: any, i: number) => (
            <a
              href={product.id ? `/store/${product.id}` : '/store'}
              class="group glass rounded-xl overflow-hidden hover:border-entrepreneur/20 transition-all duration-200"
            >
              <div class="relative aspect-square overflow-hidden bg-dracula-current/30">
                {product.photo_url ? (
                  <img
                    src={product.photo_url}
                    alt={product.name}
                    width="300"
                    height="300"
                    loading="lazy"
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                ) : (
                  <img
                    src={productImages[i % productImages.length]}
                    alt={product.name}
                    width="300"
                    height="300"
                    loading="lazy"
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                )}
                {product.contribution_amount > 0 && (
                  <div class="absolute top-2 right-2">
                    <span class="text-[10px] bg-entrepreneur/90 text-white px-1.5 py-0.5 rounded-full font-medium">
                      +{formatCurrency(product.contribution_amount)}
                    </span>
                  </div>
                )}
              </div>
              <div class="p-3">
                <h3 class="font-medium text-white text-xs mb-0.5 group-hover:text-entrepreneur transition-colors line-clamp-1">
                  {product.name}
                </h3>
                <p class="text-[10px] text-dracula-comment mb-1">{product.store_name}</p>
                <p class="text-sm font-bold text-white">{formatCurrency(product.price || 0)}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
