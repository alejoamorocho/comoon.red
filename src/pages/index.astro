            <li class="flex items-center gap-3 text-dracula-fg/80">
              <CheckCircle size={20} className="text-entrepreneur" weight="fill" />
              Vincula cada producto a una causa
            </li>
            <li class="flex items-center gap-3 text-dracula-fg/80">
              <CheckCircle size={20} className="text-entrepreneur" weight="fill" />
              Define tu aporte (% o monto fijo)
            </li>
            <li class="flex items-center gap-3 text-dracula-fg/80">
              <CheckCircle size={20} className="text-entrepreneur" weight="fill" />
              Fideliza clientes con proposito
            </li>
          </ul>

          <a
            href="/register"
            class="inline-flex items-center gap-2 px-8 py-4 bg-entrepreneur text-dracula-bg font-bold text-lg rounded-xl hover:brightness-110 transition-all"
          >
            <Storefront size={24} />
            Soy Emprendedor, quiero vender
