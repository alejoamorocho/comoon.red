---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import Navbar from '../components/Navbar';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
  fullWidth?: boolean;
}

const {
  title,
  description = 'Conectando líderes sociales y emprendedores bajo la luz de la luna.',
  ogImage,
  ogUrl,
  ogType = 'website',
  fullWidth = false,
} = Astro.props;
const canonicalUrl = ogUrl || Astro.url.href;

// Get authentication state from middleware
const isLoggedIn = Astro.locals.isAuthenticated || false;
const userRole = Astro.locals.user?.role;
const onboardingComplete = Astro.locals.user?.onboardingComplete;
const userName = Astro.locals.user?.name;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <title>{title} | comoon</title>
    <ViewTransitions />
    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | comoon`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:site_name" content="comoon" />
    <!-- Twitter -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={`${title} | comoon`} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
  </head>
  <body class="bg-dracula-bg text-dracula-fg min-h-screen flex flex-col">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-dracula-purple focus:text-white focus:rounded-lg"
    >
      Saltar al contenido principal
    </a>
    <Navbar
      client:load
      isLoggedIn={isLoggedIn}
      userRole={userRole}
      onboardingComplete={onboardingComplete}
      userName={userName}
      currentPath={Astro.url.pathname}
    />
    <main
      id="main-content"
      class:list={['flex-grow', fullWidth ? '' : 'container mx-auto px-4 py-8']}
    >
      <slot />
    </main>
    <footer class="border-t border-white/5 bg-dracula-current/20">
      <div class="max-w-7xl mx-auto px-6 py-16">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
          <div>
            <a href="/" class="group flex items-center gap-2 mb-4">
              <svg
                width="24"
                height="24"
                viewBox="0 0 375 375"
                preserveAspectRatio="xMidYMid meet"
                class="transition-transform duration-700 group-hover:rotate-[360deg]"
              >
                <defs>
                  <clipPath id="footer-moon-outer"
                    ><path
                      d="M 59.0625 37.5 L 316.3125 37.5 L 316.3125 337.5 L 59.0625 337.5 Z"
                      clip-rule="nonzero"></path></clipPath
                  >
                  <clipPath id="footer-moon-inner"
                    ><path
                      d="M 153.1875 92.722656 L 315.9375 92.722656 L 315.9375 282.472656 L 153.1875 282.472656 Z"
                      clip-rule="nonzero"></path></clipPath
                  >
                </defs>
                <g clip-path="url(#footer-moon-outer)"
                  ><path
                    fill="#9986bf"
                    d="M 232.242188 321.746094 C 263.921875 321.746094 293.058594 310.769531 316.019531 292.398438 C 288.84375 320.152344 250.902344 337.367188 208.972656 337.367188 C 126.183594 337.367188 59.0625 270.246094 59.0625 187.457031 C 59.0625 104.671875 126.183594 37.570312 208.972656 37.570312 C 250.902344 37.570312 288.824219 54.785156 316.019531 82.539062 C 293.058594 64.167969 263.921875 53.195312 232.242188 53.195312 C 158.09375 53.195312 97.976562 113.308594 97.976562 187.457031 C 97.976562 261.628906 158.09375 321.722656 232.242188 321.722656 Z"
                  ></path></g
                >
                <g clip-path="url(#footer-moon-inner)"
                  ><path
                    fill="#fdfdfd"
                    d="M 206.285156 102.5 C 186.226562 102.5 167.777344 109.449219 153.242188 121.082031 C 170.445312 103.507812 194.46875 92.609375 221.019531 92.609375 C 273.4375 92.609375 315.9375 135.109375 315.9375 187.527344 C 315.9375 239.945312 273.4375 282.429688 221.019531 282.429688 C 194.46875 282.429688 170.460938 271.53125 153.242188 253.957031 C 167.777344 265.589844 186.226562 272.539062 206.285156 272.539062 C 253.234375 272.539062 291.296875 234.472656 291.296875 187.527344 C 291.296875 140.5625 253.234375 102.511719 206.285156 102.511719 Z"
                  ></path></g
                >
              </svg>
              <span class="text-xl font-bold lowercase tracking-tight">
                <span class="text-white">co</span><span class="text-comoon-purple">moon</span>
              </span>
            </a>
            <p class="text-sm text-dracula-comment-accessible leading-relaxed">
              Economía solidaria con propósito. Cada compra ilumina una causa real.
            </p>
          </div>
          <div>
            <h4 class="text-xs font-bold uppercase tracking-widest text-dracula-fg/50 mb-4">
              Explorar
            </h4>
            <ul class="space-y-2 text-sm">
              <li>
                <a
                  href="/feed"
                  class="text-dracula-comment-accessible hover:text-white transition-colors">Feed</a
                >
              </li>
              <li>
                <a
                  href="/store"
                  class="text-dracula-comment-accessible hover:text-white transition-colors"
                  >Tienda</a
                >
              </li>
              <li>
                <a
                  href="/leaders"
                  class="text-dracula-comment-accessible hover:text-white transition-colors"
                  >Líderes</a
                >
              </li>
              <li>
                <a
                  href="/entrepreneurs"
                  class="text-dracula-comment-accessible hover:text-white transition-colors"
                  >Emprendedores</a
                >
              </li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-bold uppercase tracking-widest text-dracula-fg/50 mb-4">
              Únete
            </h4>
            <ul class="space-y-2 text-sm">
              <li>
                <a
                  href="/register"
                  class="text-dracula-comment-accessible hover:text-white transition-colors"
                  >Registrarse</a
                >
              </li>
              <li>
                <a
                  href="/login"
                  class="text-dracula-comment-accessible hover:text-white transition-colors"
                  >Iniciar Sesión</a
                >
              </li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-bold uppercase tracking-widest text-dracula-fg/50 mb-4">
              Legal
            </h4>
            <ul class="space-y-2 text-sm">
              <li>
                <a
                  href="#"
                  class="text-dracula-comment-accessible hover:text-white transition-colors"
                  >Términos</a
                >
              </li>
              <li>
                <a
                  href="#"
                  class="text-dracula-comment-accessible hover:text-white transition-colors"
                  >Privacidad</a
                >
              </li>
            </ul>
          </div>
        </div>
        <div
          class="border-t border-white/5 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-dracula-comment-accessible"
        >
          <p>
            &copy; {new Date().getFullYear()}
            <span class="font-bold"
              ><span class="text-white">co</span><span class="text-comoon-purple">moon</span></span
            >
          </p>
          <p>
            dev: <a
              href="https://github.com/alejoamorocho"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white transition-colors"
              ><span class="text-white">Alejo</span><span class="text-comoon-purple">Amorocho</span
              ></a
            >
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
